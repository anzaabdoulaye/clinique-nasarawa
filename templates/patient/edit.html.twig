{{ form_start(form, {'attr': {'id': 'PatientEditForm'}}) }}

<div class="row g-3">
  <div class="col-md-6">{{ form_row(form.nom) }}</div>
  <div class="col-md-6">{{ form_row(form.prenom) }}</div>

  <div class="col-md-6">{{ form_row(form.dateNaissance) }}</div>
  <div class="col-md-6">{{ form_row(form.sexe) }}</div>

  <div class="col-md-6">{{ form_row(form.telephone) }}</div>
  <div class="col-md-6">{{ form_row(form.code) }}</div>

  <div class="col-md-6">{{ form_row(form.groupeSanguin) }}</div>
  <div class="col-md-6">{{ form_row(form.adresse) }}</div>

  <div class="col-md-6">{{ form_row(form.emergencyContactName) }}</div>
  <div class="col-md-6">{{ form_row(form.emergencyContactRelation) }}</div>
  <div class="col-md-6">{{ form_row(form.emergencyContactPhone) }}</div>
  <div class="col-md-6">{{ form_row(form.emergencyContactAddress) }}</div>

  <div class="col-md-6">{{ form_row(form.taille) }}</div>
  <div class="col-md-6">{{ form_row(form.poids) }}</div>
  <div class="col-md-6">{{ form_row(form.allergies) }}</div>
  <div class="col-md-6">{{ form_row(form.antecedentsMedicaux) }}</div>
  <div class="col-md-6">{{ form_row(form.antecedentsChirurgicaux) }}</div>
  <div class="col-md-6">{{ form_row(form.maladiesChroniques) }}</div>
  <div class="col-md-6">{{ form_row(form.traitementEnCours) }}</div>
  <div class="col-md-6">{{ form_row(form.handicap) }}</div>
  <div class="col-md-6">{{ form_row(form.grossesse) }}</div>
</div>

<div class="d-flex justify-content-end mt-4 gap-2">
  <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
  <button class="btn btn-primary">Mettre à jour</button>
</div>

{{ form_end(form) }}