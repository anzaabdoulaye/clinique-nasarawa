<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Fiche Patient — {{ patient.nom }} {{ patient.prenom }}</title>

    <style>
        @page {
            size: A4 portrait;
            margin: 5mm;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 9.5px;
            color: #1f2937;
        }

        .document {
            width: 100%;
        }

        .top-bar {
            height: 4px;
            background: #0f4c81;
            margin-bottom: 6px;
        }

        .header-table,
        .meta-table,
        .data-table,
        .footer-table,
        .signature-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .meta-table td,
        .footer-table td,
        .signature-table td {
            vertical-align: top;
        }

        .clinic-logo {
            width: 24mm;
            height: 24mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #ffffff;
            border-radius: 50%;
        }

        .clinic h1 {
            margin: 0 0 3px 0;
            font-size: 13px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
        }

        .clinic .sub {
            font-size: 8px;
            line-height: 1.3;
            color: #6b7280;
        }

        .title-box {
            width: 32mm;
            border: 1px solid #d1d5db;
            padding: 5px;
            text-align: center;
            background: #f8fafc;
        }

        .title-box .title {
            font-size: 12px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .title-box .ref {
            font-size: 10px;
            font-weight: bold;
        }

        .separator {
            border-bottom: 1px solid #d1d5db;
            margin: 6px 0;
        }

        .meta-box,
        .box,
        .table-wrap,
        .totals-box {
            border: 1px solid #d1d5db;
        }

        .meta-box {
            padding: 5px;
            margin-bottom: 6px;
        }

        .meta-table td {
            width: 50%;
            padding: 2px;
            line-height: 1.3;
        }

        .section {
            margin-top: 5px;
        }

        .section-title {
            padding: 4px 6px;
            font-size: 9px;
            font-weight: bold;
            color: #0f4c81;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-bottom: none;
            text-transform: uppercase;
        }

        .box {
            padding: 5px 6px;
            line-height: 1.3;
        }

        .label {
            color: #6b7280;
            font-weight: bold;
        }

        .badges {
            margin-top: 4px;
        }

        .badge {
            display: inline-block;
            padding: 2px 7px;
            margin-right: 4px;
            font-size: 7.5px;
            border: 1px solid #d1d5db;
            background: #f8fafc;
            border-radius: 10px;
            color: #374151;
        }

        .table-wrap {
            border-top: none;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #e5e7eb;
            padding: 4px;
            font-size: 8.5px;
            text-align: left;
            vertical-align: top;
        }

        .data-table th {
            color: #ffffff;
            background: #0f4c81;
            font-weight: bold;
        }

        .right {
            text-align: right;
        }

        .center {
            text-align: center;
        }

        .footer-block {
            border-top: 1px dashed #d1d5db;
            margin-top: 6px;
            padding-top: 6px;
        }

        .footer-left {
            font-size: 8px;
            color: #6b7280;
            line-height: 1.3;
            padding-right: 6px;
        }

        .no-print {
            display: none;
        }

        @media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="document">
        <div class="top-bar"></div>

        <table class="header-table">
            <tr>
                <td style="width:18%;">
                    {% if logo_path is defined and logo_path %}
                        <img src="{{ logo_path }}" alt="Logo Clinique NASSARAWA" class="clinic-logo">
                    {% endif %}
                </td>

                <td style="width:52%;">
                    <div class="clinic">
                        <h1>Clinique NASSARAWA</h1>
                        <div class="sub">
                            NIF : 120402/R<br>
                            RCCM : NE-NIM-01-2024-B12-00145<br>
                            Adresse : Yantala Haut, Avenue du Daoura YN 187, Niamey<br>
                            Tél : 20 75 51 02 / 82 09 61 12<br>
                            BP : 2120 Niamey<br>
                            Email : nassrawaclinique@gmail.com
                        </div>
                    </div>
                </td>

                <td style="width:30%; text-align:right;">
                    <div class="title-box">
                        <div class="title">Fiche Patient</div>
                        <div class="ref">{{ patient.code }}</div>
                    </div>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <div class="meta-box">
            <table class="meta-table">
                <tr>
                    <td>
                        <strong>Nom complet :</strong>
                        {{ patient.nom }} {{ patient.prenom }}
                    </td>
                    <td>
                        <strong>Date de naissance :</strong>
                        {{ patient.dateNaissance ? patient.dateNaissance|date('d/m/Y') : '-' }}
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Sexe :</strong>
                        {% if patient.sexe == 'M' %}Homme{% elseif patient.sexe == 'F' %}Femme{% else %}-{% endif %}
                    </td>
                    <td>
                        <strong>Téléphone :</strong>
                        {{ patient.telephone ?? '-' }}
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Adresse :</strong>
                        {{ patient.adresse ?? '-' }}
                    </td>
                    <td>
                        <strong>Groupe sanguin :</strong>
                        {{ patient.groupeSanguin ?? '-' }}
                    </td>
                </tr>
            </table>

            <div class="badges">
                {% if patient.grossesse %}
                    <span class="badge">Enceinte</span>
                {% endif %}
                {% if patient.handicap %}
                    <span class="badge">Handicap : {{ patient.handicap }}</span>
                {% endif %}
            </div>
        </div>

        <div class="section">
            <div class="section-title">Informations médicales générales</div>
            <div class="box">
                <table class="data-table">
                    <tr>
                        <td style="width:25%;"><strong>Taille :</strong></td>
                        <td style="width:25%;">{{ patient.taille ? patient.taille ~ ' m' : '-' }}</td>
                        <td style="width:25%;"><strong>Poids :</strong></td>
                        <td style="width:25%;">{{ patient.poids ? patient.poids ~ ' kg' : '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Température :</strong></td>
                        <td>{{ patient.temperature ? patient.temperature ~ ' °C' : '-' }}</td>
                        <td><strong>Tension :</strong></td>
                        <td>{{ patient.tensionArterielle ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Fréquence cardiaque :</strong></td>
                        <td>{{ patient.frequenceCardiaque ? patient.frequenceCardiaque ~ ' bpm' : '-' }}</td>
                        <td><strong>Fréquence respiratoire :</strong></td>
                        <td>{{ patient.frequenceRespiratoire ? patient.frequenceRespiratoire ~ ' /min' : '-' }}</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Antécédents médicaux</div>
            <div class="box">
                <div style="margin-bottom: 8px;">
                    <strong>Antécédents médicaux :</strong><br>
                    {{ patient.antecedentsMedicaux ?? 'Aucun' }}
                </div>
                <div style="margin-bottom: 8px;">
                    <strong>Antécédents chirurgicaux :</strong><br>
                    {{ patient.antecedentsChirurgicaux ?? 'Aucun' }}
                </div>
                <div style="margin-bottom: 8px;">
                    <strong>Maladies chroniques :</strong><br>
                    {{ patient.maladiesChroniques ?? 'Aucune' }}
                </div>
                <div style="margin-bottom: 8px;">
                    <strong>Allergies :</strong><br>
                    {{ patient.allergies ?? 'Aucune' }}
                </div>
                <div>
                    <strong>Traitement en cours :</strong><br>
                    {{ patient.traitementEnCours ?? 'Aucun' }}
                </div>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Contact d'urgence</div>
            <div class="box">
                <table class="data-table">
                    <tr>
                        <td style="width:33%;"><strong>Nom :</strong></td>
                        <td>{{ patient.emergencyContactName ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Relation :</strong></td>
                        <td>{{ patient.emergencyContactRelation ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Téléphone :</strong></td>
                        <td>{{ patient.emergencyContactPhone ?? '-' }}</td>
                    </tr>
                    <tr>
                        <td><strong>Adresse :</strong></td>
                        <td>{{ patient.emergencyContactAddress ?? '-' }}</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="footer-block">
            <table class="footer-table">
                <tr>
                    <td class="footer-left">
                        <strong>Clinique NASSARAWA</strong><br>
                        Document généré le {{ "now"|date('d/m/Y à H:i') }}<br>
                        Code patient : {{ patient.code }}
                    </td>
                    <td style="text-align: right; font-size: 8px; color: #6b7280;">
                        Ce document est confidentiel et destiné à un usage médical uniquement.
                    </td>
                </tr>
            </table>
        </div>
    </div>
</body>
</html>