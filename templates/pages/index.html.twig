{% extends 'base.html.twig' %}

{% block title %}Tableau de bord - Clinique Mainassara{% endblock %}

{% block body %}

{# =========================
   HEADER
========================= #}
<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex flex-column flex-lg-row align-items-start align-items-lg-center justify-content-between gap-3">
      <div>
        <h4 class="mb-1">Clinique Nassarawa — Tableau de bord</h4>
        <div class="text-muted">Suivi temps réel : consultations, urgences, hospitalisations, facturation.</div>
      </div>

      <div class="d-flex flex-wrap gap-2 align-items-center">
        <div class="input-group" style="min-width: 260px;">
          <input type="text"
                 class="form-control border-0 minimal-border dash-filter-picker shadow-sm"
                 data-provider="flatpickr"
                 data-range-date="true"
                 data-date-format="d M, Y"
                 placeholder="Filtrer par période">
          <span class="input-group-text bg-primary border-primary text-white">
            <i class="ri-calendar-2-line"></i>
          </span>
        </div>

        <a href="#" class="btn btn-primary">
          <i class="ri-add-circle-line align-middle me-1"></i> Nouvelle consultation
        </a>

        <div class="dropdown">
          <button class="btn btn-soft-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
            Actions
          </button>
          <ul class="dropdown-menu dropdown-menu-end">
            <li><a class="dropdown-item" href="#"><i class="ri-user-add-line me-2"></i>Nouveau patient</a></li>
            <li><a class="dropdown-item" href="#"><i class="ri-hospital-line me-2"></i>Nouvelle hospitalisation</a></li>
            <li><a class="dropdown-item" href="#"><i class="ri-file-list-3-line me-2"></i>Facturation</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

{# =========================
   KPIs CLINIQUES (8 indicateurs)
========================= #}
<div class="row g-3 mb-3">

  {# Consultations du jour #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Consultations (Jour)</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ consultations_today }}">{{ consultations_today }}</span></h3>
            <div class="mt-2 text-success small"><i class="ri-arrow-right-up-line me-1"></i>+8% vs hier</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-primary-subtle rounded fs-3">
              <i class="ri-stethoscope-line text-primary"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Voir consultations</a></div>
      </div>
    </div>
  </div>

  {# Patients enregistrés aujourd’hui #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Nouveaux patients (Jour)</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ new_patients_today }}">{{ new_patients_today }}</span></h3>
            <div class="mt-2 text-muted small"><i class="ri-equal-line me-1"></i>stable</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-info-subtle rounded fs-3">
              <i class="ri-user-heart-line text-info"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Liste patients</a></div>
      </div>
    </div>
  </div>

  {# Urgences / Triage #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Urgences (Jour)</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ urgences_today }}">{{ urgences_today }}</span></h3>
            <div class="mt-2 text-danger small"><i class="ri-alert-line me-1"></i>{{ critical_cases }} cas critiques</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-danger-subtle rounded fs-3">
              <i class="ri-alarm-warning-line text-danger"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Voir triage</a></div>
      </div>
    </div>
  </div>

  {# RDV du jour #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Rendez-vous (Jour)</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ rdv_today }}">{{ rdv_today }}</span></h3>
            <div class="mt-2 text-warning small"><i class="ri-time-line me-1"></i>{{ late_rdv }} en retard</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-warning-subtle rounded fs-3">
              <i class="ri-calendar-check-line text-warning"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Planning</a></div>
      </div>
    </div>
  </div>

  {# Hospitalisations en cours #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Hospitalisations (En cours)</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ hospitalisations_count }}">{{ hospitalisations_count }}</span></h3>
            <div class="mt-2 text-muted small"><i class="ri-hotel-bed-line me-1"></i>Lit dispo : {{ beds_available }}</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-success-subtle rounded fs-3">
              <i class="ri-hospital-line text-success"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Voir hospitalisations</a></div>
      </div>
    </div>
  </div>

  {# Occupation lits (%) #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Taux occupation lits</div>
            <h3 class="mt-2 mb-0 ff-secondary"><span class="counter-value" data-target="{{ occupancy_rate }}">{{ occupancy_rate }}</span>%</h3>
            <div class="mt-2 text-success small"><i class="ri-arrow-right-up-line me-1"></i>{{ occupancy_rate }}% actuel</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-secondary-subtle rounded fs-3">
              <i class="ri-bar-chart-2-line text-secondary"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Capacité lits</a></div>
      </div>
    </div>
  </div>

  {# Factures du jour #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Recettes (Jour)</div>
            <h3 class="mt-2 mb-0 ff-secondary">
              <span class="counter-value" data-target="{{ receipts_today|round(0) }}">{{ receipts_today|number_format(0, '.', ' ') }}</span> <span class="fs-14 text-muted">FCFA</span>
            </h3>
            <div class="mt-2 text-success small"><i class="ri-arrow-right-up-line me-1"></i>Recettes du jour</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-success-subtle rounded fs-3">
              <i class="ri-money-dollar-circle-line text-success"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Voir factures</a></div>
      </div>
    </div>
  </div>

  {# Impayés #}
  <div class="col-12 col-md-6 col-xl-3">
    <div class="card card-animate h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between">
          <div>
            <div class="text-uppercase fw-medium text-muted small">Impayés</div>
            <h3 class="mt-2 mb-0 ff-secondary">
              <span class="counter-value" data-target="{{ unpaid_total|round(0) }}">{{ unpaid_total|number_format(0, '.', ' ') }}</span> <span class="fs-14 text-muted">FCFA</span>
            </h3>
            <div class="mt-2 text-danger small"><i class="ri-close-circle-line me-1"></i>{{ unpaid_count }} dossiers</div>
          </div>
          <div class="avatar-sm">
            <span class="avatar-title bg-danger-subtle rounded fs-3">
              <i class="ri-file-damage-line text-danger"></i>
            </span>
          </div>
        </div>
        <div class="mt-3"><a href="#" class="text-decoration-underline small">Relances</a></div>
      </div>
    </div>
  </div>

</div>

{# =========================
   GRAPHIQUES (placeholders)
========================= #}
<div class="row g-3 mb-3">
  <div class="col-12 col-xl-8">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0">Flux patients (Consultations & Urgences)</h5>
        <div class="btn-group btn-group-sm">
          <button class="btn btn-soft-secondary active" type="button">7j</button>
          <button class="btn btn-soft-secondary" type="button">30j</button>
        </div>
      </div>
      <div class="card-body">
        <div id="patients_flow_chart" style="height:320px;" class="bg-light rounded-3"></div>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-4">
    <div class="card h-100">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0">Hospitalisation par statut</h5>
        <a href="#" class="small text-decoration-underline">Détails</a>
      </div>
      <div class="card-body">
        <div id="hosp_status_chart" style="height:220px;" class="bg-light rounded-3"></div>

        <div class="mt-3 vstack gap-2">
          <div class="d-flex justify-content-between"><span class="text-muted">En cours</span><span class="fw-semibold">{{ hospitalisations_count }}</span></div>
          <div class="d-flex justify-content-between"><span class="text-muted">Sorties aujourd’hui</span><span class="fw-semibold">{{ hosp_sorties_today }}</span></div>
          <div class="d-flex justify-content-between"><span class="text-muted">Transferts</span><span class="fw-semibold">{{ hosp_transfers }}</span></div>
        </div>
      </div>
    </div>
  </div>
</div>

{# =========================
   TABLES (activité)
========================= #}
<div class="row g-3">
  <div class="col-12 col-xl-8">
    <div class="card">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h5 class="card-title mb-0">Dernières consultations</h5>
        <a href="#" class="btn btn-soft-primary btn-sm">
          <i class="ri-eye-line me-1"></i> Voir tout
        </a>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table align-middle table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Heure</th>
                <th>Patient</th>
                <th>Service</th>
                <th>Médecin</th>
                <th>Statut</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody>
              {% for consult in last_consultations %}
              <tr>
                <td>{{ consult.createdAt|date('H:i') }}</td>
                <td class="fw-medium">
                    {{ consult.dossierMedical.patient.nom }} {{ consult.dossierMedical.patient.prenom }}
                </td>
                <td>
                  {% if consult.statut.value == 'en_cours' %}
                    Urgences
                  {% else %}
                    Consultation
                  {% endif %}
                </td>
                <td>{{ consult.medecin.nomComplet }}</td>
                <td>
                    {% set badge = {
                      'en_cours': ['warning','En cours'],
                      'cloture': ['success','Terminée'],
                      'brouillon': ['secondary','Brouillon'],
                      'annule': ['danger','Annulé'],
                    }[consult.statut.value] ?? ['secondary','?'] %}
                    <span class="badge bg-{{ badge[0] }}-subtle text-{{ badge[0] }}">{{ badge[1] }}</span>
                </td>
                <td class="text-end">
                    <a href="#" class="btn btn-soft-secondary btn-sm">Dossier</a>
                </td>
              </tr>
              {% else %}
              <tr>
                  <td colspan="6" class="text-center text-muted">Aucune consultation récente</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
        <div class="mt-3 text-muted small">Astuce : ajoute un filtre “service” pour le tri rapide.</div>
      </div>
    </div>
  </div>

  <div class="col-12 col-xl-4">
  <div class="card h-100">
    <div class="card-header d-flex align-items-center justify-content-between">
      <h5 class="card-title mb-0">Alertes opérationnelles</h5>
      <span class="badge bg-danger-subtle text-danger">Priorité</span>
    </div>
    <div class="card-body">
      <div class="vstack gap-3">
        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Impayés élevés</div>
            <span class="badge bg-danger-subtle text-danger">{{ unpaid_high_count }}</span>
          </div>
          <div class="text-muted small">Relancer les dossiers &gt; 20 000 FCFA.</div>
        </div>

        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Urgences critiques</div>
            <span class="badge bg-warning-subtle text-warning">{{ critical_cases }}</span>
          </div>
          <div class="text-muted small">Prioriser triage + allocation personnel.</div>
        </div>

        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Lits presque saturés</div>
            <span class="badge bg-info-subtle text-info">{{ occupancy_rate }}%</span>
          </div>
          <div class="text-muted small">Préparer sorties / transferts.</div>
        </div>

        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Administrations manquées</div>
            <span class="badge bg-danger-subtle text-danger">{{ missed_treatments_count|default(0) }}</span>
          </div>
          <div class="text-muted small">Soins prévus non confirmés aujourd’hui.</div>
        </div>

        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Administrations imminentes</div>
            <span class="badge bg-warning-subtle text-warning">{{ upcoming_treatments_count|default(0) }}</span>
          </div>
          <div class="text-muted small">Traitements à administrer maintenant ou bientôt.</div>
        </div>

        <div class="p-3 border rounded-3">
          <div class="d-flex justify-content-between">
            <div class="fw-semibold">Fins de traitement aujourd’hui</div>
            <span class="badge bg-info-subtle text-info">{{ ending_treatments_count|default(0) }}</span>
          </div>
          <div class="text-muted small">Vérifier arrêt ou renouvellement.</div>
        </div>
      </div>

      {% if treatment_alert_items is defined and treatment_alert_items is not empty %}
        <div class="mt-4">
          <div class="fw-semibold mb-2">Patients à surveiller</div>

          <div class="vstack gap-2">
            {% for item in treatment_alert_items|slice(0, 5) %}
              <a href="{{ path('app_hospitalisation_show', { id: item.hospitalisation_id }) }}"
                 class="text-decoration-none">
                <div class="p-2 border rounded-3">
                  <div class="d-flex justify-content-between align-items-start gap-2">
                    <div>
                      <div class="fw-semibold small">
                        {% if item.type == 'missed' %}
                          <span class="text-danger">
                            <i class="ri-alarm-warning-line me-1"></i>{{ item.label }}
                          </span>
                        {% elseif item.type == 'ending' %}
                          <span class="text-warning">
                            <i class="ri-time-line me-1"></i>{{ item.label }}
                          </span>
                        {% elseif item.type == 'upcoming' %}
                          <span class="text-info">
                            <i class="ri-notification-3-line me-1"></i>{{ item.label }}
                          </span>
                        {% else %}
                          <span class="text-muted">{{ item.label }}</span>
                        {% endif %}
                      </div>

                      <div class="small text-muted">
                        <strong>{{ item.patient }}</strong>
                      </div>

                      <div class="small text-muted">
                        {{ item.traitement }}
                        {% if item.heure %}
                          — à {{ item.heure }}
                        {% endif %}
                      </div>
                    </div>

                    <i class="ri-arrow-right-s-line text-muted"></i>
                  </div>
                </div>
              </a>
            {% endfor %}
          </div>

          {% if treatment_alert_items|length > 5 %}
            <div class="text-muted small mt-2">
              + {{ treatment_alert_items|length - 5 }} autre(s) alerte(s)
            </div>
          {% endif %}
        </div>
      {% endif %}

      <hr class="my-4">

      <a href="#" class="btn btn-soft-danger w-100">
        <i class="ri-notification-3-line me-1"></i> Voir toutes les alertes
      </a>
    </div>
  </div>
</div>
</div>

{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script src="{{ asset('assets/js/pages/dashboard-ecommerce.init.js') }}"></script>

  {# custom dashboard charts #}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      
      var flowOptions = {
        chart: { type: 'area', height: 320, toolbar: { show: false } },
        series: [
          { name: 'Consultations', data: {{ flow_consultations|json_encode()|raw }} },
          { name: 'Urgences', data: {{ flow_urgences|json_encode()|raw }} }
        ],
        xaxis: { categories: {{ flow_labels|json_encode()|raw }} },
        colors: ['#50a5f1', '#f1b44c'],
        stroke: { curve: 'smooth' },
        grid: { padding: { right: 10, left: 10 } },
        tooltip: { shared: true, intersect: false }
      };
      var flowEl = document.querySelector('#patients_flow_chart');
      if (flowEl) {
        new ApexCharts(flowEl, flowOptions).render();
      }

      
      var hospOptions = {
        series: [{{ hospitalisations_count }}, {{ hosp_sorties_today }}, {{ hosp_transfers }}],
        labels: ['En cours', 'Sorties aujourd’hui', 'Transferts'],
        chart: { type: 'donut', height: 220 },
        colors: ['#0acf97', '#50a5f1', '#f46a6a'],
        legend: { position: 'bottom' }
      };
      var hospEl = document.querySelector('#hosp_status_chart');
      if (hospEl) {
        new ApexCharts(hospEl, hospOptions).render();
      }
    });
  </script>
{% endblock %}