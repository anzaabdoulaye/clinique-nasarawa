<!doctype html>
<html lang="fr"
      data-layout="vertical"
      data-topbar="light"
      data-sidebar="dark"
      data-sidebar-size="lg"
      data-sidebar-image="none"
      data-preloader="disable"
      data-theme="default"
      data-theme-colors="default">
<head>
    <meta charset="utf-8" />
    <title>Sécurité — Modifier le mot de passe | Clinique Nassarawa</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Modification sécurisée du mot de passe" name="description" />
    <meta content="Clinique Nassarawa" name="author" />

    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
    <script src="{{ asset('assets/js/layout.js') }}"></script>

    {% block stylesheets %}
        <link href="{{ asset('assets/libs/jsvectormap/jsvectormap.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/libs/swiper/swiper-bundle.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/bootstrap.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/icons.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/app.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/custom.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/libs/datatables/jquery.dataTables.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/libs/datatables/buttons/buttons.dataTables.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/select2.min.css') }}" rel="stylesheet" type="text/css" />

        <style>
            .auth-subtitle {
                color: rgba(255,255,255,.85);
            }

            .alert-form {
                border: 1px solid rgba(220, 53, 69, 0.15);
                background-color: rgba(220, 53, 69, 0.08);
            }

            .clinic-footer-note {
                font-size: .85rem;
            }

            .auth-one-bg {
                background: linear-gradient(135deg, #f8fbff 0%, #cfe2ff 50%, #0d6efd 100%);
            }

            .card-bg-fill {
                position: relative;
                margin-top: -80px;
                z-index: 10;
                backdrop-filter: blur(10px);
                background: rgba(255, 255, 255, 0.95);
                border-radius: 12px;
                box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            }

            .auth-one-bg-position {
                height: 250px;
                min-height: 250px;
                max-height: 250px;
            }

            .help-text {
                font-size: .85rem;
                color: #6c757d;
            }

            .password-guidelines {
                border: 1px solid rgba(13,110,253,.12);
                background: rgba(13,110,253,.06);
                border-radius: 10px;
            }

            .form-control:focus {
                box-shadow: 0 0 0 .25rem rgba(13,110,253,.15);
                border-color: rgba(13,110,253,.45);
            }

            .btn-primary {
                box-shadow: 0 12px 24px rgba(13,110,253,.20);
            }

            .auth-page-content {
    min-height: calc(100vh - 250px); /* 250 = ton header bg */
    display: flex;
    align-items: center;
}

.card-bg-fill {
    max-height: 90vh;
    overflow-y: auto;
}
        </style>
    {% endblock %}
</head>

<body>
<div class="auth-page-wrapper pt-5">
    <div class="auth-one-bg-position auth-one-bg" id="auth-particles">
        <div class="bg-overlay"></div>

        <div class="shape">
            <svg xmlns="http://www.w3.org/2000/svg"
                 version="1.1"
                 xmlns:xlink="http://www.w3.org/1999/xlink"
                 viewBox="0 0 1440 120">
                <path d="M 0,36 C 144,53.6 432,123.2 720,124 C 1008,124.8 1296,56.8 1440,40L1440 140L0 140z"></path>
            </svg>
        </div>
    </div>

    <div class="auth-page-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="text-center text-white">
                        <img src="{{ asset('logo2.png') }}" alt="Clinique Nasarawa" height="180" class="mb-3">
                    </div>
                </div>
            </div>

            <div class="row justify-content-center">
                <div class="col-md-9 col-lg-7 col-xl-5">
                    <div class="card mt-3 card-bg-fill">
                        <div class="card-body p-3 p-md-4">
                            <div class="text-center mb-2">
                                <h5 class="text-primary">Sécurité du compte</h5>
                                <p class="text-muted mb-0">
                                    Modifiez votre mot de passe pour sécuriser votre accès.
                                </p>
                            </div>

                            <div class="password-guidelines p-3 mt-4 mb-4">
                                <div class="fw-semibold text-primary mb-2">Recommandations</div>
                                <ul class="mb-0 ps-3 small text-muted">
                                    <li>Minimum 8 caractères</li>
                                    <li>Au moins 1 majuscule, 1 chiffre et 1 symbole</li>
                                    <li>Évitez les informations personnelles</li>
                                </ul>
                            </div>

                            <div class="p-2">
                                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                                    {% if form.vars.errors|length > 0 %}
                                        <div class="alert alert-danger alert-form mb-4" role="alert">
                                            {{ form_errors(form) }}
                                        </div>
                                    {% endif %}

                                    <div class="mb-3">
                                        {{ form_row(form.plainPassword.first, {
                                            'label': 'Nouveau mot de passe',
                                            'attr': {
                                                'class': 'form-control',
                                                'autocomplete': 'new-password',
                                                'placeholder': 'Entrez le nouveau mot de passe'
                                            }
                                        }) }}
                                        <div class="help-text mt-1">
                                            Utilisez un mot de passe unique et difficile à deviner.
                                        </div>
                                    </div>

                                    <div class="mb-4">
                                        {{ form_row(form.plainPassword.second, {
                                            'label': 'Confirmation du mot de passe',
                                            'attr': {
                                                'class': 'form-control',
                                                'autocomplete': 'new-password',
                                                'placeholder': 'Confirmez le nouveau mot de passe'
                                            }
                                        }) }}
                                        <div class="help-text mt-1">
                                            Saisissez exactement le même mot de passe.
                                        </div>
                                    </div>

                                    <div class="d-flex justify-content-between gap-2 mt-4">
                                        <a href="{{ path('home') }}" class="btn btn-outline-secondary rounded-3">
                                            Annuler
                                        </a>

                                        <button type="submit" class="btn btn-primary rounded-3 fw-semibold px-4">
                                            Mettre à jour
                                        </button>
                                    </div>

                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <p class="mb-0 text-muted clinic-footer-note">
                            Vos informations sont protégées et chiffrées.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row">
                <div class="col-lg-12">
                    <div class="text-center">
                        <p class="mb-0 text-muted">
                            &copy; {{ "now"|date("Y") }} Clinique Nassarawa. Assistance : EDMAF Niger.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </footer>
</div>

{% block javascripts %}
    <script src="{{ asset('assets/libs/datatables/jquery-3.6.4.min.js') }}"></script>
    <script src="{{ asset('assets/libs/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
    <script src="{{ asset('assets/libs/simplebar/simplebar.min.js') }}"></script>
    <script src="{{ asset('assets/libs/node-waves/waves.min.js') }}"></script>
    <script src="{{ asset('assets/libs/feather-icons/feather.min.js') }}"></script>
    <script src="{{ asset('assets/js/pages/plugins/lord-icon-2.1.0.js') }}"></script>
    <script src="{{ asset('assets/js/plugins.js') }}"></script>

    <script src="{{ asset('assets/js/pages/select2.min.js') }}"></script>
    <script src="{{ asset('assets/js/pages/select2.init.js') }}"></script>

    <script src="{{ asset('assets/libs/apexcharts/apexcharts.min.js') }}"></script>
    <script src="{{ asset('assets/libs/jsvectormap/jsvectormap.min.js') }}"></script>
    <script src="{{ asset('assets/libs/jsvectormap/maps/world-merc.js') }}"></script>
    <script src="{{ asset('assets/libs/swiper/swiper-bundle.min.js') }}"></script>

    <script src="{{ asset('assets/js/app.js') }}"></script>
    <script src="{{ asset('assets/libs/datatables/jquery.dataTables.min.js') }}"></script>
    <script src="{{ asset('assets/libs/datatables/buttons/dataTables.buttons.min.js') }}"></script>
    <script src="{{ asset('assets/libs/jszip/jszip.min.js') }}"></script>
    <script src="{{ asset('assets/libs/pdfmake/pdfmake.min.js') }}"></script>
    <script src="{{ asset('assets/libs/pdfmake/vfs_fonts.js') }}"></script>
    <script src="{{ asset('assets/libs/datatables/buttons/buttons.html5.min.js') }}"></script>
    <script src="{{ asset('assets/libs/datatables/buttons/buttons.print.min.js') }}"></script>

    <script src="{{ asset('assets/libs/particles.js/particles.js') }}"></script>
    <script src="{{ asset('assets/js/pages/particles.app.js') }}"></script>
{% endblock %}
</body>
</html>