<!doctype html>
<html lang="{{ app.request.locale|default('en') }}" 
      data-layout="vertical" 
      data-topbar="light" 
      data-sidebar="dark" 
      data-sidebar-size="lg" 
      data-sidebar-image="none" 
      data-preloader="disable" 
      data-theme="default" 
      data-theme-colors="default">

<head>
    <meta charset="utf-8" />
    <title>{% block title %}Dashboard{% endblock %}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta content="Premium Multipurpose Admin & Dashboard Template" name="description" />
    <meta content="Themesbrand" name="author" />
    
    <!-- App favicon -->
    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
    

    {% block stylesheets %}
        <!-- jsvectormap css -->
        <link href="{{ asset('assets/libs/jsvectormap/jsvectormap.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- Swiper slider css -->
        <link href="{{ asset('assets/libs/swiper/swiper-bundle.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- Bootstrap Css -->
        <link href="{{ asset('assets/css/bootstrap.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- Icons Css -->
        <link href="{{ asset('assets/css/icons.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- App Css -->
        <link href="{{ asset('assets/css/app.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- Custom Css -->
        <link href="{{ asset('assets/css/custom.min.css') }}" rel="stylesheet" type="text/css" />
        <!-- DataTables CSS  -->
        <link href="{{ asset('assets/libs/datatables/jquery.dataTables.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/libs/datatables/buttons/buttons.dataTables.min.css') }}" rel="stylesheet" type="text/css" />
        <link href="{{ asset('assets/css/select2.min.css') }}" rel="stylesheet" type="text/css" />
        
        
    {% endblock %}

    <!-- Layout config Js -->
    <script src="{{ asset('assets/js/layout.js') }}"></script>
</head>

<body>
    <!-- Begin page -->
    <div id="layout-wrapper">
        
        {# Header / Topbar #}
        {% include 'partials/_header.html.twig' %}
        
        {# Sidebar Menu #}
        {% include 'partials/_sidebar.html.twig' %}
        
        {# Vertical Overlay #}
        <div class="vertical-overlay"></div>

        <!-- Start right Content here -->
        <div class="main-content">
            <div class="page-content">
                <div class="container-fluid">
                {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'danger' ? 'danger' : (label == 'error' ? 'danger' : label) }} alert-dismissible fade show mx-3 mt-3" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}
                    {% block body %}
                    {% endblock %}
                </div>
            </div>

            {# Footer #}
            {% include 'partials/_footer.html.twig' %}
        </div>
        <!-- end main content-->

        {# Right Sidebar (Activité) #}
       
        
    </div>
    <!-- END layout-wrapper -->

    {# Back to top button #}
    <button onclick="topFunction()" class="btn btn-danger btn-icon" id="back-to-top">
        <i class="ri-arrow-up-line"></i>
    </button>

    {# Preloader #}
    <div id="preloader">
        <div id="status">
            <div class="spinner-border text-primary avatar-sm" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>

    {# Theme Settings (Customizer) #}
   

    {% block javascripts %}
        <!-- JAVASCRIPT -->
        <!-- jQuery  -->
        <script src="{{ asset('assets/libs/datatables/jquery-3.6.4.min.js') }}"></script>
        <script src="{{ asset('assets/libs/bootstrap/js/bootstrap.bundle.min.js') }}"></script>
        <script src="{{ asset('assets/libs/simplebar/simplebar.min.js') }}"></script>
        <script src="{{ asset('assets/libs/node-waves/waves.min.js') }}"></script>
        <script src="{{ asset('assets/libs/feather-icons/feather.min.js') }}"></script>
        <script src="{{ asset('assets/js/pages/plugins/lord-icon-2.1.0.js') }}"></script>
        <script src="{{ asset('assets/js/plugins.js') }}"></script>

        <script src="{{ asset('assets/js/pages/select2.min.js') }}"></script>
        <script src="{{ asset('assets/js/pages/select2.init.js') }}"></script>
        
        <!-- apexcharts -->
        <script src="{{ asset('assets/libs/apexcharts/apexcharts.min.js') }}"></script>
        <!-- Vector map-->
        <script src="{{ asset('assets/libs/jsvectormap/jsvectormap.min.js') }}"></script>
        <script src="{{ asset('assets/libs/jsvectormap/maps/world-merc.js') }}"></script>
        <!-- Swiper slider js -->
        <script src="{{ asset('assets/libs/swiper/swiper-bundle.min.js') }}"></script>
        
        <!-- App js -->
        <script src="{{ asset('assets/js/app.js') }}"></script>
        <!-- DataTables JS -->
        <script src="{{ asset('assets/libs/datatables/jquery.dataTables.min.js') }}"></script>
        <script src="{{ asset('assets/libs/datatables/buttons/dataTables.buttons.min.js') }}"></script>
        <script src="{{ asset('assets/libs/jszip/jszip.min.js') }}"></script>
        <script src="{{ asset('assets/libs/pdfmake/pdfmake.min.js') }}"></script>
        <script src="{{ asset('assets/libs/pdfmake/vfs_fonts.js') }}"></script>
        <script src="{{ asset('assets/libs/datatables/buttons/buttons.html5.min.js') }}"></script>
        <script src="{{ asset('assets/libs/datatables/buttons/buttons.print.min.js') }}"></script>

        <script>
        (function () {
            if (typeof $ === 'undefined' || !$.fn || !$.fn.DataTable) {
                return;
            }

            var frenchLanguage = {
                processing: "Traitement en cours...",
                search: "Rechercher :",
                lengthMenu: "Afficher _MENU_ éléments",
                info: "Affichage de _START_ à _END_ sur _TOTAL_ éléments",
                infoEmpty: "Aucun élément à afficher",
                infoFiltered: "(filtré de _MAX_ éléments au total)",
                loadingRecords: "Chargement...",
                zeroRecords: "Aucun résultat trouvé",
                emptyTable: "Aucune donnée disponible",
                paginate: {
                    first: "Premier",
                    previous: "Précédent",
                    next: "Suivant",
                    last: "Dernier"
                },
                buttons: {
                    copy: "Copier",
                    csv: "CSV",
                    excel: "Excel",
                    pdf: "PDF",
                    print: "Imprimer"
                }
            };

            function buildExportButtons(exportTitle) {
                return [
                    {
                        extend: 'copyHtml5',
                        text: '<i class="ri-file-copy-line me-1"></i> Copier',
                        className: 'btn btn-light btn-sm',
                        title: exportTitle,
                        exportOptions: {
                            columns: ':visible:not(.no-export)'
                        }
                    },
                    {
                        extend: 'csvHtml5',
                        text: '<i class="ri-file-text-line me-1"></i> CSV',
                        className: 'btn btn-info btn-sm',
                        title: exportTitle,
                        exportOptions: {
                            columns: ':visible:not(.no-export)'
                        }
                    },
                    {
                        extend: 'excelHtml5',
                        text: '<i class="ri-file-excel-2-line me-1"></i> Excel',
                        className: 'btn btn-success btn-sm',
                        title: exportTitle,
                        exportOptions: {
                            columns: ':visible:not(.no-export)'
                        }
                    },
                    {
                        extend: 'pdfHtml5',
                        text: '<i class="ri-file-pdf-line me-1"></i> PDF',
                        className: 'btn btn-danger btn-sm',
                        title: exportTitle,
                        orientation: 'landscape',
                        pageSize: 'A4',
                        exportOptions: {
                            columns: ':visible:not(.no-export)'
                        },
                        customize: function (doc) {
                            if (doc.content[1] && doc.content[1].table) {
                                doc.content[1].table.widths = Array(doc.content[1].table.body[0].length).fill('*');
                            }
                            doc.styles.tableHeader.alignment = 'center';
                            doc.styles.tableHeader.fontSize = 10;
                            doc.defaultStyle.fontSize = 9;
                            doc.pageMargins = [20, 20, 20, 20];
                        }
                    },
                    {
                        extend: 'print',
                        text: '<i class="ri-printer-line me-1"></i> Imprimer',
                        className: 'btn btn-secondary btn-sm',
                        title: exportTitle,
                        exportOptions: {
                            columns: ':visible:not(.no-export)'
                        }
                    }
                ];
            }

            function buildDatatableOptions($table, overrides) {
                var exportTitle = $table.data('exportTitle') || document.title || 'export_donnees';

                return $.extend(true, {
                    pageLength: 10,
                    lengthMenu: [5, 10, 25, 50, 100],
                    searching: true,
                    ordering: true,
                    responsive: true,
                    deferRender: true,
                    language: frenchLanguage,
                    columnDefs: [
                        {
                            targets: 'no-sort',
                            orderable: false
                        },
                        {
                            targets: 'text-center',
                            className: 'text-center'
                        }
                    ],
                    dom:
                        "<'row mb-3 align-items-center'<'col-md-8 dt-buttons-wrapper'B><'col-md-4 text-md-end'f>>" +
                        "<'row'<'col-12'tr>>" +
                        "<'row mt-3'<'col-md-5'i><'col-md-7'p>>",
                    buttons: buildExportButtons(exportTitle)
                }, overrides || {});
            }

            $(function () {
                $('.datatable').each(function () {
                    if ($.fn.dataTable.isDataTable(this)) {
                        return;
                    }

                    $(this).DataTable(buildDatatableOptions($(this), {
                        order: [[0, 'desc']]
                    }));
                });

                $('.datatable-a').each(function () {
                    if ($.fn.dataTable.isDataTable(this)) {
                        return;
                    }

                    $(this).DataTable(buildDatatableOptions($(this), {
                        lengthMenu: [10, 25, 50, 100],
                        autoWidth: false,
                        processing: true,
                        order: []
                    }));
                });
            });
        })();
        </script>


      

<script>
(function(){
    if (typeof $ !== 'undefined' && $.fn && $.fn.DataTable) {

        $(document).ready(function(){

            $('.datatable-mi').DataTable({

                // 🔹 Pagination
                pageLength: 10,
                lengthMenu: [5, 10, 25, 50, 100],

                // 🔹 Recherche
                searching: true,

                // 🔹 Tri
                ordering: true,

                // 🔹 Responsive
                responsive: true,

                // 🔹 Performance (très important)
                deferRender: true,

                // 🔹 Langue FR (adapté Niger)
                language: {
                    processing: "Traitement en cours...",
                    search: "Rechercher :",
                    lengthMenu: "Afficher _MENU_ éléments",
                    info: "Affichage de _START_ à _END_ sur _TOTAL_ éléments",
                    infoEmpty: "Aucun élément à afficher",
                    infoFiltered: "(filtré de _MAX_ éléments au total)",
                    loadingRecords: "Chargement...",
                    zeroRecords: "Aucun résultat trouvé",
                    emptyTable: "Aucune donnée disponible",
                    paginate: {
                        first: "Premier",
                        previous: "Précédent",
                        next: "Suivant",
                        last: "Dernier"
                    }
                },

                // 🔹 Colonnes (optionnel mais puissant)
                columnDefs: [
                    {
                        targets: 'no-sort',
                        orderable: false
                    },
                    {
                        targets: 'text-center',
                        className: 'text-center'
                    }
                ],

                // 🔹 Tri par défaut (ex: date desc)
                order: [[0, 'desc']],

                // 🔹 Boutons (si tu veux exporter plus tard)
                dom: '<"d-flex justify-content-between align-items-center mb-2"lf>rt<"d-flex justify-content-between mt-2"ip>',

            });

        });
    }
})();
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gestion du bouton Encaisser
    document.querySelectorAll('.js-open-encaissement').forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const url = this.dataset.url;
            const modalElement = document.getElementById('encaissementModal');
            const modalContent = document.getElementById('encaissementModalContent');
            
            // Afficher le spinner
            modalContent.innerHTML = `
                <div class="modal-body text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-3">Chargement...</p>
                </div>
            `;
            
            // Ouvrir la modal manuellement
            const bsModal = new bootstrap.Modal(modalElement);
            bsModal.show();
            
            // Charger le contenu
            fetch(url, { 
                headers: { 'X-Requested-With': 'XMLHttpRequest' } 
            })
            .then(response => response.text())
            .then(html => {
                modalContent.innerHTML = html;
                setTimeout(initForm, 100);
            })
            .catch(error => {
                console.error('Erreur:', error);
                modalContent.innerHTML = '<div class="modal-body text-danger">Erreur de chargement</div>';
            });
        });
    });
});

function initForm() {
    console.log('Formulaire chargé - Initialisation');
    
    const toggle = document.querySelector('.js-pec-toggle');
    const tauxSelect = document.querySelector('select[name*="tauxPriseEnChargeManuel"], select[id*="tauxPriseEnChargeManuel"]');
    const montantInput = document.querySelector('input[name*="montant"], input[id*="montant"]');
    
    console.log('Toggle:', toggle ? 'OK' : 'NON TROUVÉ');
    console.log('Taux:', tauxSelect ? 'OK' : 'NON TROUVÉ');
    console.log('Montant:', montantInput ? 'OK' : 'NON TROUVÉ');
    
    // Gestion Toggle PEC
    if (toggle) {
        toggle.addEventListener('change', function() {
            const container = document.getElementById('pec-fields-container');
            if (container) {
                if (this.checked) container.classList.add('show');
                else container.classList.remove('show');
            }
            calculer();
        });
    }
    
    // Gestion changement taux
    if (tauxSelect) {
        tauxSelect.addEventListener('change', calculer);
    }
    
    // Validation montant
    if (montantInput) {
        montantInput.addEventListener('input', function() {
            const max = parseInt(this.dataset.max || this.max || 999999999);
            const val = parseInt(this.value || 0);
            
            if (val > max) {
                this.classList.add('is-invalid');
                this.value = max;
            } else {
                this.classList.remove('is-invalid');
            }
        });
    }
    
    // Calcul initial
    calculer();
}

function calculer() {
    console.log('Calcul en cours...');
    
    const totalEl = document.getElementById('pec-total-brut');
    const dejaPayeEl = document.getElementById('pec-deja-paye');
    const toggle = document.querySelector('.js-pec-toggle');
    const tauxSelect = document.querySelector('select[name*="tauxPriseEnChargeManuel"], select[id*="tauxPriseEnChargeManuel"]');
    
    if (!totalEl) {
        console.error('Total brut non trouvé');
        return;
    }
    
    const totalBrut = parseInt(totalEl.dataset.value || 0);
    const dejaPaye = parseInt(dejaPayeEl?.dataset.value || 0);
    const pecActive = toggle ? toggle.checked : false;
    const taux = (pecActive && tauxSelect && tauxSelect.value) ? parseInt(tauxSelect.value) : 0;
    
    console.log('Données:', {totalBrut, dejaPaye, pecActive, taux});
    
    const montantPec = Math.round((totalBrut * taux) / 100);
    const partPatient = totalBrut - montantPec;
    const reste = Math.max(0, partPatient - dejaPaye);
    
    console.log('Résultat:', {montantPec, partPatient, reste});
    
    // Mise à jour affichage
    const fmt = n => new Intl.NumberFormat('fr-FR').format(n);
    
    const update = (id, val) => {
        const el = document.getElementById(id);
        if (el) {
            el.textContent = fmt(val);
            el.dataset.value = val;
        }
    };
    
    update('pec-montant-pec', montantPec);
    update('pec-part-patient', partPatient);
    update('pec-reste-patient', reste);
    
    // Mise à jour input max
    const montantInput = document.querySelector('input[name*="montant"], input[id*="montant"]');
    if (montantInput) {
        montantInput.max = reste;
        montantInput.dataset.max = reste;
        
        const helpText = montantInput.closest('.card-body, .form-group, div')?.querySelector('.form-text');
        if (helpText) {
            helpText.innerHTML = `Max: <strong class="text-danger">${fmt(reste)} FCFA</strong>`;
        }
        
        if (parseInt(montantInput.value || 0) > reste) {
            montantInput.value = reste;
        }
    }
}
</script>
    {% endblock %}
</body>
</html>