{% extends 'base.html.twig' %}

{% block title %}Rendez-vous{% endblock %}

{% block body %}
<div class="row">
  <div class="col-12">

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-0 py-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <h5 class="mb-0 fw-semibold">
              <i class="fa fa-calendar-check me-2 text-primary"></i> Rendez-vous
            </h5>
            <div class="text-muted small">Gestion des rendez-vous et démarrage des consultations</div>
          </div>

          <div class="d-flex gap-2 align-items-center">
            <div class="d-flex align-items-center gap-2">
              <label for="statutFilter" class="form-label mb-0 small fw-semibold">Filtrer par statut:</label>
              <select id="statutFilter" class="form-select form-select-sm" style="width: auto; min-width: 150px;">
                <option value="" {% if statutFilter == '' %}selected{% endif %}>Tous les statuts</option>
                <option value="actifs" {% if statutFilter == 'actifs' %}selected{% endif %}>Actifs (En attente, Planifié, Confirmé)</option>
                <option value="en_attente" {% if statutFilter == 'en_attente' %}selected{% endif %}>En attente</option>
                <option value="planifie" {% if statutFilter == 'planifie' %}selected{% endif %}>Planifié</option>
                <option value="confirme" {% if statutFilter == 'confirme' %}selected{% endif %}>Confirmé</option>
                <option value="annule" {% if statutFilter == 'annule' %}selected{% endif %}>Annulé</option>
                <option value="termine" {% if statutFilter == 'termine' %}selected{% endif %}>Terminé</option>
              </select>
            </div>

            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addRendezVousModal">
              <i class="fa fa-plus me-1"></i> Nouveau rendez-vous
            </button>
          </div>
        </div>
      </div>

      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 datatable-a">
            <thead class="table-light">
              <tr class="text-nowrap">
                <th class="text-uppercase small text-muted">Date / Heure</th>
                <th class="text-uppercase small text-muted">Statut</th>
                <th class="text-uppercase small text-muted">Motif</th>
                <th class="text-uppercase small text-muted">Patient</th>
                <th class="text-uppercase small text-muted">Médecin</th>
                <th class="text-uppercase small text-muted">Consultation</th>
                <th class="text-uppercase small text-muted">Créé le</th>
                <th class="text-uppercase small text-muted text-end" style="width: 250px;">Actions</th>
              </tr>
            </thead>

            <tbody>
            {% for rv in rendezVous %}
              {% set statut = rv.statut.name ?? '' %}

              <tr>
                <td class="text-nowrap"{% if rv.dateHeure %} data-order="{{ rv.dateHeure|date('Y-m-d H:i:s') }}"{% endif %}>
                  {% if rv.dateHeure %}
                    <div class="fw-semibold">{{ rv.dateHeure|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ rv.dateHeure|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if statut %}
                    {% set badgeClass =
                      statut == 'CONFIRME' ? 'bg-success-subtle text-success border' :
                      (statut == 'ANNULE' ? 'bg-danger-subtle text-danger border' :
                      (statut == 'EN_ATTENTE' ? 'bg-warning-subtle text-warning border' :
                      'bg-light text-muted border'))
                    %}
                    <span class="badge {{ badgeClass }}">
                      <i class="fa fa-circle me-1" style="font-size:8px;"></i> {{ statut }}
                    </span>
                  {% else %}
                    <span class="badge bg-light text-muted border">N/A</span>
                  {% endif %}
                </td>

                <td class="text-start" style="min-width: 220px;">
                  {{ rv.motif ? rv.motif|u.truncate(70, '…', false) : '—' }}
                </td>

                <td class="text-nowrap">
                  {% if rv.patient %}
                    <span class="badge bg-light text-dark border">
                      <i class="fa fa-user me-1 text-muted"></i>
                      {{ rv.patient.nom }} {{ rv.patient.prenom ?? '' }}
                    </span>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if rv.medecin %}
                    <span class="badge bg-primary-subtle text-primary border">
                      <i class="fa fa-user-md me-1"></i>
                      {{ rv.medecin.nomComplet ?? rv.medecin.id }}
                    </span>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if rv.consultation %}
                    <a class="btn btn-sm btn-outline-secondary"
                       href="{{ path('app_consultation_show', {id: rv.consultation.id}) }}">
                      <i class="fa fa-folder-open me-1"></i> Ouvrir
                    </a>
                  {% else %}
                    {% if statut == 'CONFIRME' %}
                      <form method="post"
                            action="{{ path('app_rendez_vous_start_consultation', {id: rv.id}) }}"
                            class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('start_consultation_' ~ rv.id) }}">
                        <button class="btn btn-sm btn-primary">
                          <i class="fa fa-play me-1"></i> Démarrer
                        </button>
                      </form>
                    {% else %}
                      <span class="badge bg-light text-muted border">Non démarrable</span>
                    {% endif %}
                  {% endif %}
                </td>

                <td class="text-nowrap"{% if rv.createdAt %} data-order="{{ rv.createdAt|date('Y-m-d H:i:s') }}"{% endif %}>
                  {% if rv.createdAt %}
                    <div class="small">{{ rv.createdAt|date('d/m/Y H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-end">
                  <div class="btn-group btn-group-sm" role="group" aria-label="Actions RDV">
                    <button type="button"
                            class="btn btn-outline-success js-edit-rdv-status"
                            title="Modifier le statut"
                            data-url="{{ path('app_rendez_vous_edit_statut', {id: rv.id}) }}"
                            data-bs-toggle="modal"
                            data-bs-target="#editRdvStatusModal">
                      <i class="fa fa-refresh me-1"></i> Statut
                    </button>

                    <a class="btn btn-outline-secondary"
                       title="Voir"
                       href="{{ path('app_rendez_vous_show', {'id': rv.id}) }}">
                      <i class="fa fa-eye me-1"></i> Voir
                    </a>

                    <a class="btn btn-outline-secondary"
                       title="Imprimer"
                       href="{{ path('app_rendez_vous_print_pdf', {'id': rv.id}) }}"
                       target="_blank">
                      <i class="fa fa-print me-1"></i> Imprimer
                    </a>

                    <button type="button"
                            class="btn btn-outline-primary js-edit-rdv"
                            title="Modifier"
                            data-url="{{ path('app_rendez_vous_edit', {id: rv.id}) }}"
                            data-bs-toggle="modal"
                            data-bs-target="#editRdvModal">
                      <i class="ri-pencil-fill"></i>
                    </button>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>

          </table>
        </div>
      </div>
    </div>

  </div>
</div>

{# =========================
   MODAL AJOUT RENDEZ-VOUS
========================= #}
<div class="modal fade" id="addRendezVousModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-plus me-2 text-primary"></i> Nouveau rendez-vous
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        {{ form_start(form, {'attr': {'id': 'RendezVousForm'}}) }}

        <div class="row g-3">
          <div class="col-md-6">{{ form_row(form.dateHeure) }}</div>
          <div class="col-md-6">{{ form_row(form.statut) }}</div>

          <div class="col-12">{{ form_row(form.motif) }}</div>

          <div class="col-md-6">{{ form_row(form.patient) }}</div>
          <div class="col-md-6">{{ form_row(form.medecin) }}</div>
        </div>

        <div class="d-flex justify-content-end mt-4 gap-2">
          <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Annuler</button>
          <button class="btn btn-primary">
            <i class="fa fa-save me-1"></i> Enregistrer
          </button>
        </div>

        {{ form_end(form) }}
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL EDIT RDV (AJAX)
========================= #}
<div class="modal fade" id="editRdvModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Modifier rendez-vous
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div id="editRdvLoader" class="py-5 text-center">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>

        <div id="editRdvModalBody" class="d-none"></div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fermer</button>
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL EDIT STATUT RDV (AJAX)
========================= #}
<div class="modal fade" id="editRdvStatusModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-md modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-refresh me-2 text-primary"></i> Modifier le statut
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div id="editRdvStatusLoader" class="py-4 text-center">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>

        <div id="editRdvStatusModalBody" class="d-none"></div>
      </div>

    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      function initRdvSelect2(context) {
        if (typeof $ === 'undefined' || typeof $.fn.select2 === 'undefined') return;
        const $ctx = $(context || document);
        $ctx.find('.js-select2-patient, .js-select2-medecin').each(function () {
          const $el = $(this);
          if ($el.hasClass('select2-hidden-accessible')) return;
          const placeholder = $el.data('placeholder') || 'Rechercher...';
          const $modal = $el.closest('.modal');
          $el.select2({
            width: '100%',
            placeholder: placeholder,
            allowClear: true,
            dropdownParent: $modal.length ? $modal : $(document.body),
            minimumResultsForSearch: 0
          });
        });
      }

      const modalEl = document.getElementById('editRdvModal');
      const loader  = document.getElementById('editRdvLoader');
      const body    = document.getElementById('editRdvModalBody');
      const statusModalEl = document.getElementById('editRdvStatusModal');
      const statusLoader = document.getElementById('editRdvStatusLoader');
      const statusBody = document.getElementById('editRdvStatusModalBody');

      let currentUrl = null;
      let currentStatusUrl = null;

      // Init Select2 pour le modal d'ajout
      document.addEventListener('DOMContentLoaded', function () {
        initRdvSelect2(document.getElementById('addRendezVousModal'));
      });
      document.addEventListener('shown.bs.modal', function (e) {
        initRdvSelect2(e.target);
      });

      function setLoading() {
        loader.classList.remove('d-none');
        body.classList.add('d-none');
        body.innerHTML = '';
      }

      function setStatusLoading() {
        statusLoader.classList.remove('d-none');
        statusBody.classList.add('d-none');
        statusBody.innerHTML = '';
      }

      function showError(msg) {
        loader.classList.add('d-none');
        body.classList.remove('d-none');
        body.innerHTML = `
          <div class="alert alert-danger d-flex align-items-start gap-2 mb-0">
            <i class="fa fa-exclamation-triangle mt-1"></i>
            <div>
              <div class="fw-semibold">Erreur</div>
              <div class="small">${msg || "Impossible de charger le formulaire."}</div>
            </div>
          </div>
        `;
      }

      function showStatusError(msg) {
        statusLoader.classList.add('d-none');
        statusBody.classList.remove('d-none');
        statusBody.innerHTML = `
          <div class="alert alert-danger d-flex align-items-start gap-2 mb-0">
            <i class="fa fa-exclamation-triangle mt-1"></i>
            <div>
              <div class="fw-semibold">Erreur</div>
              <div class="small">${msg || "Impossible de charger le formulaire."}</div>
            </div>
          </div>
        `;
      }

      function focusFirstField() {
        const first = body.querySelector('input, select, textarea');
        if (first) first.focus();
      }

      function focusFirstStatusField() {
        const first = statusBody.querySelector('input, select, textarea');
        if (first) first.focus();
      }

      async function loadEdit(url) {
        currentUrl = url;
        setLoading();

        const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);

        const html = await resp.text();
        body.innerHTML = html;

        loader.classList.add('d-none');
        body.classList.remove('d-none');

        initRdvSelect2(body);
        focusFirstField();
        bindEditSubmit();
      }

      async function loadStatusEdit(url) {
        currentStatusUrl = url;
        setStatusLoading();

        const resp = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!resp.ok) throw new Error('HTTP ' + resp.status);

        statusBody.innerHTML = await resp.text();

        statusLoader.classList.add('d-none');
        statusBody.classList.remove('d-none');

        focusFirstStatusField();
        bindStatusEditSubmit();
      }

      function bindEditSubmit() {
        // ⚠️ ton template edit doit sortir un form avec id="RdvEditForm"
        const form = body.querySelector('#RdvEditForm') || body.querySelector('form');
        if (!form) return;

        if (form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const submitBtn = form.querySelector('[type="submit"]');
          const oldHtml = submitBtn ? submitBtn.innerHTML : null;

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Enregistrement...`;
          }

          try {
            const action = form.getAttribute('action') || currentUrl;
            const formData = new FormData(form);

            const resp = await fetch(action, {
              method: (form.getAttribute('method') || 'POST').toUpperCase(),
              body: formData,
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const contentType = resp.headers.get('content-type') || '';

            if (contentType.includes('application/json')) {
              const data = await resp.json();
              if (data.success) {
                bootstrap.Modal.getInstance(modalEl)?.hide();
                window.location.reload();
                return;
              }
            }

            // erreurs => HTML
            body.innerHTML = await resp.text();
            initRdvSelect2(body);
            focusFirstField();
            bindEditSubmit();
          } catch (err) {
            showError("Une erreur est survenue lors de l'enregistrement.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = oldHtml;
            }
          }
        });
      }

      function bindStatusEditSubmit() {
        const form = statusBody.querySelector('#RdvStatusForm') || statusBody.querySelector('form');
        if (!form) return;

        if (form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const submitBtn = form.querySelector('[type="submit"]');
          const oldHtml = submitBtn ? submitBtn.innerHTML : null;

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Mise à jour...`;
          }

          try {
            const action = form.getAttribute('action') || currentStatusUrl;
            const formData = new FormData(form);

            const resp = await fetch(action, {
              method: (form.getAttribute('method') || 'POST').toUpperCase(),
              body: formData,
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const contentType = resp.headers.get('content-type') || '';

            if (contentType.includes('application/json')) {
              const data = await resp.json();
              if (data.success) {
                bootstrap.Modal.getInstance(statusModalEl)?.hide();
                window.location.reload();
                return;
              }
            }

            statusBody.innerHTML = await resp.text();
            focusFirstStatusField();
            bindStatusEditSubmit();
          } catch (err) {
            showStatusError("Une erreur est survenue lors de la mise à jour du statut.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = oldHtml;
            }
          }
        });
      }

      // Délégation => pas besoin de querySelectorAll
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-edit-rdv');
        if (!btn) return;

        const url = btn.getAttribute('data-url');
        if (!url) return;

        loadEdit(url).catch(() => showError("Impossible de charger le formulaire. Vérifie la route et la réponse AJAX."));
      });

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-edit-rdv-status');
        if (!btn) return;

        const url = btn.getAttribute('data-url');
        if (!url) return;

        loadStatusEdit(url).catch(() => showStatusError("Impossible de charger le formulaire de statut."));
      });

      modalEl?.addEventListener('hidden.bs.modal', () => {
        currentUrl = null;
        setLoading();
      });

      statusModalEl?.addEventListener('hidden.bs.modal', () => {
        currentStatusUrl = null;
        setStatusLoading();
      });

      // Gestionnaire pour le filtre de statut
      document.getElementById('statutFilter').addEventListener('change', function() {
        const selectedValue = this.value;
        const url = new URL(window.location);
        if (selectedValue) {
          url.searchParams.set('statut', selectedValue);
        } else {
          url.searchParams.set('statut', ''); // Explicitement définir comme vide pour "Tous les statuts"
        }
        window.location.href = url.toString();
      });
    })();
  </script>
{% endblock %}