{% extends 'base.html.twig' %}

{% block title %}Détail du rendez-vous{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold text-dark">
                <i class="bi bi-calendar2-check me-2 text-primary"></i>Détail du rendez-vous
            </h1>
            <p class="text-muted mb-0">
                Consultation des informations complètes du rendez-vous N° {{ rendez_vou.id }}
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_rendez_vous_index') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>Retour à la liste
            </a>

            <a href="{{ path('app_rendez_vous_edit', {'id': rendez_vou.id}) }}" class="btn btn-primary">
                <i class="bi bi-pencil-square me-1"></i>Modifier
            </a>
        </div>
    </div>

    {% set statutLabel = {
        'en_attente': 'En attente',
        'planifie': 'Planifié',
        'confirme': 'Confirmé',
        'annule': 'Annulé',
        'termine': 'Terminé'
    }[rendez_vou.statut.value] ?? rendez_vou.statut.value %}

    {% set statutClass = {
        'en_attente': 'warning',
        'planifie': 'info',
        'confirme': 'primary',
        'annule': 'danger',
        'termine': 'success'
    }[rendez_vou.statut.value] ?? 'secondary' %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold text-dark">
                        <i class="bi bi-card-list me-2 text-primary"></i>Informations générales
                    </h5>
                </div>

                <div class="card-body pt-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <tbody>
                                <tr>
                                    <th class="text-muted fw-semibold" style="width: 240px;">Identifiant</th>
                                    <td>
                                        <span class="badge bg-dark-subtle text-dark px-3 py-2 rounded-pill">
                                            #{{ rendez_vou.id }}
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-muted fw-semibold">Date et heure</th>
                                    <td>
                                        {% if rendez_vou.dateHeure %}
                                            <div class="fw-semibold text-dark">
                                                {{ rendez_vou.dateHeure|date('d/m/Y') }}
                                            </div>
                                            <small class="text-muted">
                                                à {{ rendez_vou.dateHeure|date('H:i') }}
                                            </small>
                                        {% else %}
                                            <span class="text-muted">Non renseignée</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-muted fw-semibold">Statut</th>
                                    <td>
                                        <span class="badge bg-{{ statutClass }}-subtle text-{{ statutClass }} px-3 py-2 rounded-pill">
                                            {{ statutLabel }}
                                        </span>
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-muted fw-semibold">Motif</th>
                                    <td>
                                        {% if rendez_vou.motif %}
                                            <div class="text-dark" style="white-space: pre-line;">
                                                {{ rendez_vou.motif }}
                                            </div>
                                        {% else %}
                                            <span class="text-muted">Aucun motif renseigné</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-muted fw-semibold">Date de création</th>
                                    <td>
                                        {% if rendez_vou.createdAt %}
                                            {{ rendez_vou.createdAt|date('d/m/Y à H:i:s') }}
                                        {% else %}
                                            <span class="text-muted">Non disponible</span>
                                        {% endif %}
                                    </td>
                                </tr>

                                <tr>
                                    <th class="text-muted fw-semibold">Dernière modification</th>
                                    <td>
                                        {% if rendez_vou.modifiedAt %}
                                            {{ rendez_vou.modifiedAt|date('d/m/Y à H:i:s') }}
                                        {% else %}
                                            <span class="text-muted">Non disponible</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-semibold text-dark">
                        <i class="bi bi-info-circle me-2 text-primary"></i>Résumé
                    </h5>
                </div>

                <div class="card-body">
                    <div class="mb-3">
                        <div class="text-muted small">Rendez-vous</div>
                        <div class="fw-bold fs-5 text-dark">#{{ rendez_vou.id }}</div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Statut actuel</div>
                        <div>
                            <span class="badge bg-{{ statutClass }}-subtle text-{{ statutClass }} px-3 py-2 rounded-pill">
                                {{ statutLabel }}
                            </span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="text-muted small">Programmation</div>
                        <div class="fw-semibold text-dark">
                            {{ rendez_vou.dateHeure ? rendez_vou.dateHeure|date('d/m/Y à H:i') : 'Non renseignée' }}
                        </div>
                    </div>

                    <hr>

                    <div class="d-grid gap-2">
                        <a href="{{ path('app_rendez_vous_edit', {'id': rendez_vou.id}) }}" class="btn btn-primary">
                            <i class="bi bi-pencil-square me-1"></i>Modifier ce rendez-vous
                        </a>

                        <a href="{{ path('app_rendez_vous_index') }}" class="btn btn-light border">
                            <i class="bi bi-list-ul me-1"></i>Voir la liste
                        </a>
                    </div>

                    <div class="mt-3">
                        {{ include('rendez_vous/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}