{% block title %}Impression rendez-vous{% endblock %}

{% block body %}
<style>
    @page {
        size: A4 portrait;
        margin: 5mm;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: DejaVu Sans, Arial, sans-serif;
        font-size: 9.5px;
        color: #1f2937;
        background: #ffffff;
    }

    .document {
        width: 100%;
    }

    .sheet {
        border: 1px solid #d7dee7;
        padding: 6px;
        background: #ffffff;
    }

    .top-bar {
        height: 6px;
        background: linear-gradient(90deg, #0f4c81 0%, #1d6fa5 55%, #7db4d8 100%);
        margin-bottom: 8px;
        border-radius: 4px;
    }

    .header-table,
    .meta-table,
    .summary-table,
    .footer-table,
    .signature-table {
        width: 100%;
        border-collapse: collapse;
    }

    .header-table td,
    .meta-table td,
    .summary-table td,
    .footer-table td,
    .signature-table td {
        vertical-align: top;
    }

    .clinic-logo {
        width: 23mm;
        height: 23mm;
        border: 1px solid #cfd8e3;
        padding: 2px;
        background: #ffffff;
        border-radius: 50%;
        box-shadow: 0 2px 6px rgba(15, 76, 129, 0.08);
    }

    .clinic h1 {
        margin: 0 0 4px 0;
        font-size: 13.5px;
        font-weight: bold;
        color: #0f4c81;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        line-height: 1.15;
    }

    .clinic .sub {
        font-size: 7.8px;
        line-height: 1.45;
        color: #4b5563;
    }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 8px;
        font-weight: bold;
        letter-spacing: 0.04em;
        border: 1px solid #d1d5db;
        background: #f8fafc;
        color: #374151;
        text-transform: uppercase;
    }

    .badge-soft-success {
        background: #ecfdf5;
        border-color: #b7ebcf;
        color: #166534;
    }

    .badge-soft-warning {
        background: #fffbeb;
        border-color: #f6dd9b;
        color: #92400e;
    }

    .badge-soft-danger {
        background: #fef2f2;
        border-color: #f1b3b3;
        color: #b91c1c;
    }

    .separator {
        border-bottom: 1px solid #d7dee7;
        margin: 8px 0;
    }

    .title-box {
        text-align: center;
        margin-bottom: 8px;
    }

    .title-box .title {
        font-size: 12.5px;
        font-weight: bold;
        color: #0f4c81;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .title-box .subtitle {
        margin-top: 3px;
        font-size: 7.4px;
        color: #6b7280;
    }

    .meta-box,
    .summary-box,
    .box {
        border: 1px solid #d7dee7;
        border-radius: 8px;
    }

    .meta-box {
        padding: 6px;
        margin-bottom: 7px;
        background: #fbfdff;
    }

    .meta-table td {
        width: 50%;
        padding: 4px 5px;
        line-height: 1.35;
    }

    .meta-label {
        display: block;
        font-size: 7px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6b7280;
        margin-bottom: 1px;
    }

    .meta-value {
        display: block;
        font-size: 9.4px;
        font-weight: bold;
        color: #111827;
    }

    .summary-box {
        margin-bottom: 7px;
        padding: 0;
        overflow: hidden;
    }

    .summary-table td {
        width: 33.33%;
        padding: 6px 7px;
        border-right: 1px solid #e5ebf2;
        background: #ffffff;
    }

    .summary-table td:last-child {
        border-right: none;
    }

    .summary-kicker {
        font-size: 7px;
        text-transform: uppercase;
        color: #6b7280;
        letter-spacing: 0.05em;
        margin-bottom: 2px;
    }

    .summary-value {
        font-size: 9px;
        font-weight: bold;
        color: #0f172a;
        line-height: 1.35;
    }

    .section {
        margin-top: 6px;
    }

    .section-title {
        padding: 5px 7px;
        font-size: 9px;
        font-weight: bold;
        color: #0f4c81;
        background: #f5f9fc;
        border: 1px solid #d7dee7;
        border-bottom: none;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-top-left-radius: 8px;
        border-top-right-radius: 8px;
    }

    .box {
        padding: 7px;
        line-height: 1.45;
        border-top-left-radius: 0;
        border-top-right-radius: 0;
        background: #ffffff;
    }

    .notes-box {
        min-height: 64px;
    }

    .notes-lines {
        margin-top: 2px;
    }

    .notes-line {
        height: 15px;
        border-bottom: 1px dashed #d9e1ea;
    }

    .footer-block {
        border-top: 1px dashed #d1d5db;
        margin-top: 8px;
        padding-top: 7px;
    }

    .footer-left {
        font-size: 8px;
        color: #6b7280;
        line-height: 1.45;
        padding-right: 8px;
    }

    .qr-box {
        width: 30mm;
        text-align: center;
        border: 1px solid #d7dee7;
        border-radius: 8px;
        padding: 4px;
        background: #f8fbfe;
    }

    .qr-box img {
        width: 21mm;
        height: 21mm;
        border: 1px solid #e5e7eb;
        background: #fff;
        padding: 2px;
    }

    .qr-label {
        margin-top: 3px;
        font-size: 7px;
        line-height: 1.3;
        color: #6b7280;
        word-break: break-word;
    }

    .signature-table {
        margin-top: 12px;
    }

    .signature-block {
        text-align: center;
        vertical-align: bottom;
        height: 62px;
        padding: 0 10px;
    }

    .signature-title {
        font-size: 8px;
        color: #6b7280;
        margin-bottom: 38px;
    }

    .line {
        border-top: 1px solid #000;
        padding-top: 4px;
        font-size: 8px;
        color: #6b7280;
    }

    .footer-note {
        margin-top: 8px;
        padding: 5px 4px 0;
        text-align: center;
        font-size: 8.6px;
        font-weight: bold;
        color: #0f4c81;
        border-top: 1px dashed #d1d5db;
        letter-spacing: 0.03em;
    }

    .no-print {
        display: none;
    }

    @media screen {
        body {
            background: #f9fafb;
        }

        .document {
            max-width: 148mm;
            margin: 12px auto;
            padding: 10px;
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.08);
        }

        .no-print {
            display: block;
            margin-bottom: 10px;
            text-align: right;
        }

        .btn-print,
        .btn-back {
            display: inline-block;
            padding: 7px 11px;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            text-decoration: none;
            font-size: 11px;
            cursor: pointer;
            background: #fff;
            color: #111827;
            margin-left: 8px;
        }

        .btn-primary {
            background: #0f4c81;
            color: #fff;
            border-color: #0f4c81;
        }
    }

    @media print {
        .no-print {
            display: none !important;
        }
    }
</style>

{# ===== Données clinique ===== #}
{% set clinic_name = 'CLINIQUE NEUROLOGIQUE NASSARAWA' %}
{% set clinic_nif = '120402/R' %}
{% set clinic_rccm = 'NE-NIM-01-2024-B12-00145' %}
{% set clinic_addr = 'Yantala Haut, Avenue du Daoura YN 187, Niamey - Niger' %}
{% set clinic_phone = '20 75 51 02 / 82 09 61 12' %}
{% set clinic_bp = 'BP : 2120 Niamey' %}
{% set clinic_email = 'nassrawaclinique@gmail.com' %}

{# ===== Données rendez-vous ===== #}
{% set patientNom = rendez_vous.patient ? ((rendez_vous.patient.nom ?? '') ~ ' ' ~ (rendez_vous.patient.prenom ?? ''))|trim : '—' %}
{% set medecinNom = rendez_vous.medecin ? (rendez_vous.medecin.nomComplet ?? ((rendez_vous.medecin.nom ?? '') ~ ' ' ~ (rendez_vous.medecin.prenom ?? ''))|trim) : '—' %}
{% set dt = rendez_vous.dateheure ? rendez_vous.dateheure|date('d/m/Y H:i') : '—' %}
{% set statut = rendez_vous.statut ? rendez_vous.statut.value : '—' %}
{% set motif = rendez_vous.motif ?: '—' %}
{% set dossier = (rendez_vous.patient and rendez_vous.patient.dossierMedical)
    ? (rendez_vous.patient.dossierMedical.numeroDossier ?? ('#' ~ rendez_vous.patient.dossierMedical.id))
    : '—'
%}
{% set telephone = rendez_vous.patient and rendez_vous.patient.telephone is defined ? rendez_vous.patient.telephone : '—' %}
{% set sexe = rendez_vous.patient and rendez_vous.patient.sexe is defined ? rendez_vous.patient.sexe : '—' %}
{% set age = rendez_vous.patient and rendez_vous.patient.age is defined ? rendez_vous.patient.age ~ ' ans' : '—' %}
{% set badgeClass = 'badge-soft-warning' %}
{% if statut in ['CONFIRME', 'VALIDE', 'PLANIFIE'] %}
    {% set badgeClass = 'badge-soft-success' %}
{% elseif statut in ['ANNULE', 'REPORTE', 'ABSENT'] %}
    {% set badgeClass = 'badge-soft-danger' %}
{% endif %}

{% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}
{% set showUrl = verifyUrl is defined ? verifyUrl : absolute_url(path('app_rendez_vous_show', {'id': rendez_vous.id})) %}

<div class="document">
    <div class="sheet">

    {# <div class="no-print">
        <a href="{{ path('app_rendez_vous_show', {'id': rendez_vous.id}) }}" class="btn-back">Retour</a>
        <button type="button" onclick="window.print()" class="btn-print btn-primary">Imprimer</button>
    </div> #}

    <div class="top-bar"></div>

    <table class="header-table">
        <tr>
            <td style="width:18%;">
                {% if logo_path is defined and logo_path %}
                    <img src="{{ logo_path }}" alt="Logo Clinique Nassarawa" class="clinic-logo">
                {% endif %}
            </td>

            <td style="width:58%;">
                <div class="clinic">
                    <h1>{{ clinic_name }}</h1>
                    <div class="sub">
                        <strong>NIF :</strong> {{ clinic_nif }}<br>
                        <strong>RCCM :</strong> {{ clinic_rccm }}<br>
                        <strong>Adresse :</strong> {{ clinic_addr }}<br>
                        <strong>Tél :</strong> {{ clinic_phone }}<br>
                        <strong>{{ clinic_bp }}</strong><br>
                        <strong>Email :</strong> {{ clinic_email }}
                    </div>
                </div>
            </td>

            <td style="width:24%; text-align:right;">
                <span class="badge {{ badgeClass }}">{{ statut }}</span>
            </td>
        </tr>
    </table>

    <div class="separator"></div>

    <div class="title-box">
        <div class="title">Fiche de rendez-vous</div>
        <div class="subtitle">
            Référence : RDV-{{ rendez_vous.id }} | Généré le {{ "now"|date('d/m/Y H:i') }}
        </div>
    </div>

    <div class="meta-box">
        <table class="meta-table">
            <tr>
                <td>
                    <span class="meta-label">Patient</span>
                    <span class="meta-value">{{ patientNom }}</span>
                </td>
                <td>
                    <span class="meta-label">Dossier médical</span>
                    <span class="meta-value">{{ dossier }}</span>
                </td>
            </tr>
            <tr>
                <td>
                    <span class="meta-label">Médecin</span>
                    <span class="meta-value">{{ medecinNom }}</span>
                </td>
                <td>
                    <span class="meta-label">Date et heure</span>
                    <span class="meta-value">{{ dt }}</span>
                </td>
            </tr>
            <tr>
                <td>
                    <span class="meta-label">Téléphone</span>
                    <span class="meta-value">{{ telephone }}</span>
                </td>
                <td>
                    <span class="meta-label">Statut</span>
                    <span class="meta-value">{{ statut }}</span>
                </td>
            </tr>
        </table>
    </div>

    <div class="summary-box">
        <table class="summary-table">
            <tr>
                <td>
                    <div class="summary-kicker">Sexe</div>
                    <div class="summary-value">{{ sexe }}</div>
                </td>
                <td>
                    <div class="summary-kicker">Âge</div>
                    <div class="summary-value">{{ age }}</div>
                </td>
                <td>
                    <div class="summary-kicker">Référence</div>
                    <div class="summary-value">RDV-{{ rendez_vous.id }}</div>
                </td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Motif du rendez-vous</div>
        <div class="box">
            {{ motif }}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Observations / Notes</div>
        <div class="box notes-box">
            <div class="notes-lines">
                <div class="notes-line"></div>
                <div class="notes-line"></div>
                <div class="notes-line"></div>
                <div class="notes-line"></div>
            </div>
        </div>
    </div>

    <div class="footer-block">
        <table class="footer-table">
            <tr>
                <td style="width:60%;" class="footer-left">
                    <div><strong>Document :</strong> Fiche de rendez-vous générée automatiquement par le système de gestion de la clinique.</div>
                    <div><strong>Référence :</strong> RDV-{{ rendez_vous.id }}</div>
                    <div><strong>Vérification :</strong> Scanner le QR code ci-contre.</div>
                </td>

                <td style="width:40%; text-align:right;">
                    <div class="qr-box" style="float:right;">
                        {% if _qr %}
                            <img src="{{ _qr }}" alt="QR Code">
                        {% endif %}
                        <div class="qr-label">Vérifier le rendez-vous</div>
                        {% if code_qr is defined and code_qr %}
                            <div class="qr-label">Code : {{ code_qr }}</div>
                        {% endif %}
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <table class="signature-table">
        <tr>
            <td class="signature-block" style="width:50%;">
                <div class="signature-title">Médecin / Cachet</div>
                <div class="line">Signature / Cachet</div>
            </td>
            <td class="signature-block" style="width:50%;">
                <div class="signature-title">Service accueil</div>
                <div class="line">Visa / Accueil</div>
            </td>
        </tr>
    </table>

    <div class="footer-note">
        Merci de conserver cette fiche et de la présenter en cas de besoin
    </div>
    </div>
</div>
{% endblock %}