{% block title %}Impression rendez-vous{% endblock %}

{% block body %}
<style>
    @page {
        size: A5 portrait;
        margin: 5mm;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: DejaVu Sans, Arial, sans-serif;
        font-size: 9.5px;
        color: #1f2937;
        background: #ffffff;
    }

    .document {
        width: 100%;
    }

    .top-bar {
        height: 4px;
        background: #0f4c81;
        margin-bottom: 6px;
    }

    .header-table,
    .meta-table,
    .footer-table,
    .signature-table {
        width: 100%;
        border-collapse: collapse;
    }

    .header-table td,
    .meta-table td,
    .footer-table td,
    .signature-table td {
        vertical-align: top;
    }

    .clinic-logo {
        width: 24mm;
        height: 24mm;
        border: 1px solid #d1d5db;
        padding: 2px;
        background: #ffffff;
        border-radius: 50%;
    }

    .clinic h1 {
        margin: 0 0 3px 0;
        font-size: 13px;
        font-weight: bold;
        color: #0f4c81;
        text-transform: uppercase;
        line-height: 1.2;
    }

    .clinic .sub {
        font-size: 8px;
        line-height: 1.35;
        color: #6b7280;
    }

    .badge {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 10px;
        font-size: 8px;
        font-weight: bold;
        border: 1px solid #d1d5db;
        background: #f8fafc;
        color: #374151;
    }

    .separator {
        border-bottom: 1px solid #d1d5db;
        margin: 6px 0;
    }

    .title-box {
        text-align: center;
        margin-bottom: 6px;
    }

    .title-box .title {
        font-size: 12px;
        font-weight: bold;
        color: #0f4c81;
        text-transform: uppercase;
    }

    .title-box .subtitle {
        margin-top: 2px;
        font-size: 7px;
        color: #6b7280;
    }

    .meta-box,
    .box {
        border: 1px solid #d1d5db;
    }

    .meta-box {
        padding: 5px;
        margin-bottom: 6px;
    }

    .meta-table td {
        width: 50%;
        padding: 2px 4px;
        line-height: 1.3;
    }

    .section {
        margin-top: 5px;
    }

    .section-title {
        padding: 4px 6px;
        font-size: 9px;
        font-weight: bold;
        color: #0f4c81;
        background: #f8fafc;
        border: 1px solid #d1d5db;
        border-bottom: none;
        text-transform: uppercase;
    }

    .box {
        padding: 6px;
        line-height: 1.35;
    }

    .notes-box {
        min-height: 70px;
    }

    .footer-block {
        border-top: 1px dashed #d1d5db;
        margin-top: 6px;
        padding-top: 6px;
    }

    .footer-left {
        font-size: 8px;
        color: #6b7280;
        line-height: 1.3;
        padding-right: 6px;
    }

    .qr-box {
        width: 28mm;
        text-align: center;
        border: 1px solid #d1d5db;
        padding: 3px;
        background: #f8fafc;
    }

    .qr-box img {
        width: 20mm;
        height: 20mm;
        border: 1px solid #e5e7eb;
        background: #fff;
        padding: 2px;
    }

    .qr-label {
        margin-top: 2px;
        font-size: 7px;
        line-height: 1.2;
        color: #6b7280;
        word-break: break-word;
    }

    .signature-table {
        margin-top: 10px;
    }

    .signature-block {
        text-align: center;
        vertical-align: bottom;
        height: 65px;
        padding: 0 8px;
    }

    .line {
        border-top: 1px solid #000;
        padding-top: 4px;
        font-size: 8px;
        color: #6b7280;
    }

    .footer-note {
        margin-top: 6px;
        padding-top: 4px;
        text-align: center;
        font-size: 9px;
        font-weight: bold;
        color: #0f4c81;
        border-top: 1px dashed #d1d5db;
    }

    .no-print {
        display: none;
    }

    @media screen {
        body {
            background: #f9fafb;
        }

        .document {
            max-width: 148mm;
            margin: 12px auto;
            background: #fff;
            border: 1px solid #e5e7eb;
            padding: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,.06);
        }

        .no-print {
            display: block;
            margin-bottom: 10px;
            text-align: right;
        }

        .btn-print,
        .btn-back {
            display: inline-block;
            padding: 7px 11px;
            border-radius: 8px;
            border: 1px solid #d1d5db;
            text-decoration: none;
            font-size: 11px;
            cursor: pointer;
            background: #fff;
            color: #111827;
            margin-left: 8px;
        }

        .btn-primary {
            background: #0f4c81;
            color: #fff;
            border-color: #0f4c81;
        }
    }

    @media print {
        .no-print {
            display: none !important;
        }
    }
</style>

{# ===== Données clinique ===== #}
{% set clinic_name = 'CLINIQUE MÉDICALE NASSARAWA' %}
{% set clinic_nif = '120402/R' %}
{% set clinic_rccm = 'NE-NIM-01-2024-B12-00145' %}
{% set clinic_addr = 'Yantala Haut, Avenue du Daoura YN 187, Niamey - Niger' %}
{% set clinic_phone = '20 75 51 02 / 88 05 22 20' %}
{% set clinic_bp = 'BP : 2120 Niamey' %}
{% set clinic_email = 'nassrawaclinique@gmail.com' %}

{# ===== Données rendez-vous ===== #}
{% set patientNom = rendez_vous.patient ? ((rendez_vous.patient.nom ?? '') ~ ' ' ~ (rendez_vous.patient.prenom ?? ''))|trim : '—' %}
{% set medecinNom = rendez_vous.medecin ? (rendez_vous.medecin.nomComplet ?? ((rendez_vous.medecin.nom ?? '') ~ ' ' ~ (rendez_vous.medecin.prenom ?? ''))|trim) : '—' %}
{% set dt = rendez_vous.dateheure ? rendez_vous.dateheure|date('d/m/Y H:i') : '—' %}
{% set statut = rendez_vous.statut ? rendez_vous.statut.value : '—' %}
{% set motif = rendez_vous.motif ?: '—' %}
{% set dossier = (rendez_vous.patient and rendez_vous.patient.dossierMedical)
    ? (rendez_vous.patient.dossierMedical.numeroDossier ?? ('#' ~ rendez_vous.patient.dossierMedical.id))
    : '—'
%}
{% set telephone = rendez_vous.patient and rendez_vous.patient.telephone is defined ? rendez_vous.patient.telephone : '—' %}
{% set sexe = rendez_vous.patient and rendez_vous.patient.sexe is defined ? rendez_vous.patient.sexe : '—' %}
{% set age = rendez_vous.patient and rendez_vous.patient.age is defined ? rendez_vous.patient.age ~ ' ans' : '—' %}

{% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}
{% set showUrl = verifyUrl is defined ? verifyUrl : absolute_url(path('app_rendez_vous_show', {'id': rendez_vous.id})) %}

<div class="document">

    <div class="no-print">
        <a href="{{ path('app_rendez_vous_show', {'id': rendez_vous.id}) }}" class="btn-back">Retour</a>
        <button type="button" onclick="window.print()" class="btn-print btn-primary">Imprimer</button>
    </div>

    <div class="top-bar"></div>

    <table class="header-table">
        <tr>
            <td style="width:18%;">
                {% if logo_path is defined and logo_path %}
                    <img src="{{ logo_path }}" alt="Logo Clinique Nassarawa" class="clinic-logo">
                {% endif %}
            </td>

            <td style="width:58%;">
                <div class="clinic">
                    <h1>{{ clinic_name }}</h1>
                    <div class="sub">
                        <strong>NIF :</strong> {{ clinic_nif }}<br>
                        <strong>RCCM :</strong> {{ clinic_rccm }}<br>
                        <strong>Adresse :</strong> {{ clinic_addr }}<br>
                        <strong>Tél :</strong> {{ clinic_phone }}<br>
                        <strong>{{ clinic_bp }}</strong><br>
                        <strong>Email :</strong> {{ clinic_email }}
                    </div>
                </div>
            </td>

            <td style="width:24%; text-align:right;">
                <span class="badge">{{ statut }}</span>
            </td>
        </tr>
    </table>

    <div class="separator"></div>

    <div class="title-box">
        <div class="title">Fiche de rendez-vous</div>
        <div class="subtitle">
            Référence : RDV-{{ rendez_vous.id }} — Généré le {{ "now"|date('d/m/Y H:i') }}
        </div>
    </div>

    <div class="meta-box">
        <table class="meta-table">
            <tr>
                <td><strong>Patient :</strong> {{ patientNom }}</td>
                <td><strong>Dossier médical :</strong> {{ dossier }}</td>
            </tr>
            <tr>
                <td><strong>Médecin :</strong> {{ medecinNom }}</td>
                <td><strong>Date & heure :</strong> {{ dt }}</td>
            </tr>
            <tr>
                <td><strong>Téléphone :</strong> {{ telephone }}</td>
                <td><strong>Statut :</strong> {{ statut }}</td>
            </tr>
            <tr>
                <td><strong>Sexe :</strong> {{ sexe }}</td>
                <td><strong>Âge :</strong> {{ age }}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Motif du rendez-vous</div>
        <div class="box">
            {{ motif }}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Observations / Notes</div>
        <div class="box notes-box">
            —
        </div>
    </div>

    <div class="footer-block">
        <table class="footer-table">
            <tr>
                <td style="width:60%;" class="footer-left">
                    <div><strong>Document :</strong> Fiche de rendez-vous générée automatiquement par le système de gestion de la clinique.</div>
                    <div><strong>Référence :</strong> RDV-{{ rendez_vous.id }}</div>
                    <div><strong>Vérification :</strong> Scanner le QR code ci-contre.</div>
                </td>

                <td style="width:40%; text-align:right;">
                    <div class="qr-box" style="float:right;">
                        {% if _qr %}
                            <img src="{{ _qr }}" alt="QR Code">
                        {% endif %}
                        <div class="qr-label">Vérifier le rendez-vous</div>
                        {% if code_qr is defined and code_qr %}
                            <div class="qr-label">Code : {{ code_qr }}</div>
                        {% endif %}
                    </div>
                </td>
            </tr>
        </table>
    </div>

    <table class="signature-table">
        <tr>
            <td class="signature-block" style="width:50%;">
                <div class="line">Signature / Cachet</div>
            </td>
            <td class="signature-block" style="width:50%;">
                <div class="line">Visa / Accueil</div>
            </td>
        </tr>
    </table>

    <div class="footer-note">
        Merci de conserver cette fiche et de la présenter en cas de besoin
    </div>
</div>
{% endblock %}