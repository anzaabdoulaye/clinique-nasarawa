{{ form_start(form) }}

<div class="row g-3">
    <div class="col-12">
        {{ form_errors(form) }}
    </div>

    {% if form.medecin is defined %}
        <div class="col-md-6">
            {{ form_row(form.medecin) }}
        </div>
    {% endif %}

    {% if form.dossierMedical is defined %}
        <div class="col-md-6">
            {{ form_row(form.dossierMedical) }}
        </div>
    {% endif %}

    {% if form.rendezVous is defined %}
        <div class="col-md-6">
            {{ form_row(form.rendezVous) }}
        </div>
    {% endif %}

    {% if form.dateConsultation is defined %}
        <div class="col-md-6">
            {{ form_row(form.dateConsultation) }}
        </div>
    {% endif %}

    {% if form.facture is defined %}
        <div class="col-md-6">
            {{ form_row(form.facture) }}
        </div>
    {% endif %}

    {% if form.tarifPrestation is defined %}
        <div class="col-md-6">
            {{ form_row(form.tarifPrestation) }}
        </div>
    {% endif %}
</div>

<div class="d-flex justify-content-end gap-2 mt-4">
    <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
        Annuler
    </button>
    <button type="submit" class="btn btn-primary">
        <i class="fa fa-save me-1"></i> Enregistrer
    </button>
</div>

{{ form_end(form) }}