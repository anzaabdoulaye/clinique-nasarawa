{% extends 'base.html.twig' %}

{% block title %}Consultation #{{ consultation.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set rdv = consultation.rendezVous|default(null) %}
    {% set patient = rdv ? (rdv.patient|default(null)) : null %}
    {% set st = consultation.statut is defined and consultation.statut ? (consultation.statut.name ?? consultation.statut.value ?? '') : '' %}
    {% set badgeClass =
        st in ['EN_COURS'] ? 'bg-primary' :
        st in ['BROUILLON'] ? 'bg-secondary' :
        st in ['CLOTURE', 'CLOTUREE'] ? 'bg-success' :
        st in ['ANNULE', 'ANNULEE'] ? 'bg-danger' :
        'bg-dark'
    %}
    {% set locked = st in ['CLOTURE', 'CLOTUREE', 'ANNULE', 'ANNULEE'] %}

    {# ===================== HEADER ===================== #}
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <h3 class="mb-1">
                Consultation <span class="text-muted">#{{ consultation.id }}</span>
            </h3>

            <div class="text-muted small">
                {% if rdv %}
                    RDV #{{ rdv.id }}
                    {% if rdv.dateHeure is defined and rdv.dateHeure %}
                        — {{ rdv.dateHeure|date('Y-m-d H:i') }}
                    {% endif %}
                {% endif %}
            </div>

            <div class="mt-2 d-flex flex-wrap gap-2">
                <span class="badge {{ badgeClass }}">{{ st ?: 'N/A' }}</span>

                {% if consultation.medecin is defined and consultation.medecin %}
                    <span class="badge bg-light text-dark border">
                        Médecin :
                        {{ consultation.medecin.nomComplet|default(((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim))|default(consultation.medecin.id) }}
                    </span>
                {% endif %}

                {% if patient %}
                    <span class="badge bg-light text-dark border">
                        Patient :
                        {{ patient.nomComplet|default(((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim))|default(patient.id) }}
                    </span>
                {% endif %}
            </div>
        </div>

        {# ===================== ACTIONS ===================== #}
        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_consultation_index') }}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left me-1"></i> Retour
            </a>

            <button type="button"
                    class="btn btn-primary js-edit-consultation {{ locked ? 'disabled' : '' }}"
                    title="Saisie médicale"
                    data-bs-toggle="modal"
                    data-bs-target="#editConsultationModal"
                    data-url="{{ path('app_consultation_medical_edit', {'id': consultation.id}) }}"
                    {{ locked ? 'disabled' : '' }}>
                <i class="fa fa-pen me-1"></i> Saisie médicale
            </button>
        </div>
    </div>

    {# ===================== PRESTATIONS PRESCRITES ===================== #}
    <div class="card shadow-sm border-0 rounded-4 mt-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Prestations prescrites</h5>
                <small class="text-muted">Actes, examens et consommables demandés par le médecin</small>
            </div>

            <button type="button"
                    class="btn btn-primary btn-sm js-add-prestation"
                    data-bs-toggle="modal"
                    data-bs-target="#prestationModal"
                    data-url="{{ path('app_prescription_prestation_new', {id: consultation.id}) }}">
                <i class="ri-add-line me-1"></i> Ajouter
            </button>
        </div>

        <div class="card-body">
            {% if consultation.prescriptionsPrestations is defined and consultation.prescriptionsPrestations|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Prestation</th>
                                <th>Catégorie</th>
                                <th>Quantité</th>
                                <th>Instructions</th>
                               
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptionsPrestations %}
                            <tr>
                                <td class="fw-semibold">
                                    {{ p.tarifPrestation.libelle|default('-') }}
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        {{ p.tarifPrestation.categorie.value|default('-')|replace({'_':' '})|title }}
                                    </span>
                                </td>
                                <td>{{ p.quantite|default(1) }}</td>
                                <td>{{ p.instructions ?: '-' }}</td>
                                <td class="text-end">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-primary js-edit-prestation"
                                            title="Modifier"
                                            data-bs-toggle="modal"
                                            data-bs-target="#prestationModal"
                                            data-url="{{ path('app_prescription_prestation_edit', {id: p.id}) }}">
                                        <i class="ri-pencil-line"></i>
                                    </button>

                                    <form method="post"
                                          action="{{ path('app_prescription_prestation_delete', {id: p.id}) }}"
                                          class="d-inline"
                                          onsubmit="return confirm('Supprimer cette prestation ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_prestation_' ~ p.id) }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                                            <i class="ri-delete-bin-line"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="ri-file-list-3-line fs-1 text-muted"></i>
                    <p class="text-muted mb-0 mt-2">Aucune prestation prescrite pour cette consultation.</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# ===================== KPI CARDS (Constantes) ===================== #}
    <div class="row g-3 mb-4 mt-1">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Poids</div>
                    <div class="fs-4 fw-semibold">
                       <div class="fs-4 fw-semibold" id="consultation-poids">
    {{ consultation.poids ?? '-' }} <span class="text-muted fs-6">kg</span>
</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Taille</div>
                    <div class="fs-4 fw-semibold">
                       <div class="fs-4 fw-semibold" id="consultation-taille">
    {{ consultation.taille ?? '-' }} <span class="text-muted fs-6">cm</span>
</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Température</div>
                    <div class="fs-4 fw-semibold">
                        <div class="fs-4 fw-semibold" id="consultation-temperature">
    {{ consultation.temperature ?? '-' }} <span class="text-muted fs-6">°C</span>
</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Fréquence cardiaque</div>
                    <div class="fs-4 fw-semibold">
                        <div class="fs-4 fw-semibold" id="consultation-frequence">
    {{ consultation.frequenceCardiaque ?? '-' }} <span class="text-muted fs-6">bpm</span>
</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ===================== TABS ===================== #}
    <ul class="nav nav-tabs" id="consultTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="tab-clinique"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-clinique"
                    type="button"
                    role="tab">
                Clinique
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="tab-prescriptions"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-prescriptions"
                    type="button"
                    role="tab">
                Prescriptions
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3" id="consultTabsContent">
        {# ========== CLINIQUE ========== #}
        <div class="tab-pane fade show active" id="pane-clinique" role="tabpanel">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Motif & Histoire</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Motifs</div>
                                <div id="consultation-motifs">{{ consultation.motifs ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">Histoire / Anamnèse</div>
                                <div id="consultation-histoire">{{ consultation.histoire ?? '-' }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Examen & Diagnostic</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Examen clinique</div>
                                <div id="consultation-examen">{{ consultation.examenClinique ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Tension artérielle</div>
                                <div id="consultation-tension">{{ consultation.tensionArterielle ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Diagnostic</div>
                                <div id="consultation-diagnostic">{{ consultation.diagnostic ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">CIM10</div>
                                <div id="consultation-cim10">
                                    {% if consultation.cim10 is defined and consultation.cim10 %}
                                        {{ consultation.cim10 }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card">
                        <div class="card-header fw-semibold">Conduite à tenir</div>
                        <div class="card-body">
                            <div id="consultation-conduite">{{ consultation.conduiteATenir ?? '-' }}</div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">
                        Créée : {{ consultation.createdAt ? consultation.createdAt|date('Y-m-d H:i') : '-' }}
                        — Modifiée : <div id="consultation-modified-at">
    {{ consultation.modifiedAt ? consultation.modifiedAt|date('Y-m-d H:i') : '-' }}
</div>
                    </div>
                </div>
            </div>
        </div>

        {# ========== PRESCRIPTIONS ========== #}
        <div class="tab-pane fade" id="pane-prescriptions" role="tabpanel">
            <div class="card mb-3 border-0 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Prescription</h6>
                    <span class="badge bg-light text-dark border">
                        {{ consultation.prescriptions is defined ? consultation.prescriptions|length : 0 }} document(s)
                    </span>
                </div>
                <div class="card-body" id="prescriptionSummary">
                    {% include 'prescription/_summary.html.twig' with { consultation: consultation } %}
                </div>
            </div>

            {% if consultation.prescriptions is defined and consultation.prescriptions|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Commentaire</th>
                            <th class="text-end">Lignes</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptions %}
                            <tr>
                                <td>{{ p.id }}</td>
                                <td>{{ p.datePrescription is defined and p.datePrescription ? p.datePrescription|date('Y-m-d H:i') : '-' }}</td>
                                <td>{{ p.commentaire ?? '-' }}</td>
                                <td class="text-end">
                                    {{ p.lignes is defined ? p.lignes|length : 0 }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucune prescription pour le moment.</div>
            {% endif %}
        </div>
    </div>
</div>

{# =========================
   MODAL EDIT CONSULTATION (AJAX)
========================= #}
<div class="modal fade" id="editConsultationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Saisie médicale
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div id="editConsultationLoader" class="py-5 text-center">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>

        <div id="editConsultationModalBody" class="d-none"></div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
          Fermer
        </button>
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL PRESTATION (AJAX)
========================= #}
<div class="modal fade" id="prestationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" id="prestationModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{# =========================
   MODAL RESUME PRESCRIPTION (AJAX)
========================= #}
<div class="modal fade" id="prescriptionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-body p-4 text-center text-muted">Chargement...</div>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>
    (() => {
        const modalEl = document.getElementById('editConsultationModal');
        if (!modalEl) {
            console.error('Modal #editConsultationModal introuvable');
            return;
        }

        let currentUrl = null;

        function getLoader() {
            return modalEl.querySelector('#editConsultationLoader');
        }

        function getBody() {
            return modalEl.querySelector('#editConsultationModalBody');
        }

        function setLoading() {
            const loader = getLoader();
            const body = getBody();

            if (!loader || !body) {
                console.error('Loader ou body introuvable dans la modale', { loader, body });
                return;
            }

            loader.classList.remove('d-none');
            body.classList.add('d-none');
            body.innerHTML = '';
        }

        function showError(message, details = '') {
            const loader = getLoader();
            const body = getBody();

            if (!body) {
                console.error('Body introuvable pour afficher erreur', { message, details });
                return;
            }

            if (loader) {
                loader.classList.add('d-none');
            }

            body.classList.remove('d-none');
            body.innerHTML = `
                <div class="alert alert-danger mb-0">
                    <div class="fw-semibold mb-1">Erreur</div>
                    <div>${message || 'Impossible de charger le formulaire.'}</div>
                    ${details ? `<hr><pre class="mb-0 small" style="white-space: pre-wrap;">${details}</pre>` : ''}
                </div>
            `;
        }

        function bindMedicalForm() {
            const body = getBody();
            if (!body) return;

            const form = body.querySelector('#medicalForm');
            console.log('bindMedicalForm =>', !!form);

            if (!form) {
                showError('Le formulaire #medicalForm est introuvable dans la modale.');
                return;
            }

            if (form.dataset.bound === '1') return;
            form.dataset.bound = '1';

            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                console.log('SUBMIT AJAX intercepté');

                const submitBtn = form.querySelector('button[type="submit"]');
                const oldHtml = submitBtn ? submitBtn.innerHTML : '';

                if (submitBtn) {
                    submitBtn.disabled = true;
                    submitBtn.innerHTML = 'Enregistrement...';
                }

                try {
                    const response = await fetch(form.action || currentUrl, {
                        method: (form.method || 'POST').toUpperCase(),
                        body: new FormData(form),
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    });

                    const contentType = response.headers.get('content-type') || '';
console.log('submit status=', response.status, 'contentType=', contentType);
console.log('submit redirected =', response.redirected);
console.log('submit final url =', response.url);

                    if (contentType.includes('application/json')) {
                        const data = await response.json();
                        console.log('JSON reçu:', data);

                        if (response.ok && data.success) {
                            bootstrap.Modal.getInstance(modalEl)?.hide();
                            const d = data.data || {};

                            const setHtml = (id, value) => {
                                const el = document.getElementById(id);
                                if (el) el.innerHTML = value ?? '-';
                            };

                            setHtml('consultation-poids', `${d.poids ?? '-'} <span class="text-muted fs-6">kg</span>`);
                            setHtml('consultation-taille', `${d.taille ?? '-'} <span class="text-muted fs-6">cm</span>`);
                            setHtml('consultation-temperature', `${d.temperature ?? '-'} <span class="text-muted fs-6">°C</span>`);
                            setHtml('consultation-frequence', `${d.frequenceCardiaque ?? '-'} <span class="text-muted fs-6">bpm</span>`);

                            setHtml('consultation-motifs', d.motifs || '-');
                            setHtml('consultation-histoire', d.histoire || '-');
                            setHtml('consultation-examen', d.examenClinique || '-');
                            setHtml('consultation-tension', d.tensionArterielle || '-');
                            setHtml('consultation-diagnostic', d.diagnostic || '-');
                            setHtml('consultation-cim10', d.cim10 || '-');
                            setHtml('consultation-conduite', d.conduiteATenir || '-');
                            setHtml('consultation-modified-at', d.modifiedAt || '-');

                            bootstrap.Modal.getInstance(modalEl)?.hide();
                            return;
                        }

                        showError(data.message || 'Erreur JSON côté serveur.', JSON.stringify(data, null, 2));
                        return;
                    }

                    const html = await response.text();
                    console.log('HTML reçu après submit');

                    const loader = getLoader();
                    const body = getBody();
                    if (!body) return;

                    body.innerHTML = html;
                    if (loader) loader.classList.add('d-none');
                    body.classList.remove('d-none');

                    bindMedicalForm();
                } catch (error) {
                    console.error('Erreur submit fetch:', error);
                    showError('Erreur JS/fetch pendant la soumission.', error.message || '');
                } finally {
                    if (submitBtn) {
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = oldHtml;
                    }
                }
            });
        }

        async function loadMedicalForm(url) {
            currentUrl = url;
            console.log('loadMedicalForm()', url);
            setLoading();

            try {
                const response = await fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const text = await response.text();
                console.log('GET status=', response.status);

                if (!response.ok) {
                    showError(`Chargement impossible (HTTP ${response.status})`, text);
                    return;
                }

                const loader = getLoader();
                const body = getBody();

                if (!body) {
                    showError('Le conteneur #editConsultationModalBody est introuvable.');
                    return;
                }

                body.innerHTML = text;
                if (loader) loader.classList.add('d-none');
                body.classList.remove('d-none');

                bindMedicalForm();
            } catch (error) {
                console.error('Erreur GET fetch:', error);
                showError('Erreur JS/fetch pendant le chargement.', error.message || '');
            }
        }

        document.addEventListener('click', function (e) {
            const btn = e.target.closest('.js-edit-consultation');
            if (!btn) return;

            const url = btn.dataset.url;
            console.log('clic .js-edit-consultation =>', url);

            if (!url) {
                showError('Aucune URL trouvée sur le bouton.');
                return;
            }

            loadMedicalForm(url);
        });

        modalEl.addEventListener('hidden.bs.modal', function () {
            currentUrl = null;
            setLoading();
        });
    })();
    </script>
    <script>
(() => {
    const prestationModalEl = document.getElementById('prestationModal');
    const prestationModalContent = document.getElementById('prestationModalContent');

    if (!prestationModalEl || !prestationModalContent) {
        console.error('Modale prestation introuvable');
        return;
    }

    function showLoading() {
        prestationModalContent.innerHTML = `
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        `;
    }

    function showError(message, details = '') {
        prestationModalContent.innerHTML = `
            <div class="modal-header">
                <h5 class="modal-title">Erreur</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-danger mb-0">
                    <div class="fw-semibold mb-1">${message || 'Impossible de charger le formulaire.'}</div>
                    ${details ? `<pre class="small mt-2 mb-0" style="white-space: pre-wrap;">${details}</pre>` : ''}
                </div>
            </div>
        `;
    }

    function bindPrestationForm() {
        const form = prestationModalContent.querySelector('#prestationForm') || prestationModalContent.querySelector('form');
        console.log('bindPrestationForm =>', !!form);

        if (!form) {
            showError('Le formulaire prestation est introuvable.', prestationModalContent.innerHTML);
            return;
        }

        if (form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            console.log('SUBMIT prestation intercepté');

            const submitBtn = form.querySelector('.js-submit-prestation, button[type="submit"]');
            const oldHtml = submitBtn ? submitBtn.innerHTML : '';

            if (submitBtn) {
                submitBtn.disabled = true;
                submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1"></span> Enregistrement...`;
            }

            try {
                const response = await fetch(form.action, {
                    method: (form.method || 'POST').toUpperCase(),
                    body: new FormData(form),
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const contentType = response.headers.get('content-type') || '';
                console.log('submit prestation status=', response.status, 'contentType=', contentType);
                console.log('submit prestation redirected=', response.redirected);
                console.log('submit prestation final url=', response.url);

                if (contentType.includes('application/json')) {
                    const data = await response.json();
                    console.log('JSON prestation reçu:', data);

                    if (response.ok && data.success) {
                        bootstrap.Modal.getInstance(prestationModalEl)?.hide();
                        window.location.reload();
                        return;
                    }

                    showError(data.message || 'Erreur lors de l’enregistrement.');
                    return;
                }

                const html = await response.text();
                prestationModalContent.innerHTML = html;
                bindPrestationForm();
            } catch (error) {
                console.error('Erreur soumission prestation:', error);
                showError('Erreur JS/fetch pendant la soumission.', error.message || '');
            } finally {
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = oldHtml;
                }
            }
        });
    }

    async function openPrestationModal(url) {
        console.log('openPrestationModal =>', url);
        showLoading();

        try {
            const response = await fetch(url, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            const html = await response.text();
            console.log('GET prestation status=', response.status);

            if (!response.ok) {
                showError(`Chargement impossible (HTTP ${response.status})`, html);
                return;
            }

            prestationModalContent.innerHTML = html;
            bindPrestationForm();
        } catch (error) {
            console.error('Erreur chargement prestation:', error);
            showError('Impossible de charger le formulaire.', error.message || '');
        }
    }

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.js-add-prestation, .js-edit-prestation');
        if (!btn) return;

        const url = btn.dataset.url;
        console.log('clic prestation =>', url);

        if (!url) {
            showError('Aucune URL trouvée pour la modale prestation.');
            return;
        }

        openPrestationModal(url);
    });

    prestationModalEl.addEventListener('hidden.bs.modal', function () {
        showLoading();
    });
})();
</script>
{% endblock %}