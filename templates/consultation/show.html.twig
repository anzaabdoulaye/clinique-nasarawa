{% extends 'base.html.twig' %}

{% block title %}Consultation #{{ consultation.id }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .consultation-hero {
            background: linear-gradient(135deg, #f8fbff 0%, #eef6ff 100%);
            border: 1px solid #dbe7f3;
            border-radius: 1rem;
            padding: 1.25rem;
        }

        .consultation-meta-card {
            background: #fff;
            border: 1px solid #e8eef5;
            border-radius: .9rem;
            padding: 1rem;
            height: 100%;
        }

        .consultation-meta-label {
            color: #6c757d;
            font-size: .78rem;
            font-weight: 600;
            letter-spacing: .04em;
            text-transform: uppercase;
            margin-bottom: .2rem;
        }

        .consultation-meta-value {
            color: #1f2937;
            font-size: .98rem;
            font-weight: 600;
            line-height: 1.4;
        }

        .consultation-meta-subtle {
            color: #6c757d;
            font-size: .9rem;
        }

        .consultation-action-panel {
            background: #fff;
            border: 1px solid #e8eef5;
            border-radius: .9rem;
            padding: 1rem;
        }

        .consultation-action-panel .btn {
            width: 100%;
            justify-content: center;
        }

        @media (max-width: 991.98px) {
            .consultation-action-panel .btn {
                width: auto;
            }
        }
    </style>
{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set rdv = consultation.rendezVous|default(null) %}
    {% set dossier = consultation.dossierMedical|default(null) %}
    {% set patient = dossier and dossier.patient is defined and dossier.patient ? dossier.patient : (rdv ? (rdv.patient|default(null)) : null) %}
    {% set st = consultation.statut is defined and consultation.statut ? (consultation.statut.name ?? consultation.statut.value ?? '') : '' %}
    {% set badgeClass =
        st in ['EN_COURS'] ? 'bg-primary' :
        st in ['BROUILLON'] ? 'bg-secondary' :
        st in ['CLOTURE', 'CLOTUREE'] ? 'bg-success' :
        st in ['ANNULE', 'ANNULEE'] ? 'bg-danger' :
        'bg-dark'
    %}
    {% set locked = st in ['CLOTURE', 'CLOTUREE', 'ANNULE', 'ANNULEE'] %}
    {% set nbResultatsLabo = 0 %}
    {% for p in consultation.prescriptionsPrestations %}
        {% if p.tarifPrestation
            and p.tarifPrestation.serviceExecution == 'laboratoire'
            and p.resultatLaboratoire %}
            {% set nbResultatsLabo = nbResultatsLabo + 1 %}
        {% endif %}
    {% endfor %}

    <div class="consultation-hero mb-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
            <div>
                <h3 class="mb-1">
                    Consultation <span class="text-muted">#{{ consultation.id }}</span>
                </h3>
                <div class="text-muted small">
                    {% if rdv %}
                        Consultation issue du rendez-vous #{{ rdv.id }}
                        {% if rdv.dateHeure is defined and rdv.dateHeure %}
                            — {{ rdv.dateHeure|date('d/m/Y H:i') }}
                        {% endif %}
                    {% elseif dossier %}
                        Consultation rattachée au dossier {{ dossier.numeroDossier|default('#' ~ dossier.id) }}
                    {% else %}
                        Consultation sans rendez-vous ni dossier lié
                    {% endif %}
                </div>
            </div>

            <div class="d-flex flex-wrap gap-2">
                <span class="badge {{ badgeClass }}">{{ st ?: 'N/A' }}</span>
                {% if nbResultatsLabo > 0 %}
                    <span class="badge bg-success-subtle text-success border">
                        <i class="ri-flask-line me-1"></i>
                        {{ nbResultatsLabo }} résultat{{ nbResultatsLabo > 1 ? 's' : '' }} labo disponible{{ nbResultatsLabo > 1 ? 's' : '' }}
                    </span>
                {% endif %}
            </div>
        </div>

        <div class="row g-3 align-items-stretch">
            <div class="col-12 col-lg-4">
                <div class="consultation-meta-card">
                    <div class="consultation-meta-label">Patient</div>
                    {% if patient %}
                        <div class="consultation-meta-value">
                            {{ patient.nomComplet|default(((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim))|default(patient.id) }}
                        </div>
                        <div class="consultation-meta-subtle mt-2">
                            {% if patient.code is defined and patient.code %}
                                Code patient : {{ patient.code }}<br>
                            {% endif %}
                            {% if patient.telephone is defined and patient.telephone %}
                                Téléphone : {{ patient.telephone }}
                            {% else %}
                                Téléphone non renseigné
                            {% endif %}
                        </div>
                    {% elseif dossier %}
                        <div class="consultation-meta-value text-warning">Aucun patient trouvé sur le dossier lié</div>
                    {% else %}
                        <div class="consultation-meta-value text-muted">Aucun patient lié</div>
                    {% endif %}
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="consultation-meta-card">
                    <div class="consultation-meta-label">Liaison</div>
                    {% if rdv %}
                        <div class="consultation-meta-value">Rendez-vous #{{ rdv.id }}</div>
                        <div class="consultation-meta-subtle mt-2">
                            {% if rdv.dateHeure is defined and rdv.dateHeure %}
                                Date : {{ rdv.dateHeure|date('d/m/Y H:i') }}<br>
                            {% endif %}
                            Consultation liée à un rendez-vous existant
                        </div>
                    {% elseif dossier %}
                        <div class="consultation-meta-value">Dossier {{ dossier.numeroDossier|default('#' ~ dossier.id) }}</div>
                        <div class="consultation-meta-subtle mt-2">
                            Consultation créée directement depuis le dossier médical
                        </div>
                    {% else %}
                        <div class="consultation-meta-value text-muted">Aucune liaison disponible</div>
                    {% endif %}
                </div>
            </div>

            <div class="col-12 col-lg-4">
                <div class="consultation-meta-card">
                    <div class="consultation-meta-label">Médecin</div>
                    {% if consultation.medecin is defined and consultation.medecin %}
                        <div class="consultation-meta-value">
                            {{ consultation.medecin.nomComplet|default(((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim))|default(consultation.medecin.id) }}
                        </div>
                        <div class="consultation-meta-subtle mt-2">
                            Consultation prise en charge par le médecin assigné
                        </div>
                    {% else %}
                        <div class="consultation-meta-value text-muted">Médecin non renseigné</div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="consultation-action-panel mt-3">
            <div class="consultation-meta-label mb-3">Actions</div>
            <div class="row g-2">
                <div class="col-12 col-md-6 col-xl-3 d-grid">
                    <a href="{{ path('app_consultation_index') }}" class="btn btn-outline-secondary">
                        <i class="fa fa-arrow-left me-1"></i> Retour
                    </a>
                </div>
                {% if dossier %}
                    <div class="col-12 col-md-6 col-xl-3 d-grid">
                        <a href="{{ path('app_dossier_medical_show', {'id': dossier.id}) }}" class="btn btn-outline-info">
                            <i class="fa fa-folder-open me-1"></i> Ouvrir le dossier
                        </a>
                    </div>
                {% endif %}
                <div class="col-12 col-md-6 col-xl-3 d-grid">
                    <button type="button"
                            class="btn btn-primary js-edit-consultation {{ locked ? 'disabled' : '' }}"
                            title="Saisie médicale"
                            data-bs-toggle="modal"
                            data-bs-target="#editConsultationModal"
                            data-url="{{ path('app_consultation_medical_edit', {'id': consultation.id}) }}"
                            {{ locked ? 'disabled' : '' }}>
                        <i class="fa fa-pen me-1"></i> Saisie médicale
                    </button>
                </div>
                <div class="col-12 col-md-6 col-xl-3 d-grid">
                    <a href="{{ path('app_consultation_print_fiche_pdf', {id: consultation.id}) }}"
                       target="_blank"
                       class="btn btn-success">
                        <i class="fa fa-print me-1"></i> Fiche consultation
                    </a>
                </div>
                <div class="col-12 col-xl-3 d-grid">
                    {{ include('consultation/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>

    {# ===================== PRESTATIONS PRESCRITES ===================== #}
    <div class="card shadow-sm border-0 rounded-4 mt-4">
        <div class="card-header bg-light d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">Prestations prescrites</h5>
                <small class="text-muted">Actes, examens et consommables demandés par le médecin</small>
            </div>

            <button type="button"
                    class="btn btn-primary btn-sm js-add-prestation"
                    data-bs-toggle="modal"
                    data-bs-target="#prestationModal"
                    data-url="{{ path('app_prescription_prestation_new', {id: consultation.id}) }}">
                <i class="ri-add-line me-1"></i> Ajouter
            </button>
        </div>

        <div class="card-body">
            {% if consultation.prescriptionsPrestations is defined and consultation.prescriptionsPrestations|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Prestation</th>
                                <th>Catégorie</th>
                                <th>Quantité</th>
                                <th>Instructions</th>
                                <th>Résultat</th>
                                <th>Action</th>
                               
                            </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptionsPrestations %}
                            {% set isLabo = p.tarifPrestation and p.tarifPrestation.serviceExecution == 'laboratoire' %}
                            <tr>
                                <td class="fw-semibold">
                                    {{ p.tarifPrestation.libelle|default('-') }}
                                </td>
                                <td>
                                    <span class="badge bg-secondary-subtle text-secondary">
                                        {{ p.tarifPrestation.categorie.value|default('-')|replace({'_':' '})|title }}
                                    </span>
                                </td>
                                <td>{{ p.quantite|default(1) }}</td>
                                <td>{{ p.instructions ?: '-' }}</td>
                                <td>
                                    {% if isLabo and p.resultatLaboratoire %}
                                        <div class="d-flex flex-wrap gap-2">
                                            <span class="badge bg-success-subtle text-success">Disponible</span>
                                            <a href="{{ path('app_laboratoire_resultat_pdf', {id: p.id}) }}"
                                               target="_blank"
                                               class="btn btn-sm btn-outline-dark">
                                                Voir / Imprimer
                                            </a>
                                        </div>
                                    {% elseif isLabo %}
                                        <span class="badge bg-light text-dark">En attente</span>
                                    {% else %}
                                        -
                                    {% endif %}
                                </td>
                               <td >
    {% set locked = p.estVerrouilleePourEdition %}

    {% if locked %}
        <span class="badge bg-warning-subtle text-warning border">
            {% if p.resultatLaboratoire %}
                Résultat disponible
            {% else %}
                Prise en charge
            {% endif %}
        </span>
    {% else %}
        <button type="button"
                class="btn btn-sm btn-outline-primary js-edit-prestation"
                title="Modifier"
                data-bs-toggle="modal"
                data-bs-target="#prestationModal"
                data-url="{{ path('app_prescription_prestation_edit', {id: p.id}) }}">
            <i class="ri-pencil-line"></i>
        </button>

        <form method="post"
              action="{{ path('app_prescription_prestation_delete', {id: p.id}) }}"
              class="d-inline"
              onsubmit="return confirm('Supprimer cette prestation ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_prestation_' ~ p.id) }}">
            <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer">
                <i class="ri-delete-bin-line"></i>
            </button>
        </form>
    {% endif %}
</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-4">
                    <i class="ri-file-list-3-line fs-1 text-muted"></i>
                    <p class="text-muted mb-0 mt-2">Aucune prestation prescrite pour cette consultation.</p>
                </div>
            {% endif %}
        </div>
    </div>

    {# ===================== RESULTATS LABORATOIRE ===================== #}
    <div class="card shadow-sm border-0 rounded-4 mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Résultats laboratoire</h5>
        </div>

        <div class="card-body">
            {% set hasLabResults = false %}
            {% for p in consultation.prescriptionsPrestations %}
                {% if p.tarifPrestation and p.tarifPrestation.serviceExecution == 'laboratoire' and p.resultatLaboratoire %}
                    {% set hasLabResults = true %}
                {% endif %}
            {% endfor %}

            {% if hasLabResults %}
                <div class="accordion" id="labResultsAccordion">
                    {% for p in consultation.prescriptionsPrestations %}
                        {% if p.tarifPrestation and p.tarifPrestation.serviceExecution == 'laboratoire' and p.resultatLaboratoire %}
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="heading-{{ p.id }}">
                                    <button class="accordion-button collapsed" type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#collapse-{{ p.id }}"
                                            aria-expanded="false"
                                            aria-controls="collapse-{{ p.id }}">
                                        <span class="fw-semibold">{{ p.tarifPrestation.libelle }}</span>
                                        <span class="ms-3 badge bg-success">Résultat disponible</span>
                                    </button>
                                </h2>

                                <div id="collapse-{{ p.id }}"
                                     class="accordion-collapse collapse"
                                     aria-labelledby="heading-{{ p.id }}"
                                     data-bs-parent="#labResultsAccordion">
                                    <div class="accordion-body">
                                        {% if p.resultatLaboratoire.lignes|length > 0 %}
                                            <div class="table-responsive mb-3">
                                                <table class="table table-sm align-middle">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th>Demande</th>
                                                            <th>Résultat</th>
                                                            <th>Valeurs normales</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                    {% for ligne in p.resultatLaboratoire.lignes|sort((a, b) => a.ordre <=> b.ordre) %}
                                                        <tr>
                                                            <td>{{ ligne.demande|nl2br }}</td>
                                                            <td>{{ ligne.resultat ? ligne.resultat|nl2br : '-' }}</td>
                                                            <td>{{ ligne.valeurNormale ? ligne.valeurNormale|nl2br : '-' }}</td>
                                                        </tr>
                                                    {% endfor %}
                                                    </tbody>
                                                </table>
                                            </div>
                                        {% else %}
                                            <div class="mb-3">
                                                {{ p.resultatLaboratoire.resultat ? p.resultatLaboratoire.resultat|nl2br : 'Aucun détail disponible.' }}
                                            </div>
                                        {% endif %}

                                        <div class="mb-3">
                                            <strong>Conclusion :</strong>
                                            {{ p.resultatLaboratoire.conclusion ? p.resultatLaboratoire.conclusion|nl2br : '-' }}
                                        </div>

                                        <div class="text-muted small mb-3">
                                            Validé le :
                                            {{ p.resultatLaboratoire.dateValidation ? p.resultatLaboratoire.dateValidation|date('Y-m-d H:i') : '-' }}
                                            — Par :
                                            {{ p.resultatLaboratoire.validePar ?: '-' }}
                                        </div>

                                        <a href="{{ path('app_laboratoire_resultat_pdf', {id: p.id}) }}"
                                           target="_blank"
                                           class="btn btn-sm btn-outline-dark">
                                            <i class="ri-printer-line me-1"></i> Imprimer le résultat
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-muted mb-0">Aucun résultat laboratoire disponible pour cette consultation.</p>
            {% endif %}
        </div>
    </div>

    {# ===================== KPI CARDS ===================== #}
    <div class="row g-3 mb-4 mt-1">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Poids</div>
                    <div class="fs-4 fw-semibold" id="consultation-poids">
    {{ consultation.poids ?? '-' }} <span class="text-muted fs-6">kg</span>
</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Taille</div>
                    <div class="fs-4 fw-semibold" id="consultation-taille">
    {{ consultation.taille ?? '-' }} <span class="text-muted fs-6">cm</span>
</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Température</div>
                    <div class="fs-4 fw-semibold" id="consultation-temperature">
    {{ consultation.temperature ?? '-' }} <span class="text-muted fs-6">°C</span>
</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small">Fréquence cardiaque</div>
                   <div class="fs-4 fw-semibold" id="consultation-frequence">
    {{ consultation.frequenceCardiaque ?? '-' }} <span class="text-muted fs-6">bpm</span>
</div>
                </div>
            </div>
        </div>
    </div>

    {# ===================== TABS ===================== #}
    <ul class="nav nav-tabs" id="consultTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active"
                    id="tab-clinique"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-clinique"
                    type="button"
                    role="tab">
                Clinique
            </button>
        </li>

        <li class="nav-item" role="presentation">
            <button class="nav-link"
                    id="tab-prescriptions"
                    data-bs-toggle="tab"
                    data-bs-target="#pane-prescriptions"
                    type="button"
                    role="tab">
                Prescriptions
            </button>
        </li>
    </ul>

    <div class="tab-content border border-top-0 rounded-bottom p-3" id="consultTabsContent">
        <div class="tab-pane fade show active" id="pane-clinique" role="tabpanel">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Motif & Histoire</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Motifs</div>
                                <div id="consultation-motifs">{{ consultation.motifs ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">Histoire / Anamnèse</div>
                                <div id="consultation-histoire">{{ consultation.histoire ?? '-' }}</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12 col-lg-6">
                    <div class="card h-100">
                        <div class="card-header fw-semibold">Examen & Diagnostic</div>
                        <div class="card-body">
                            <div class="mb-3">
                                <div class="text-muted small">Examen clinique</div>
                                <div id="consultation-examen">{{ consultation.examenClinique ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Tension artérielle</div>
                                <div id="consultation-tension">{{ consultation.tensionArterielle ?? '-' }}</div>
                            </div>

                            <div class="mb-3">
                                <div class="text-muted small">Diagnostic</div>
                                <div id="consultation-diagnostic">{{ consultation.diagnostic ?? '-' }}</div>
                            </div>

                            <div>
                                <div class="text-muted small">CIM10</div>
                                <div id="consultation-cim10">
                                    {% if consultation.cim10 is defined and consultation.cim10 %}
                                        {{ consultation.cim10 }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="card">
                        <div class="card-header fw-semibold">Conduite à tenir</div>
                       <div class="card-body" id="consultation-conduite">
                            {{ consultation.conduiteATenir ?? '-' }}
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="text-muted small">
                        Créée : {{ consultation.createdAt ? consultation.createdAt|date('Y-m-d H:i') : '-' }}
                        — Modifiée : <span id="consultation-modified-at">{{ consultation.modifiedAt ? consultation.modifiedAt|date('Y-m-d H:i') : '-' }}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="pane-prescriptions" role="tabpanel">
            <div class="card mb-3 border-0 shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Prescription</h6>
                    <span class="badge bg-light text-dark border">
                        {{ consultation.prescriptions is defined ? consultation.prescriptions|length : 0 }} document(s)
                    </span>
                </div>
                <div class="card-body" id="prescriptionSummary">
                    {% include 'prescription/_summary.html.twig' with { consultation: consultation } %}
                </div>
            </div>

            {% if consultation.prescriptions is defined and consultation.prescriptions|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Commentaire</th>
                            <th class="text-end">Lignes</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for p in consultation.prescriptions %}
                            <tr>
                                <td>{{ p.id }}</td>
                                <td>{{ p.datePrescription is defined and p.datePrescription ? p.datePrescription|date('Y-m-d H:i') : '-' }}</td>
                                <td>{{ p.commentaire ?? '-' }}</td>
                                <td class="text-end">
                                    {{ p.lignes is defined ? p.lignes|length : 0 }}
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-muted">Aucune prescription pour le moment.</div>
            {% endif %}
        </div>
    </div>
</div>

{# ========================= MODAL EDIT CONSULTATION ========================= #}
<div class="modal fade" id="editConsultationModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-white">
                <h5 class="modal-title fw-semibold">
                    <i class="fa fa-pen me-2 text-primary"></i> Modifier la consultation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>

            <div class="modal-body">
                <div id="editConsultationLoader" class="py-5 text-center">
                    <div class="spinner-border" role="status" aria-hidden="true"></div>
                    <div class="mt-2 text-muted small">Chargement du formulaire…</div>
                </div>

                <div id="editConsultationModalBody" class="d-none"></div>
            </div>

            <div class="modal-footer bg-white">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
                    Fermer
                </button>
            </div>
        </div>
