{% extends 'base.html.twig' %}

{% block title %}Consultations{% endblock %}

{% block body %}
<div class="row">
  <div class="col-12">

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-0 py-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
          <div>
            <h5 class="mb-0 fw-semibold">
              <i class="fa fa-stethoscope me-2 text-primary"></i> Consultations
            </h5>
            <div class="text-muted small">Historique des consultations enregistrées</div>
          </div>

          <div class="d-flex flex-wrap align-items-center gap-2">
            <form method="get" action="{{ path('app_consultation_index') }}" class="app-search d-flex">
             <div class="position-relative">
              <input
                type="text"
                id="consultationSearchInput"
                name="search"
                class="form-control"
                placeholder="Code patient, N° dossier ou téléphone"
                autocomplete="off"
                value="{{ search|default('') }}"
                style="min-width: 360px;"
              >
             <span class="mdi mdi-magnify search-widget-icon">
             </span>
              </div>
               <button type="submit" class="btn btn-primary ms-2"> 
               <i class="fa fa-search me-1"> </i> Rechercher 
               </button>

            {% if search is defined and search %}
              <a href="{{ path('app_consultation_index') }}" class="btn btn-light border">
                Réinitialiser
              </a>
            {% endif %}
            </form>

            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addConsultationModal">
              <i class="fa fa-plus me-1"></i> Nouvelle consultation
            </button>
          </div>
        </div>
      </div>

      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 datatable">
            <thead class="table-light">
              <tr class="text-nowrap">
                <th class="text-uppercase small text-muted">Date / Heure</th>
                <th class="text-uppercase small text-muted">Dossier / Patient</th>
                <th class="text-uppercase small text-muted">Médecin</th>
                <th class="text-uppercase small text-muted text-end" style="width: 170px;">Actions</th>
              </tr>
            </thead>

            <tbody>
            {% for c in consultations %}
              <tr>
                <td class="text-nowrap">
                  {% if c.createdAt %}
                    <div class="fw-semibold">{{ c.createdAt|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ c.createdAt|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td>
                  {% if c.dossierMedical %}
                    <div class="fw-semibold">
                      <i class="fa fa-folder-open me-1 text-muted"></i>
                      {{ c.dossierMedical.numeroDossier ?? ('#' ~ c.dossierMedical.id) }}
                    </div>

                    {% set patient = c.dossierMedical.patient ?? null %}
                    {% if patient %}
                      <div class="small text-muted">
                          Patient : {% if patient.nom or patient.prenom %}
                        
                        {{ patient.nom ?? '' }} {{ patient.prenom ?? '' }}
                        
                    

                      </div>
                         <div class="small text-muted">
                          Contact : {{ patient.telephone ?? '—' }}
                      </div>
                        
                      {% endif %}

                      
                    {% endif %}
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if c.medecin %}
                    <span class="badge bg-primary-subtle text-primary border">
                      <i class="fa fa-user-md me-1"></i> {{ c.medecin.nomComplet }}
                    </span>
                  {% else %}
                    <span class="badge bg-light text-muted border">Non renseigné</span>
                  {% endif %}
                </td>

                <td class="text-end">
                  <div class="btn-group btn-group-sm" role="group" aria-label="Actions consultation">
                    <a class="btn btn-outline-secondary"
                       title="Voir"
                       href="{{ path('app_consultation_show', {'id': c.id}) }}">
                      <i class="fa fa-eye me-1"></i> Voir
                    </a>

                    <button type="button"
                            class="btn btn-outline-primary js-edit-consultation-admin"
                            title="Modifier les informations de base"
                            data-bs-toggle="modal"
                            data-bs-target="#editConsultationModal"
                            data-url="{{ path('app_consultation_admin_edit', {'id': c.id}) }}">
                      <i class="ri-pencil-fill"></i>
                    </button>
                  </div>
                </td>
              </tr>
            {% else %}
              <tr>
                <td colspan="4">
                  <div class="py-5 text-center">
                    <div class="mb-2">
                      <i class="fa fa-info-circle text-muted" style="font-size: 28px;"></i>
                    </div>
                    <div class="fw-semibold">Aucune consultation trouvée</div>
                    <div class="text-muted small">
                      Vérifie le code patient, le numéro de dossier ou le téléphone.
                    </div>
                  </div>
                </td>
              </tr>
            {% endfor %}
            </tbody>

          </table>
        </div>
      </div>
    </div>

  </div>
</div>

{# =========================
   MODAL AJOUT CONSULTATION
========================= #}
<div class="modal fade" id="addConsultationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-plus me-2 text-primary"></i> Nouvelle consultation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        {% if form is defined %}
          {{ form_start(form) }}
            <div class="row g-3">
              {% if form.children.medecin is defined %}
                <div class="col-md-6">{{ form_row(form.medecin) }}</div>
              {% endif %}

              {% if form.children.dossierMedical is defined %}
                <div class="col-md-6">{{ form_row(form.dossierMedical) }}</div>
              {% endif %}

              {% if form.children.rendezVous is defined %}
                <div class="col-md-6">{{ form_row(form.rendezVous) }}</div>
              {% endif %}

              {% if form.children.dateConsultation is defined %}
                <div class="col-md-6">{{ form_row(form.dateConsultation) }}</div>
              {% endif %}
            </div>

            <div class="d-flex justify-content-end mt-4">
              <button type="submit" class="btn btn-primary">
                <i class="fa fa-save me-1"></i> Enregistrer
              </button>
            </div>
          {{ form_end(form) }}
        {% else %}
          <div class="alert alert-warning mb-0">
            Le formulaire <code>form</code> n'est pas transmis à ce template.
          </div>
        {% endif %}
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fermer</button>
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL EDIT CONSULTATION BASE (AJAX)
========================= #}
<div class="modal fade" id="editConsultationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Modifier les informations de base
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div id="editConsultationLoader" class="py-5 text-center">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>

        <div id="editConsultationModalBody" class="d-none"></div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">
          Fermer
        </button>
      </div>

    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (() => {
      const editModalEl = document.getElementById('editConsultationModal');
      const loader = document.getElementById('editConsultationLoader');
      const body = document.getElementById('editConsultationModalBody');
      let currentUrl = null;

      function showError(message) {
        loader.classList.add('d-none');
        body.classList.remove('d-none');
        body.innerHTML = `
          <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
            <i class="fa fa-exclamation-triangle mt-1"></i>
            <div>
              <div class="fw-semibold">Erreur</div>
              <div class="small">${message || 'Impossible de charger le formulaire.'}</div>
            </div>
          </div>
        `;
      }

      function setLoading() {
        loader.classList.remove('d-none');
        body.classList.add('d-none');
        body.innerHTML = '';
      }

      function focusFirstField() {
        const first = body.querySelector('input, select, textarea');
        if (first) first.focus();
      }

      function bindForm() {
        const form = body.querySelector('form');
        if (!form || form.dataset.bound === '1') return;

        form.dataset.bound = '1';

        form.addEventListener('submit', async (ev) => {
          ev.preventDefault();

          const submitBtn = form.querySelector('[type="submit"]');
          const oldSubmitHtml = submitBtn ? submitBtn.innerHTML : null;

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Enregistrement...`;
          }

          try {
            const submitRes = await fetch(form.getAttribute('action') || currentUrl, {
              method: (form.getAttribute('method') || 'POST').toUpperCase(),
              body: new FormData(form),
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const contentType = submitRes.headers.get('content-type') || '';

            if (contentType.includes('application/json')) {
              const json = await submitRes.json();

              if (json.success) {
                bootstrap.Modal.getInstance(editModalEl)?.hide();
                window.location.reload();
                return;
              }

              showError(json.message || "Une erreur est survenue.");
              return;
            }

            const submitHtml = await submitRes.text();
            body.innerHTML = submitHtml;
            focusFirstField();
            bindForm();
          } catch (err) {
            showError("Une erreur est survenue lors de l'enregistrement.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = oldSubmitHtml;
            }
          }
        });
      }

      async function loadEditForm(url) {
        currentUrl = url;
        setLoading();

        try {
          const res = await fetch(url, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
          });

          if (!res.ok) throw new Error('HTTP ' + res.status);

          const html = await res.text();
          body.innerHTML = html;

          loader.classList.add('d-none');
          body.classList.remove('d-none');

          focusFirstField();
          bindForm();
        } catch (err) {
          showError("Impossible de charger le formulaire.");
        }
      }

      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-edit-consultation-admin');
        if (!btn) return;

        const url = btn.getAttribute('data-url');
        if (!url) return;

        loadEditForm(url);
      });

      editModalEl?.addEventListener('hidden.bs.modal', () => {
        currentUrl = null;
        setLoading();
      });
    })();

    (() => {
      const input = document.getElementById('consultationSearchInput');
      if (!input) return;

      let timer = null;

      input.addEventListener('input', function () {
        clearTimeout(timer);

        timer = setTimeout(() => {
          const value = input.value.trim();
          const url = new URL(window.location.href);

          if (value !== '') {
            url.searchParams.set('search', value);
          } else {
            url.searchParams.delete('search');
          }

          window.location.href = url.toString();
        }, 300);
      });
    })();
  </script>
{% endblock %}