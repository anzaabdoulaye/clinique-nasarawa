<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>
        Fiche de consultation #
        {{ consultation ? consultation.id : (facture is defined and facture and facture.consultation ? facture.consultation.id : '-') }}
    </title>

    <style>
        @page {
            size: A4 portrait;
            margin: 5mm;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 9.5px;
            color: #1f2937;
        }

        .document {
            width: 100%;
        }

        .top-bar {
            height: 4px;
            background: #0f4c81;
            margin-bottom: 6px;
        }

        .header-table,
        .meta-table,
        .data-table,
        .signature-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .meta-table td,
        .signature-table td {
            vertical-align: top;
        }

        .clinic-logo {
            width: 24mm;
            height: 24mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #ffffff;
            border-radius: 50%;
        }

        .clinic h1 {
            margin: 0 0 3px 0;
            font-size: 13px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
        }

        .clinic .sub {
            font-size: 8px;
            line-height: 1.3;
            color: #6b7280;
        }

        .qr-box {
            width: 28mm;
            text-align: center;
            border: 1px solid #d1d5db;
            padding: 3px;
            background: #f8fafc;
        }

        .qr-box img {
            width: 20mm;
            height: 20mm;
            border: 1px solid #e5e7eb;
            background: #ffffff;
            padding: 2px;
        }

        .qr-label {
            margin-top: 2px;
            font-size: 7px;
            line-height: 1.2;
            color: #6b7280;
        }

        .title {
            margin: 5px 0;
            text-align: center;
            font-size: 12px;
            font-weight: bold;
            color: #111827;
            text-transform: uppercase;
        }

        .meta-box,
        .box,
        .table-wrap {
            border: 1px solid #d1d5db;
        }

        .meta-box {
            padding: 5px;
            margin-bottom: 6px;
        }

        .meta-table td {
            width: 50%;
            padding: 2px;
            line-height: 1.3;
        }

        .section {
            margin-top: 5px;
        }

        .section-title {
            padding: 4px 6px;
            font-size: 9px;
            font-weight: bold;
            color: #0f4c81;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-bottom: none;
            text-transform: uppercase;
        }

        .box {
            padding: 5px 6px;
            line-height: 1.3;
        }

        .table-wrap {
            border-top: none;
        }

        .data-table th,
        .data-table td {
            border: 1px solid #e5e7eb;
            padding: 3px;
            font-size: 8.5px;
            text-align: left;
            vertical-align: top;
        }

        .data-table th {
            color: #ffffff;
            background: #0f4c81;
            font-weight: bold;
        }

        .signature-table {
            width: 100%;
            margin-top: 100px;
            border-collapse: collapse;
        }

        .signature-block {
            text-align: center;
            vertical-align: bottom;
            height: 4px; /* espace réservé pour signer / cacheter */
            padding: 0 8px;
        }

        .line {
            border-top: 1px solid #000;
            padding-top: 4px;
            font-size: 8px;
            color: #6b7280;
        }

        .footer-note {
            margin-top: 6px;
            padding-top: 4px;
            text-align: center;
            font-size: 9px;
            font-weight: bold;
            color: #0f4c81;
            border-top: 1px dashed #d1d5db;
        }
    </style>
</head>
<body>
    {% set consultation = consultation ?? (facture is defined and facture ? facture.consultation : null) %}
    {% set patient = null %}
    {% if consultation %}
        {% if consultation.rendezVous and consultation.rendezVous.patient %}
            {% set patient = consultation.rendezVous.patient %}
        {% elseif consultation.dossierMedical and consultation.dossierMedical.patient %}
            {% set patient = consultation.dossierMedical.patient %}
        {% endif %}
    {% endif %}

    <div class="document">
        <div class="top-bar"></div>

        <table class="header-table">
            <tr>
                <td style="width:20%;">
                    {% if logo_path is defined and logo_path %}
                        <img src="{{ logo_path }}" alt="Logo Clinique Nassarawa" class="clinic-logo">
                    {% endif %}
                </td>

                <td style="width:52%;">
                    <div class="clinic">
                        <h1>Clinique Neurologique Nassarawa</h1>
                        <div class="sub">
                            NIF : 120402/R<br>
                            RCCM : NE-NIM-01-2024-B12-00145<br>
                            Adresse : Yantala Haut, Avenue du Daoura YN 187, Niamey<br>
                            Tél : 20 75 51 02 / 82 09 61 12<br>
                            BP : 2120 Niamey<br>
                            Email : nassrawaclinique@gmail.com
                        </div>
                    </div>
                </td>

                <td style="width:28%; text-align:right;">
                    <div class="qr-box">
                        {% if qr_data is defined and qr_data %}
                            <img src="{{ qr_data }}" alt="QR Code">
                        {% endif %}

                        {% if code_qr is defined and code_qr %}
                            <div class="qr-label">Code : {{ code_qr }}</div>
                        {% endif %}

                        <div class="qr-label">Scanner pour vérification</div>
                    </div>
                </td>
            </tr>
        </table>

        <div class="title">Fiche de consultation</div>

        <div class="meta-box">
            <table class="meta-table">
                <tr>
                    <td>
                        <strong>N° fiche :</strong>
                        {{ consultation ? consultation.id : '-' }}
                    </td>
                    <td>
                        <strong>Date :</strong>
                        {{ consultation and consultation.createdAt ? consultation.createdAt|date('d/m/Y H:i') : '-' }}
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Service :</strong>
                        {{ consultation.serviceMedical.nom ?? '-' }}
                    </td>
                    <td>
                        <strong>Médecin :</strong>
                        {% if consultation and consultation.medecin %}
                            {{ ((consultation.medecin.nom ?? '') ~ ' ' ~ (consultation.medecin.prenom ?? ''))|trim }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                </tr>
            </table>
        </div>

        <div class="section">
            <div class="section-title">Patient</div>
            <div class="box">
                <strong>Nom et prénom :</strong>
                {{ patient ? ((patient.nom ?? '') ~ ' ' ~ (patient.prenom ?? ''))|trim : '-' }}
                <br>

                <strong>Code patient :</strong>
                {{ patient and patient.code ? patient.code : '-' }}
                <br>

                <strong>N° dossier médical :</strong>
                {{ consultation and consultation.dossierMedical and consultation.dossierMedical.numeroDossier ? consultation.dossierMedical.numeroDossier : '-' }}
                <br>

                <strong>Téléphone :</strong>
                {{ patient and patient.telephone ? patient.telephone : '-' }}
            </div>
        </div>

        <div class="section">
            <div class="section-title">Prestations prescrites</div>
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width:8%;">#</th>
                            <th style="width:52%;">Prestation</th>
                            <th style="width:12%;">Qté</th>
                            <th style="width:28%;">Instructions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for p in consultation and consultation.prescriptionsPrestations ? consultation.prescriptionsPrestations : [] %}
                            <tr>
                                <td>{{ loop.index }}</td>
                                <td>{{ p.tarifPrestation.libelle|default('-') }}</td>
                                <td>{{ p.quantite|default(1) }}</td>
                                <td>{{ p.instructions ?: '-' }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4">Aucune prestation prescrite</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Observations médicales</div>
            <div class="box">
                <strong>Motif :</strong>
                {{ consultation and consultation.motifs ? consultation.motifs : '-' }}
                <br>

                <strong>Diagnostic :</strong>
                {{ consultation and consultation.diagnostic ? consultation.diagnostic : '-' }}
                <br>

                <strong>Conduite à tenir :</strong>
                {{ consultation and consultation.conduiteATenir ? consultation.conduiteATenir : '-' }}
            </div>
        </div>

        <table class="signature-table">
            <tr>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Signature du médecin</div>
                </td>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Cachet du service</div>
                </td>
            </tr>
        </table>

        <div class="footer-note">
            À PRÉSENTER À LA CAISSE POUR RÈGLEMENT
        </div>
    </div>
</body>
</html>