<div class="modal fade" id="newBonMatiereModal" tabindex="-1" aria-labelledby="newBonMatiereModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow">
            <form method="post" action="{{ path('app_comptabilite_matiere_new') }}">
                <div class="modal-header border-0 pb-0 px-4 pt-4">
                    <div>
                        <h4 class="modal-title fw-bold text-dark" id="newBonMatiereModalLabel">
                            <i class="ri-add-circle-line me-2 text-primary"></i>
                            Nouveau bon matière
                        </h4>
                        <p class="text-muted mb-0 mt-1">
                            Enregistrez un bon d’entrée, de sortie définitive ou de sortie provisoire.
                        </p>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                </div>

                <div class="modal-body px-4 py-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Type de bon</label>
                            <select name="type" class="form-select" required>
                                <option value="">Sélectionner...</option>
                                {% for type in types %}
                                    <option value="{{ type.value }}">{{ type.label() }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Motif</label>
                            <select name="motif" class="form-select" required>
                                <option value="">Sélectionner...</option>
                                {% for motif in motifs %}
                                    <option value="{{ motif.value }}">{{ motif.label() }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label fw-semibold">Référence externe</label>
                            <input type="text" name="reference" class="form-control" placeholder="Ex: FACT-2026-001">
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Observation générale</label>
                            <textarea name="observation" rows="2" class="form-control" placeholder="Observation sur le bon..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-semibold text-dark mb-0">Lignes du bon</h5>
                        <button type="button" class="btn btn-outline-primary btn-sm rounded-pill px-3" id="add-bon-line">
                            <i class="ri-add-line me-1"></i>
                            Ajouter une ligne
                        </button>
                    </div>

                    <div id="bon-lines">
                        <div class="border rounded-4 p-3 mb-3 bon-line bg-light-subtle">
                            <div class="row g-3 align-items-end">
                                <div class="col-md-3">
                                    <label class="form-label fw-semibold">Médicament</label>
                                    <select name="lignes[0][medicament]" class="form-select" required>
                                        <option value="">Sélectionner...</option>
                                        {% for medicament in medicaments %}
                                            <option value="{{ medicament.id }}">{{ medicament.nom }}</option>
                                        {% endfor %}
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Lot</label>
                                    <select name="lignes[0][lot]" class="form-select">
                                        <option value="">Sélectionner...</option>
                                        {% for lot in lots %}
                                            <option value="{{ lot.id }}">
                                                {{ lot.medicament.nom }} — {{ lot.numeroLot ?: ('Lot #' ~ lot.id) }} ({{ lot.quantite }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                    <small class="text-muted d-block mt-1">Sélectionnez un lot existant ou renseignez-en un nouveau ci-dessous.</small>
                                </div>

                                <div class="col-md-2 bon-entree-only">
                                    <label class="form-label fw-semibold">Nouveau numéro lot</label>
                                    <input type="text" name="lignes[0][numeroLot]" class="form-control" placeholder="Ex: LOT-2026-001">
                                </div>

                                <div class="col-md-2 bon-entree-only">
                                    <label class="form-label fw-semibold">Péremption</label>
                                    <input type="date" name="lignes[0][datePeremption]" class="form-control">
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Quantité</label>
                                    <input type="number" min="1" name="lignes[0][quantite]" class="form-control" required>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Prix unitaire</label>
                                    <input type="number" min="0" step="0.01" name="lignes[0][prixUnitaire]" class="form-control">
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label fw-semibold">Observation</label>
                                    <input type="text" name="lignes[0][observation]" class="form-control" placeholder="Note">
                                </div>

                                <div class="col-md-1 d-grid">
                                    <button type="button" class="btn btn-outline-danger remove-line" title="Supprimer">
                                        <i class="ri-delete-bin-line"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">
                        Annuler
                    </button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="ri-save-line me-1"></i>
                        Enregistrer le bon
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('bon-lines');
    const addBtn = document.getElementById('add-bon-line');
    const typeSelect = document.querySelector('select[name="type"]');

    if (!container || !addBtn) return;

    let index = container.querySelectorAll('.bon-line').length;

    const syncEntreeFields = function () {
        const isEntree = typeSelect && typeSelect.value === 'ENTREE';

        container.querySelectorAll('.bon-entree-only').forEach(function (fieldWrapper) {
            fieldWrapper.classList.toggle('d-none', !isEntree);

            fieldWrapper.querySelectorAll('input').forEach(function (field) {
                if (!isEntree) {
                    field.value = '';
                }
            });
        });
    };

    addBtn.addEventListener('click', function () {
        const firstLine = container.querySelector('.bon-line');
        if (!firstLine) return;

        const clone = firstLine.cloneNode(true);

        clone.querySelectorAll('input, select, textarea').forEach(function (field) {
            const name = field.getAttribute('name');
            if (name) {
                field.setAttribute('name', name.replace(/\[\d+\]/, '[' + index + ']'));
            }

            if (field.tagName === 'SELECT') {
                field.selectedIndex = 0;
            } else {
                field.value = '';
            }
        });

        container.appendChild(clone);
        index++;
        syncEntreeFields();
    });

    if (typeSelect) {
        typeSelect.addEventListener('change', syncEntreeFields);
    }

    document.addEventListener('click', function (e) {
        const btn = e.target.closest('.remove-line');
        if (!btn) return;

        const lines = container.querySelectorAll('.bon-line');
        if (lines.length === 1) {
            const line = btn.closest('.bon-line');
            line.querySelectorAll('input').forEach(input => input.value = '');
            line.querySelectorAll('select').forEach(select => select.selectedIndex = 0);
            return;
        }

        btn.closest('.bon-line')?.remove();
    });

    syncEntreeFields();
});
</script>