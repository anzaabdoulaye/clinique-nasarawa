{% extends 'base.html.twig' %}

{% block title %}Bon matière {{ bon.numero }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ===== En-tête ===== #}
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 flex-wrap mb-2">
                <h2 class="fw-bold mb-0 text-dark">
                    <i class="ri-file-text-line me-2 text-primary"></i>
                    Bon matière {{ bon.numero }}
                </h2>

                {% if bon.type.value == 'ENTREE' %}
                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                        <i class="ri-arrow-left-down-line me-1"></i>
                        Entrée
                    </span>
                {% elseif bon.type.value == 'SORTIE_DEFINITIVE' %}
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                        <i class="ri-arrow-right-up-line me-1"></i>
                        Sortie définitive
                    </span>
                {% elseif bon.type.value == 'SORTIE_PROVISOIRE' %}
                    <span class="badge bg-warning-subtle text-dark border border-warning-subtle px-3 py-2">
                        <i class="ri-external-link-line me-1"></i>
                        Sortie provisoire
                    </span>
                {% endif %}

                {% if bon.statut.value == 'BROUILLON' %}
                    <span class="badge bg-secondary-subtle text-secondary border px-3 py-2">
                        Brouillon
                    </span>
                {% elseif bon.statut.value == 'VALIDE' %}
                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                        Validé
                    </span>
                {% elseif bon.statut.value == 'ANNULE' %}
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                        Annulé
                    </span>
                {% endif %}
            </div>

            <p class="text-muted mb-0">
                Détail complet du bon de comptabilité matière, avec ses lignes, son contexte et son statut.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-outline-secondary shadow-sm" href="{{ path('app_comptabilite_matiere_index') }}">
                <i class="ri-arrow-left-line me-1"></i>
                Retour
            </a>

            <a class="btn btn-primary shadow-sm"
               href="{{ path('app_comptabilite_matiere_print', {'id': bon.id}) }}"
               target="_blank">
                <i class="ri-printer-line me-1"></i>
                Imprimer
            </a>

            {% if bon.statut.value == 'BROUILLON' %}
                <form method="post"
                      action="{{ path('app_comptabilite_matiere_valider', {'id': bon.id}) }}"
                      onsubmit="return confirm('Confirmer la validation de ce bon ?');"
                      class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('valider_bon_' ~ bon.id) }}">
                    <button type="submit" class="btn btn-success shadow-sm">
                        <i class="ri-check-line me-1"></i>
                        Valider
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    <div class="row g-4">

        {# ===== Colonne gauche : fiche bon ===== #}
        <div class="col-12 col-xl-8">

            {# ===== Informations générales ===== #}
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                    <h5 class="mb-0 fw-semibold text-dark">Informations générales</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Numéro du bon</small>
                            <div class="fw-semibold text-dark">{{ bon.numero }}</div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Date</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.dateBon ? bon.dateBon|date('d/m/Y à H:i') : 'Non définie' }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Type</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.type.label is defined ? bon.type.label : bon.type.value }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Motif</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.motif.label is defined ? bon.motif.label : bon.motif.value }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Référence externe</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.referenceExterne ?: '—' }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Impact stock</small>
                            <div>
                                {% if bon.impactStock %}
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                        Oui
                                    </span>
                                {% else %}
                                    <span class="badge bg-warning-subtle text-dark border border-warning-subtle px-3 py-2">
                                        Non
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Créé par</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.creePar ? bon.creePar.getNomComplet() : 'Non renseigné' }}
                            </div>
                        </div>

                        <div class="col-md-6">
                            <small class="text-muted d-block mb-1">Ordonnateur</small>
                            <div class="fw-semibold text-dark">
                                {{ bon.ordonnateur ? bon.ordonnateur.getNomComplet() : 'Non renseigné' }}
                            </div>
                        </div>

                        {% if bon.vente %}
                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Vente liée</small>
                                <div class="fw-semibold text-dark">
                                    Vente #{{ bon.vente.id }}
                                </div>
                            </div>

                            <div class="col-md-6">
                                <small class="text-muted d-block mb-1">Montant vente</small>
                                <div class="fw-bold text-success">
                                    {{ bon.vente.total|number_format(0, ',', ' ') }} FCFA
                                </div>
                            </div>
                        {% endif %}

                        <div class="col-12">
                            <small class="text-muted d-block mb-1">Observation</small>
                            <div class="text-dark">
                                {{ bon.observation ?: 'Aucune observation.' }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            {# ===== Lignes du bon ===== #}
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                        <div>
                            <h5 class="mb-1 fw-semibold text-dark">Lignes du bon</h5>
                            <small class="text-muted">
                                {{ bon.totalLignes }} ligne(s) • Quantité totale : {{ bon.quantiteTotale }}
                            </small>
                        </div>
                    </div>
                </div>

                <div class="card-body px-4 pb-4">
                    {% if bon.lignes|length > 0 %}
                        <div class="table-responsive">
                            <table class="table align-middle table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="fw-semibold text-dark">Médicament</th>
                                        <th class="fw-semibold text-dark">Lot</th>
                                        <th class="fw-semibold text-dark">Péremption</th>
                                        <th class="fw-semibold text-dark">Quantité</th>
                                        <th class="fw-semibold text-dark">Prix unitaire</th>
                                        <th class="fw-semibold text-dark">Montant</th>
                                        <th class="fw-semibold text-dark">Observation</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set montantTotal = 0 %}
                                    {% for ligne in bon.lignes %}
                                        {% set montantTotal = montantTotal + ligne.montantLigne %}
                                        <tr>
                                            <td>
                                                <div class="fw-semibold text-dark">
                                                    {{ ligne.medicament ? ligne.medicament.nom : '—' }}
                                                </div>
                                                {% if ligne.medicament and ligne.medicament.sku %}
                                                    <small class="text-muted">SKU : {{ ligne.medicament.sku }}</small>
                                                {% endif %}
                                            </td>

                                            <td>
                                                {% if ligne.lot %}
                                                    <span class="badge bg-light text-dark border px-3 py-2">
                                                        {{ ligne.lot.numeroLot ?: ('Lot #' ~ ligne.lot.id) }}
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>

                                            <td>
                                                {% if ligne.lot and ligne.lot.datePeremption %}
                                                    <span class="text-dark">{{ ligne.lot.datePeremption|date('d/m/Y') }}</span>
                                                {% else %}
                                                    <span class="text-muted">Non renseignée</span>
                                                {% endif %}
                                            </td>

                                            <td>
                                                <span class="fw-bold text-primary">{{ ligne.quantite }}</span>
                                            </td>

                                            <td>
                                                {% if ligne.prixUnitaire is not null %}
                                                    <span class="fw-semibold text-dark">
                                                        {{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCFA
                                                    </span>
                                                {% else %}
                                                    <span class="text-muted">—</span>
                                                {% endif %}
                                            </td>

                                            <td>
                                                <span class="fw-bold text-success">
                                                    {{ ligne.montantLigne|number_format(0, ',', ' ') }} FCFA
                                                </span>
                                            </td>

                                            <td>
                                                <span class="text-dark">{{ ligne.observation ?: '—' }}</span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                                <tfoot class="table-light">
                                    <tr>
                                        <th colspan="3" class="text-end fw-semibold text-dark">Totaux</th>
                                        <th class="fw-bold text-primary">{{ bon.quantiteTotale }}</th>
                                        <th></th>
                                        <th class="fw-bold text-success">{{ montantTotal|number_format(0, ',', ' ') }} FCFA</th>
                                        <th></th>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <div class="rounded-circle bg-light d-inline-flex justify-content-center align-items-center"
                                     style="width: 70px; height: 70px;">
                                    <i class="ri-file-list-3-line fs-2 text-muted"></i>
                                </div>
                            </div>
                            <h5 class="fw-bold text-dark mb-2">Aucune ligne enregistrée</h5>
                            <p class="text-muted mb-0">
                                Ce bon ne contient actuellement aucune ligne.
                            </p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# ===== Colonne droite : résumé ===== #}
        <div class="col-12 col-xl-4">

            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                    <h5 class="mb-0 fw-semibold text-dark">Résumé</h5>
                </div>
                <div class="card-body px-4 pb-4">
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted">Nombre de lignes</span>
                        <span class="fw-semibold text-dark">{{ bon.totalLignes }}</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted">Quantité totale</span>
                        <span class="fw-bold text-primary">{{ bon.quantiteTotale }}</span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted">Statut</span>
                        <span class="fw-semibold text-dark">
                            {{ bon.statut.label is defined ? bon.statut.label : bon.statut.value }}
                        </span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <span class="text-muted">Type</span>
                        <span class="fw-semibold text-dark">
                            {{ bon.type.label is defined ? bon.type.label : bon.type.value }}
                        </span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center pt-2">
                        <span class="text-muted">Motif</span>
                        <span class="fw-semibold text-dark">
                            {{ bon.motif.label is defined ? bon.motif.label : bon.motif.value }}
                        </span>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                    <h5 class="mb-0 fw-semibold text-dark">Actions rapides</h5>
                </div>
                <div class="card-body px-4 pb-4 d-grid gap-2">
                    <a class="btn btn-outline-secondary" href="{{ path('app_comptabilite_matiere_index') }}">
                        <i class="ri-list-check-2 me-1"></i>
                        Retour à la liste
                    </a>

                    <a class="btn btn-primary" href="{{ path('app_comptabilite_matiere_print', {'id': bon.id}) }}" target="_blank">
                        <i class="ri-printer-line me-1"></i>
                        Imprimer le bon
                    </a>

                    {% if bon.statut.value == 'BROUILLON' %}
                        <form method="post"
                              action="{{ path('app_comptabilite_matiere_valider', {'id': bon.id}) }}"
                              onsubmit="return confirm('Confirmer la validation de ce bon ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('valider_bon_' ~ bon.id) }}">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="ri-check-line me-1"></i>
                                Valider ce bon
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}