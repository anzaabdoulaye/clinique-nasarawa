{% extends 'base.html.twig' %}

{% block title %}Nouveau bon matière{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="ri-add-circle-line me-2 text-primary"></i>
                Nouveau bon matière
            </h2>
            <p class="text-muted mb-0">Création manuelle d’un bon de comptabilité matière.</p>
        </div>
        <a href="{{ path('app_comptabilite_matiere_index') }}" class="btn btn-outline-secondary">
            <i class="ri-arrow-left-line me-1"></i>
            Retour
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            {% include 'comptabilite_matiere/_new_modal.html.twig' with {
                types: types,
                motifs: motifs,
                medicaments: medicaments,
                lots: lots
            } %}
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const modalEl = document.getElementById('newBonMatiereModal');
    if (modalEl && window.bootstrap) {
        const modal = new bootstrap.Modal(modalEl);
        modal.show();
    }
});
</script>
{% endblock %}