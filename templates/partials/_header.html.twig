<script>
document.addEventListener('DOMContentLoaded', function () {
    const input = document.getElementById('app-quick-search');
    const clearButton = document.getElementById('app-quick-search-clear');
    const menu = document.getElementById('app-quick-search-menu');
    const emptyState = document.getElementById('app-quick-search-empty');

    if (!input || !clearButton || !menu || !emptyState) {
        return;
    }

    const items = Array.from(menu.querySelectorAll('.search-shortcut-item'));

    function getVisibleItems() {
        return items.filter((item) => item.style.display !== 'none');
    }

    function closeMenu() {
        menu.classList.remove('show');
    }

    function openMenu() {
        menu.classList.add('show');
    }

    function filterItems() {
        const query = input.value.trim().toLowerCase();
        let visibleCount = 0;

        items.forEach((item) => {
            const text = (item.dataset.searchText || item.textContent || '').toLowerCase();
            const isVisible = query === '' || text.includes(query);

            item.style.display = isVisible ? '' : 'none';
            if (isVisible) {
                visibleCount += 1;
            }
        });

        clearButton.classList.toggle('d-none', query === '');
        emptyState.classList.toggle('d-none', visibleCount > 0);

        if (document.activeElement === input || query !== '') {
            openMenu();
        }
    }

    input.addEventListener('focus', function () {
        filterItems();
        openMenu();
    });

    input.addEventListener('input', filterItems);

    input.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
            input.value = '';
            filterItems();
            closeMenu();
            input.blur();
            return;
        }

        if (event.key === 'Enter') {
            const [firstVisibleItem] = getVisibleItems();
            if (firstVisibleItem) {
                event.preventDefault();
                firstVisibleItem.click();
            }
        }
    });

    clearButton.addEventListener('click', function () {
        input.value = '';
        filterItems();
        input.focus();
    });

    document.addEventListener('click', function (event) {
        if (event.target === input || menu.contains(event.target)) {
            return;
        }

        closeMenu();
    });
});
</script>