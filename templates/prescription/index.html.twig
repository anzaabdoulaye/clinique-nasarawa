{% extends 'base.html.twig' %}

{% block title %}Prescription index{% endblock %}

{% block body %}
    <h1>Prescription index</h1>

    <table class="table table-hover align-middle mb-0 datatable">
        <thead>
            <tr>
                <th>Id</th>
                <th>TypePrescription</th>
                <th>Instructions</th>
                <th>CreatedAt</th>
                <th>ModifiedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for prescription in prescriptions %}
            <tr>
                <td>{{ prescription.id }}</td>
                <td>{{ prescription.typePrescription }}</td>
                <td>{{ prescription.instructions }}</td>
                <td>{{ prescription.createdAt ? prescription.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ prescription.modifiedAt ? prescription.modifiedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_prescription_show', {'id': prescription.id}) }}">show</a>
                    <a href="{{ path('app_prescription_edit', {'id': prescription.id}) }}">edit</a>
                </td>
            </tr>

        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_prescription_new') }}">Create new</a>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
    <script>
document.addEventListener('click', async (e) => {
  // Ouvrir modal Prescription
  const openBtn = e.target.closest('.js-open-prescription');
  if (openBtn) {
    const url = openBtn.dataset.url;
    const modalEl = document.querySelector('#prescriptionModal');
    const content = modalEl.querySelector('.modal-content');

    content.innerHTML = `<div class="modal-body p-4 text-center text-muted">Chargement...</div>`;
    const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
    content.innerHTML = await res.text();
    return;
  }
});

document.addEventListener('submit', async (e) => {
  const form = e.target.closest('#prescriptionForm');
  if (!form) return;

  e.preventDefault();

  const modalEl = document.querySelector('#prescriptionModal');
  const content = modalEl.querySelector('.modal-content');
  const btn = content.querySelector('.js-submit-prescription');
  if (btn) btn.disabled = true;

  const res = await fetch(form.action, {
    method: 'POST',
    body: new FormData(form),
    headers: { 'X-Requested-With': 'XMLHttpRequest' }
  });

  // Succès => refresh résumé + fermer modal
  if (res.ok) {
    const data = await res.json();
    if (data.success) {
      const summary = document.querySelector('#prescriptionSummary');
      if (summary && data.summaryHtml) summary.innerHTML = data.summaryHtml;

      const bsModal = bootstrap.Modal.getInstance(modalEl);
      bsModal?.hide();
      return;
    }
  }

  // Erreurs => re-render du form dans modal
  const data = await res.json().catch(() => null);
  if (data?.html) {
    content.innerHTML = data.html;
  } else {
    alert("Erreur lors de l'enregistrement de la prescription.");
  }
});
</script>

{% endblock %}
