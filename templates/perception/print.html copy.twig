<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Fiche de consultation #{{ consultation.id }}</title>
    <style>
        @page {
            size: A5 portrait;
            margin: 6mm;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, Helvetica, sans-serif;
            font-size: 10px;
            color: #1f2937;
        }

        .document {
            width: 100%;
        }

        .top-bar {
            height: 5px;
            background: #0f4c81;
            margin-bottom: 8px;
        }

        .header-table,
        .meta-table,
        .signature-table,
        .main-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .meta-table td,
        .signature-table td {
            vertical-align: top;
        }

        .clinic h1 {
            margin: 0 0 4px 0;
            font-size: 15px;
            color: #0f4c81;
            font-weight: bold;
            text-transform: uppercase;
            line-height: 1.15;
        }

        .clinic .sub {
            color: #6b7280;
            line-height: 1.35;
            font-size: 9px;
        }

        .qr-box {
            width: 34mm;
            text-align: center;
            border: 1px solid #d1d5db;
            padding: 4px;
            background: #f8fafc;
        }

        .qr-box img {
            width: 24mm;
            height: 24mm;
            border: 1px solid #e5e7eb;
            background: #fff;
            padding: 2px;
        }

        .qr-label {
            font-size: 8px;
            margin-top: 3px;
            color: #6b7280;
            line-height: 1.2;
        }

        .title {
            text-align: center;
            font-size: 14px;
            font-weight: bold;
            margin: 8px 0 10px 0;
            text-transform: uppercase;
            color: #111827;
            letter-spacing: 0.3px;
        }

        .meta-box {
            border: 1px solid #d1d5db;
            padding: 7px;
            margin-bottom: 8px;
        }

        .meta-table td {
            width: 50%;
            padding: 2px 4px 2px 0;
            line-height: 1.3;
        }

        .section {
            margin-top: 8px;
        }

        .section-title {
            font-weight: bold;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            color: #0f4c81;
            padding: 6px 8px;
            margin-bottom: 0;
            text-transform: uppercase;
            font-size: 10px;
        }

        .box {
            border: 1px solid #d1d5db;
            border-top: none;
            padding: 8px;
            line-height: 1.35;
        }

        .box strong {
            color: #111827;
        }

        .table-wrap {
            border: 1px solid #d1d5db;
            border-top: none;
        }

        table.data-table {
            width: 100%;
            border-collapse: collapse;
        }

        table.data-table th,
        table.data-table td {
            border: 1px solid #e5e7eb;
            padding: 5px 4px;
            vertical-align: top;
            font-size: 9px;
        }

        table.data-table th {
            background: #0f4c81;
            color: #fff;
            text-align: left;
            font-weight: bold;
        }

        .signature-block {
            text-align: center;
            padding-top: 14px;
        }

        .line {
            margin-top: 24px;
            border-top: 1px solid #000;
            padding-top: 4px;
            font-size: 9px;
            color: #6b7280;
        }

        .footer-note {
            margin-top: 12px;
            text-align: center;
            font-weight: bold;
            font-size: 10px;
            color: #0f4c81;
            border-top: 1px dashed #d1d5db;
            padding-top: 8px;
        }
    </style>
</head>
<body>

{% set patient = consultation.rendezVous.patient ?? null %}

<div class="document">
    <div class="top-bar"></div>

    <table class="header-table">
        <tr>
            <td style="width:72%;">
                <div class="clinic">
                    <h1>Clinique Nassarawa</h1>
                    <div class="sub">
                        Niamey - Niger<br>
                        Tél : +227 XX XX XX XX
                    </div>
                </div>
            </td>
            <td style="width:28%; text-align:right;">
                <div class="qr-box">
                    {% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}
                    {% if _qr %}
                        <img src="{{ _qr }}" alt="QR Code fiche consultation">
                    {% endif %}
                    <div class="qr-label">QR Consultation</div>
                    {% if code_qr is defined and code_qr %}
                        <div class="qr-label">Code : {{ code_qr }}</div>
                    {% endif %}
                    <div class="qr-label">Scanner pour vérification</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="title">Fiche de consultation</div>

    <div class="meta-box">
        <table class="meta-table">
            <tr>
                <td><strong>N° fiche :</strong> {{ consultation.id }}</td>
                <td><strong>N° consultation :</strong> {{ consultation.id }}</td>
            </tr>
            <tr>
                <td><strong>Date :</strong> {{ consultation.createdAt ? consultation.createdAt|date('d/m/Y H:i') : '-' }}</td>
                <td><strong>Service médical :</strong> {{ consultation.serviceMedical.nom ?? '-' }}</td>
            </tr>
        </table>
    </div>

    <div class="section">
        <div class="section-title">Patient</div>
        <div class="box">
            <strong>Nom et prénom :</strong>
            {{ patient ? ((patient.nom ?? '') ~ ' ' ~ (patient.prenom ?? ''))|trim : '-' }}<br>

            <strong>Code patient :</strong>
            {{ patient and patient.code ? patient.code : '-' }}<br>

            <strong>N° dossier médical :</strong>
            {{ consultation.dossierMedical and consultation.dossierMedical.numeroDossier ? consultation.dossierMedical.numeroDossier : '-' }}<br>

            <strong>Téléphone :</strong>
            {{ patient and patient.telephone ? patient.telephone : '-' }}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Médecin</div>
        <div class="box">
            {{ consultation.medecin
                ? ((consultation.medecin.nom ?? '') ~ ' ' ~ (consultation.medecin.prenom ?? ''))|trim
                : '-' }}
        </div>
    </div>

    <div class="section">
        <div class="section-title">Prestations prescrites</div>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th style="width:6%;">#</th>
                        <th style="width:42%;">Prestation</th>
                        <th style="width:20%;">Catégorie</th>
                        <th style="width:12%;">Qté</th>
                        <th style="width:20%;">Instructions</th>
                    </tr>
                </thead>
                <tbody>
                {% for p in consultation.prescriptionsPrestations %}
                    <tr>
                        <td>{{ loop.index }}</td>
                        <td>{{ p.tarifPrestation.libelle|default('-') }}</td>
                        <td>{{ p.tarifPrestation.categorie.value|default('-')|replace({'_':' '})|title }}</td>
                        <td>{{ p.quantite|default(1) }}</td>
                        <td>{{ p.instructions ?: '-' }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">Aucune prestation prescrite</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="section">
        <div class="section-title">Observations médicales</div>
        <div class="box">
            <strong>Motif :</strong> {{ consultation.motifs ?: '-' }}<br><br>
            <strong>Diagnostic :</strong> {{ consultation.diagnostic ?: '-' }}<br><br>
            <strong>Conduite à tenir :</strong> {{ consultation.conduiteATenir ?: '-' }}
        </div>
    </div>

    <table class="signature-table" style="margin-top:14px;">
        <tr>
            <td style="width:50%;" class="signature-block">
                <div class="line">Signature du médecin</div>
            </td>
            <td style="width:50%;" class="signature-block">
                <div class="line">Cachet du service</div>
            </td>
        </tr>
    </table>

    <div class="footer-note">
        À PRÉSENTER À LA CAISSE POUR RÈGLEMENT
    </div>
</div>

</body>
</html>