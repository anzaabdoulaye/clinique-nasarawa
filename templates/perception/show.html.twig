{% extends 'base.html.twig' %}

{% block title %}Facture #{{ facture.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set consultation = facture.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}
    {% set statut = facture.statut.value %}

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h3 class="mb-1">Facture #{{ facture.id }}</h3>
            <div class="text-muted small">
                Émise le {{ facture.dateEmission ? facture.dateEmission|date('Y-m-d H:i') : '-' }}
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_perception_index') }}" class="btn btn-outline-secondary">
                Retour
            </a>

            {% if facture.statut.value in ['paye', 'partiellement_paye'] %}
                <a href="{{ path('app_perception_facture_print', {id: facture.id}) }}"
                target="_blank"
                class="btn btn-outline-dark">
                    <i class="ri-printer-line me-1"></i> Voir
                </a>
                <a href="{{ path('app_perception_facture_pdf', {id: facture.id}) }}"
                target="_blank"
                class="btn btn-outline-dark">
                    <i class="ri-printer-line me-1"></i> Imprimer
                </a>
            {% endif %}

            {% if facture.resteAPayer > 0 and statut != 'annule' %}
                <button type="button"
                        class="btn btn-success js-open-encaissement"
                        data-bs-toggle="modal"
                        data-bs-target="#encaissementModal"
                        data-url="{{ path('app_perception_facture_encaisser', {id: facture.id}) }}">
                    Encaisser
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Patient</div>
                <div class="card-body">
                    <div><strong>Nom :</strong>
                        {% if patient %}
                            {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                    <div><strong>Consultation :</strong> #{{ consultation.id }}</div>
                    <div><strong>Médecin :</strong>
                        {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Synthèse financière</div>
                <div class="card-body">
                    <div><strong>Total :</strong> {{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Payé :</strong> {{ facture.montantPaye|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Reste :</strong> {{ facture.resteAPayer|number_format(0, ',', ' ') }} FCFA</div>
                    <div class="mt-2">
                        <strong>Statut :</strong>
                        {% if statut == 'brouillon' %}
                            <span class="badge bg-secondary">Brouillon</span>
                        {% elseif statut == 'non_paye' %}
                            <span class="badge bg-warning text-dark">Non payé</span>
                        {% elseif statut == 'partiellement_paye' %}
                            <span class="badge bg-info text-dark">Partiellement payé</span>
                        {% elseif statut == 'paye' %}
                            <span class="badge bg-success">Payé</span>
                        {% elseif statut == 'annule' %}
                            <span class="badge bg-danger">Annulé</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Paiements</div>
                <div class="card-body">
                    {% if facture.paiements|length > 0 %}
                        {% for paiement in facture.paiements %}
                            <div class="border rounded p-2 mb-2">
                                <div><strong>Montant :</strong> {{ paiement.montant|number_format(0, ',', ' ') }} FCFA</div>
                                <div><strong>Mode :</strong> {{ paiement.mode.value|replace({'_':' '})|title }}</div>
                                <div><strong>Date :</strong> {{ paiement.payeLe|date('Y-m-d H:i') }}</div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-muted">Aucun paiement enregistré.</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white fw-semibold">Lignes de facture</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Libellé</th>
                            <th>Type</th>
                            <th>Quantité</th>
                            <th>Prix unitaire</th>
                            <th>Total</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for ligne in facture.lignes %}
                        <tr>
                            <td>{{ ligne.libelle }}</td>
                            <td>{{ ligne.type ? ligne.type|replace({'_':' '})|title : '-' }}</td>
                            <td>{{ ligne.quantite }}</td>
                            <td>{{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ ligne.total|number_format(0, ',', ' ') }} FCFA</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center text-muted">Aucune ligne de facture.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="4" class="text-end">Total général</th>
                            <th>{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="encaissementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" id="encaissementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('encaissementModal');
            const modalContent = document.getElementById('encaissementModalContent');

            function openEncaissementModal(url) {
                modalContent.innerHTML = `
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 mb-0">Chargement...</p>
                    </div>
                `;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    modalContent.innerHTML = html;
                    bindEncaissementForm();
                });
            }

            function bindEncaissementForm() {
                const form = modalContent.querySelector('form');
                if (!form) return;

                const montantInput = form.querySelector('#encaissement_montant');
                const alertBox = form.querySelector('.js-encaissement-alert');
                const maxAmount = Number.parseInt(form.dataset.resteAPayer || montantInput?.dataset.maxAmount || '0', 10);

                function showAlert(message) {
                    if (!alertBox) {
                        return;
                    }

                    if (!message) {
                        alertBox.textContent = '';
                        alertBox.classList.add('d-none');
                        return;
                    }

                    alertBox.textContent = message;
                    alertBox.classList.remove('d-none');
                }

                function validateMontant() {
                    if (!montantInput || Number.isNaN(maxAmount) || maxAmount <= 0) {
                        showAlert('');
                        return true;
                    }

                    const value = Number.parseInt(montantInput.value || '0', 10);

                    if (!Number.isNaN(value) && value > maxAmount) {
                        showAlert(`Le montant saisi ne doit pas depasser le total a payer de ${maxAmount} FCFA.`);
                        return false;
                    }

                    showAlert('');

                    return true;
                }

                montantInput?.addEventListener('input', validateMontant);

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    if (!validateMontant()) {
                        return;
                    }

                    const submitBtn = form.querySelector('.js-submit-encaissement');
                    if (submitBtn) submitBtn.disabled = true;

                    fetch(form.action, {
                        method: form.method || 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(async response => {
                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.includes('application/json')) {
                            const data = await response.json();

                            if (data.success) {
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                modal?.hide();

                                if (data.printUrl) {
                                    window.open(data.printUrl, '_blank');
                                }

                                window.location.reload();
                                return;
                            }
                        }

                        const html = await response.text();
                        modalContent.innerHTML = html;
                        bindEncaissementForm();
                    })
                    .finally(() => {
                        if (submitBtn) submitBtn.disabled = false;
                    });
                });
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.js-open-encaissement');
                if (!btn) return;

                const url = btn.dataset.url;
                if (!url) return;

                openEncaissementModal(url);
            });
        });
    </script>
{% endblock %}