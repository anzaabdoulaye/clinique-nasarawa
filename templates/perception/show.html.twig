{% extends 'base.html.twig' %}

{% block title %}Facture #{{ facture.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set consultation = facture.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}
    {% set statut = facture.statut.value %}

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h3 class="mb-1">Facture #{{ facture.id }}</h3>
            <div class="text-muted small">
                Émise le {{ facture.dateEmission ? facture.dateEmission|date('Y-m-d H:i') : '-' }}
            </div>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_perception_index') }}" class="btn btn-outline-secondary">Retour</a>
            {% if facture.statut.value in ['paye', 'partiellement_paye'] %}
                <a href="{{ path('app_perception_facture_print', {id: facture.id}) }}" target="_blank" class="btn btn-outline-dark">
                    <i class="ri-eye-line me-1"></i> Voir
                </a>
                <a href="{{ path('app_perception_facture_pdf', {id: facture.id}) }}" target="_blank" class="btn btn-outline-dark">
                    <i class="ri-printer-line me-1"></i> Imprimer
                </a>
            {% endif %}
            {% if facture.resteAPayer > 0 and statut != 'annule' %}
                <button type="button"
                        class="btn btn-success js-open-encaissement"
                        data-url="{{ path('app_perception_facture_encaisser', {id: facture.id}) }}">
                    <i class="ri-money-dollar-circle-line me-1"></i> Encaisser
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Patient</div>
                <div class="card-body">
                    <div><strong>Nom :</strong>
                        {% if patient %}{{ patient.nomComplet|default((patient.nom|default('')~' '~patient.prenom|default(''))|trim) }}{% else %}-{% endif %}
                    </div>
                    <div><strong>Consultation :</strong> #{{ consultation.id }}</div>
                    <div><strong>Médecin :</strong>
                        {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('')~' '~consultation.medecin.prenom|default(''))|trim) }}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Synthèse financière</div>
                <div class="card-body">
                    <div><strong>Total brut :</strong> {{ facture.montantTotalBrut|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Prise en charge :</strong> {{ facture.montantTotalPriseEnCharge|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Part patient :</strong> {{ facture.montantTotalPatient|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Payé :</strong> {{ facture.montantPayePatient|number_format(0, ',', ' ') }} FCFA</div>
                    <div><strong>Reste :</strong> {{ facture.restePatient|number_format(0, ',', ' ') }} FCFA</div>
                    <div class="mt-2"><strong>Statut :</strong>
                        {% if statut == 'brouillon' %}<span class="badge bg-secondary">Brouillon</span>
                        {% elseif statut == 'non_paye' %}<span class="badge bg-warning text-dark">Non payé</span>
                        {% elseif statut == 'partiellement_paye' %}<span class="badge bg-info text-dark">Partiellement payé</span>
                        {% elseif statut == 'paye' %}<span class="badge bg-success">Payé</span>
                        {% elseif statut == 'annule' %}<span class="badge bg-danger">Annulé</span>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Paiements</div>
                <div class="card-body">
                    {% if facture.paiements|length > 0 %}
                        {% for paiement in facture.paiements %}
                            <div class="border rounded p-2 mb-2">
                                <div><strong>Montant :</strong> {{ paiement.montant|number_format(0, ',', ' ') }} FCFA</div>
                                <div><strong>Mode :</strong> {{ paiement.mode.value|replace({'_':' '})|title }}</div>
                                <div><strong>Date :</strong> {{ paiement.payeLe|date('Y-m-d H:i') }}</div>
                                <div><strong>Perçu par :</strong>
                                    {% if paiement.effectuePar %}{{ paiement.effectuePar.nomComplet }}{% if paiement.effectuePar.username %} | {{ paiement.effectuePar.username }}{% endif %}{% else %}-{% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        <div class="text-muted">Aucun paiement enregistré.</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white fw-semibold">Lignes de facture</div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr><th>Libellé</th><th>Type</th><th>Quantité</th><th>Prix unitaire</th><th>Total</th></tr>
                    </thead>
                    <tbody>
                    {% for ligne in facture.lignes %}
                        <tr>
                            <td>{{ ligne.libelle }}</td>
                            <td>{{ ligne.type ? ligne.type|replace({'_':' '})|title : '-' }}</td>
                            <td>{{ ligne.quantite }}</td>
                            <td>{{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ ligne.total|number_format(0, ',', ' ') }} FCFA</td>
                        </tr>
                    {% else %}
                        <tr><td colspan="5" class="text-center text-muted">Aucune ligne de facture.</td></tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="4" class="text-end">Total général</th>
                            <th>{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

{# Modale encaissement #}
<div class="modal fade" id="encaissementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" id="encaissementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement…</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Gestion du bouton Encaisser
    document.querySelectorAll('.js-open-encaissement').forEach(button => {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            
            const url = this.dataset.url;
            const modalElement = document.getElementById('encaissementModal');
            const modalContent = document.getElementById('encaissementModalContent');
            
            // Afficher le spinner
            modalContent.innerHTML = `
                <div class="modal-body text-center py-5">
                    <div class="spinner-border text-primary"></div>
                    <p class="mt-3">Chargement...</p>
                </div>
            `;
            
            // Ouvrir la modal manuellement
            const bsModal = new bootstrap.Modal(modalElement);
            bsModal.show();
            
            // Charger le contenu
            fetch(url, { 
                headers: { 'X-Requested-With': 'XMLHttpRequest' } 
            })
            .then(response => response.text())
            .then(html => {
                modalContent.innerHTML = html;
                setTimeout(initForm, 100);
            })
            .catch(error => {
                console.error('Erreur:', error);
                modalContent.innerHTML = '<div class="modal-body text-danger">Erreur de chargement</div>';
            });
        });
    });
});

function initForm() {
    console.log('Formulaire chargé - Initialisation');
    
    const toggle = document.querySelector('.js-pec-toggle');
    const tauxSelect = document.querySelector('select[name*="tauxPriseEnChargeManuel"], select[id*="tauxPriseEnChargeManuel"]');
    const montantInput = document.querySelector('input[name*="montant"], input[id*="montant"]');
    
    console.log('Toggle:', toggle ? 'OK' : 'NON TROUVÉ');
    console.log('Taux:', tauxSelect ? 'OK' : 'NON TROUVÉ');
    console.log('Montant:', montantInput ? 'OK' : 'NON TROUVÉ');
    
    // Gestion Toggle PEC
    if (toggle) {
        toggle.addEventListener('change', function() {
            const container = document.getElementById('pec-fields-container');
            if (container) {
                if (this.checked) container.classList.add('show');
                else container.classList.remove('show');
            }
            calculer();
        });
    }
    
    // Gestion changement taux
    if (tauxSelect) {
        tauxSelect.addEventListener('change', calculer);
    }
    
    // Validation montant
    if (montantInput) {
        montantInput.addEventListener('input', function() {
            const max = parseInt(this.dataset.max || this.max || 999999999);
            const val = parseInt(this.value || 0);
            
            if (val > max) {
                this.classList.add('is-invalid');
                this.value = max;
            } else {
                this.classList.remove('is-invalid');
            }
        });
    }
    
    // Calcul initial
    calculer();
}

function calculer() {
    console.log('Calcul en cours...');
    
    const totalEl = document.getElementById('pec-total-brut');
    const dejaPayeEl = document.getElementById('pec-deja-paye');
    const toggle = document.querySelector('.js-pec-toggle');
    const tauxSelect = document.querySelector('select[name*="tauxPriseEnChargeManuel"], select[id*="tauxPriseEnChargeManuel"]');
    
    if (!totalEl) {
        console.error('Total brut non trouvé');
        return;
    }
    
    const totalBrut = parseInt(totalEl.dataset.value || 0);
    const dejaPaye = parseInt(dejaPayeEl?.dataset.value || 0);
    const pecActive = toggle ? toggle.checked : false;
    const taux = (pecActive && tauxSelect && tauxSelect.value) ? parseInt(tauxSelect.value) : 0;
    
    console.log('Données:', {totalBrut, dejaPaye, pecActive, taux});
    
    const montantPec = Math.round((totalBrut * taux) / 100);
    const partPatient = totalBrut - montantPec;
    const reste = Math.max(0, partPatient - dejaPaye);
    
    console.log('Résultat:', {montantPec, partPatient, reste});
    
    // Mise à jour affichage
    const fmt = n => new Intl.NumberFormat('fr-FR').format(n);
    
    const update = (id, val) => {
        const el = document.getElementById(id);
        if (el) {
            el.textContent = fmt(val);
            el.dataset.value = val;
        }
    };
    
    update('pec-montant-pec', montantPec);
    update('pec-part-patient', partPatient);
    update('pec-reste-patient', reste);
    
    // Mise à jour input max
    const montantInput = document.querySelector('input[name*="montant"], input[id*="montant"]');
    if (montantInput) {
        montantInput.max = reste;
        montantInput.dataset.max = reste;
        
        const helpText = montantInput.closest('.card-body, .form-group, div')?.querySelector('.form-text');
        if (helpText) {
            helpText.innerHTML = `Max: <strong class="text-danger">${fmt(reste)} FCFA</strong>`;
        }
        
        if (parseInt(montantInput.value || 0) > reste) {
            montantInput.value = reste;
        }
    }
}
</script>
{% endblock %}