<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture #{{ facture.id }}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 13px;
            color: #000;
            margin: 20px;
        }

        .header,
        .footer {
            width: 100%;
            margin-bottom: 20px;
        }

        .title {
            text-align: center;
            margin-bottom: 20px;
        }

        .title h1 {
            margin: 0;
            font-size: 22px;
        }

        .title p {
            margin: 5px 0 0;
            font-size: 13px;
        }

        .row {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 20px;
        }

        .col {
            width: 48%;
        }

        .box {
            border: 1px solid #000;
            padding: 10px;
            border-radius: 4px;
        }

        .box h3 {
            margin-top: 0;
            margin-bottom: 10px;
            font-size: 14px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        table th,
        table td {
            border: 1px solid #000;
            padding: 8px;
            text-align: left;
        }

        table th {
            background: #f2f2f2;
        }

        .text-end {
            text-align: right;
        }

        .totals {
            margin-top: 20px;
            width: 320px;
            margin-left: auto;
        }

        .totals table td,
        .totals table th {
            border: 1px solid #000;
        }

        .signature {
            margin-top: 50px;
            display: flex;
            justify-content: space-between;
        }

        .signature-box {
            width: 40%;
            text-align: center;
        }

        .print-actions {
            margin-bottom: 20px;
        }

        @media print {
            .print-actions {
                display: none;
            }

            body {
                margin: 0;
            }

            @page {
                size: A4;
                margin: 12mm;
            }
        }
    </style>
</head>
<body>
    {% set consultation = facture.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}

    <div class="print-actions">
        <button onclick="window.print()">Imprimer</button>
        <button onclick="window.close()">Fermer</button>
    </div>

    <div class="title">
        <h1>FACTURE</h1>
        <p>N° {{ facture.id }}</p>
        <p>Date : {{ facture.dateEmission ? facture.dateEmission|date('d/m/Y H:i') : '-' }}</p>
    </div>

    <div class="row">
        <div class="col">
            <div class="box">
                <h3>Informations patient</h3>
                <p>
                    <strong>Patient :</strong>
                    {% if patient %}
                        {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                    {% else %}
                        -
                    {% endif %}
                </p>
                <p><strong>Consultation :</strong> #{{ consultation.id }}</p>
                <p>
                    <strong>Médecin :</strong>
                    {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim) }}
                </p>
            </div>
        </div>

        <div class="col">
            <div class="box">
                <h3>Informations facture</h3>
                <p><strong>Statut :</strong> {{ facture.statut.value|replace({'_':' '})|title }}</p>
                <p><strong>Montant total :</strong> {{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</p>
                <p><strong>Montant payé :</strong> {{ facture.montantPaye|number_format(0, ',', ' ') }} FCFA</p>
                <p><strong>Reste à payer :</strong> {{ facture.resteAPayer|number_format(0, ',', ' ') }} FCFA</p>
            </div>
        </div>
    </div>

    <table>
        <thead>
            <tr>
                <th>Libellé</th>
                <th>Type</th>
                <th>Qté</th>
                <th>Prix unitaire</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
        {% for ligne in facture.lignes %}
            <tr>
                <td>{{ ligne.libelle }}</td>
                <td>{{ ligne.type ? ligne.type|replace({'_':' '})|title : '-' }}</td>
                <td>{{ ligne.quantite }}</td>
                <td>{{ ligne.prixUnitaire|number_format(0, ',', ' ') }} FCFA</td>
                <td>{{ ligne.total|number_format(0, ',', ' ') }} FCFA</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center">Aucune ligne de facture</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="totals">
        <table>
            <tr>
                <th>Total</th>
                <td class="text-end">{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</td>
            </tr>
            <tr>
                <th>Payé</th>
                <td class="text-end">{{ facture.montantPaye|number_format(0, ',', ' ') }} FCFA</td>
            </tr>
            <tr>
                <th>Reste</th>
                <td class="text-end">{{ facture.resteAPayer|number_format(0, ',', ' ') }} FCFA</td>
            </tr>
        </table>
    </div>

    <div class="signature">
        <div class="signature-box">
            <p><strong>Le patient</strong></p>
            <br><br>
            <p>_____________________</p>
        </div>

        <div class="signature-box">
            <p><strong>La perception</strong></p>
            <br><br>
            <p>_____________________</p>
        </div>
    </div>

    <script>
        window.addEventListener('load', function () {
            setTimeout(() => window.print(), 300);
        });
    </script>
</body>
</html>