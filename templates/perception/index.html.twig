{% extends 'base.html.twig' %}

{% block title %}Perception{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white border-0 py-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h3 class="mb-1 fw-semibold">
                        <i class="fa fa-microscope me-2 text-primary"></i> Perception / Encaissement
                    </h3>
                    <p class="text-muted mb-0 small">Gestion des factures et des paiements patients</p>
                </div>

                <div class="d-flex flex-wrap align-items-center gap-2">
                    <form method="get" action="{{ path('app_perception_index') }}" class="app-search d-flex">
                        <div class="position-relative">
                            <input
                                type="text"
                                id="labSearchInput"
                                name="search"
                                class="form-control"
                                placeholder="Code patient, N° dossier ou téléphone"
                                autocomplete="off"
                                value="{{ search|default('') }}"
                                style="min-width: 360px;"
                            >
                            <span class="mdi mdi-magnify search-widget-icon"></span>
                        </div>
                        <button type="submit" class="btn btn-primary ms-2"> 
                            <i class="fa fa-search me-1"></i> Rechercher 
                        </button>

                        {% if search is defined and search %}
                            <a href="{{ path('app_perception_index') }}" class="btn btn-light border ms-2">
                                Réinitialiser
                            </a>
                        {% endif %}
                    </form>
                </div>
            </div>
        </div>
    </div>


    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures non payées</div>
                    <div class="fs-3 fw-bold">{{ nbNonPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Paiements partiels</div>
                    <div class="fs-3 fw-bold">{{ nbPartielles }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures payées</div>
                    <div class="fs-3 fw-bold">{{ nbPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Encaissement du jour</div>
                    <div class="fs-4 fw-bold">{{ totalEncaisseJour|number_format(0, ',', ' ') }} FCFA</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Liste des factures</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr class="text-nowrap">
                <th class="text-uppercase small text-muted">#</th>
                <th class="text-uppercase small text-muted">Dossier / Patient</th>
                <th class="text-uppercase small text-muted">Montant Total</th>
                <th class="text-uppercase small text-muted">Reste à Payer</th>
                <th class="text-uppercase small text-muted">Date Facture</th>
                <th class="text-uppercase small text-muted">Statut</th>
                <th class="text-uppercase small text-muted text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for facture in factures %}
            {% set consultation = facture.consultation %}
            {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
            {% set patient = rdv ? rdv.patient|default(null) : null %}
            {% set dossier = patient and patient.dossierMedical ? patient.dossierMedical : null %}
            {% set statut = facture.statutPaiement.value %}

            <tr>
                <td class="text-nowrap">{{ facture.id }}</td>

                <td style="min-width: 260px;">
                    {% if patient %}
                        <div class="fw-semibold text-primary">
                            {{ patient.nom|upper }} {{ patient.prenom }}
                        </div>
                        <div class="text-muted small d-flex align-items-center gap-2">
                            <span><i class="fa fa-folder-open me-1"></i> {{ dossier ? dossier.numeroDossier : 'N/A' }}</span>
                            <span class="text-secondary">|</span>
                            <span><i class="fa fa-id-card me-1"></i> {{ patient.code }}</span>
                        </div>
                    {% else %}
                        <span class="text-muted small">Patient non défini</span>
                    {% endif %}
                </td>

                <td class="fw-bold">{{ facture.montantTotal|number_format(0, ',', ' ') }} F</td>
                
                <td class="text-danger fw-bold">
                    {{ facture.resteAPayer|number_format(0, ',', ' ') }} F
                </td>

                <td class="text-nowrap">
                    <div class="small">{{ facture.createdAt|date('d/m/Y') }}</div>
                    <div class="text-muted style-italic small">{{ facture.createdAt|date('H:i') }}</div>
                </td>

                <td>
                    {% if statut == 'payee' %}
                        <span class="badge rounded-pill bg-success-subtle text-success px-3">
                             <i class="fa fa-check-circle me-1"></i> Payée
                        </span>
                    {% elseif statut == 'partiel' %}
                        <span class="badge rounded-pill bg-warning-subtle text-warning px-3">
                            <i class="fa fa-hourglass-half me-1"></i> Partiel
                        </span>
                    {% else %}
                        <span class="badge rounded-pill bg-danger-subtle text-danger px-3">
                            <i class="fa fa-exclamation-circle me-1"></i> Non payée
                        </span>
                    {% endif %}
                </td>

                <td class="text-end">
                    <div class="btn-group btn-group-sm">
                        <button type="button" 
                                class="btn btn-primary js-open-encaissement" 
                                data-url="{{ path('app_perception_new_paiement', {id: facture.id}) }}"
                                title="Encaisser">
                            <i class="fa fa-cash-register"></i>
                        </button>
                        <a href="{{ path('app_facture_print', {id: facture.id}) }}" 
                           class="btn btn-outline-dark" target="_blank" title="Imprimer">
                            <i class="fa fa-print"></i>
                        </a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7" class="text-center py-5 text-muted">
                    <i class="fa fa-info-circle fa-2x mb-3"></i>
                    <p>Aucune facture trouvée pour cette recherche.</p>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
        </div>
    </div>
</div>

<div class="modal fade" id="encaissementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" id="encaissementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('encaissementModal');
            const modalContent = document.getElementById('encaissementModalContent');

            function openEncaissementModal(url) {
                modalContent.innerHTML = `
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 mb-0">Chargement...</p>
                    </div>
                `;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    modalContent.innerHTML = html;
                    bindEncaissementForm();
                })
                .catch(() => {
                    modalContent.innerHTML = `
                        <div class="modal-body">
                            <div class="alert alert-danger mb-0">
                                Impossible de charger le formulaire d'encaissement.
                            </div>
                        </div>
                    `;
                });
            }

            function bindEncaissementForm() {
                const form = modalContent.querySelector('form');
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    const submitBtn = form.querySelector('.js-submit-encaissement');
                    if (submitBtn) submitBtn.disabled = true;

                    fetch(form.action, {
                        method: form.method || 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(async response => {
                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.includes('application/json')) {
                            const data = await response.json();

                            if (data.success) {
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                modal?.hide();
                                window.location.reload();
                                return;
                            }
                        }

                        const html = await response.text();
                        modalContent.innerHTML = html;
                        bindEncaissementForm();
                    })
                    .catch(() => {
                        modalContent.innerHTML = `
                            <div class="modal-body">
                                <div class="alert alert-danger mb-0">
                                    Une erreur est survenue pendant l'encaissement.
                                </div>
                            </div>
                        `;
                    })
                    .finally(() => {
                        if (submitBtn) submitBtn.disabled = false;
                    });
                });
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.js-open-encaissement');
                if (!btn) return;

                const url = btn.dataset.url;
                if (!url) return;

                openEncaissementModal(url);
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('perceptionSearchInput');
            if (searchInput) {
                let timeout = null;
                searchInput.addEventListener('input', function() {
                    clearTimeout(timeout);
                    timeout = setTimeout(() => {
                        this.closest('form').submit();
                    }, 800); // Lance la recherche après 0.8s d'arrêt de frappe
                });
            }
        });
    </script>
{% endblock %}