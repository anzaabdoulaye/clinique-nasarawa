{% extends 'base.html.twig' %}

{% block title %}Perception{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Perception / Encaissement</h3>
            <p class="text-muted mb-0">Gestion des factures et des paiements patients</p>
        </div>
        {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_PERCEPTION') %}
        <div >
            <a href="{{ path('app_perception_rapport_agents') }}" class="btn btn-outline-dark">
                Rapport par agent
            </a>
             <a href="{{ path('app_perception_rapport_organisme') }}" class="btn btn-outline-success">
                Prises en charge par organisme
            </a>
        </div>
        {% endif %}
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures non payées</div>
                    <div class="fs-3 fw-bold">{{ nbNonPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Paiements partiels</div>
                    <div class="fs-3 fw-bold">{{ nbPartielles }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures payées</div>
                    <div class="fs-3 fw-bold">{{ nbPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Encaissement du jour</div>
                    <div class="fs-4 fw-bold">{{ totalEncaisseJour|number_format(0, ',', ' ') }} FCFA</div>
                </div>
            </div>
        </div>

    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                <h5 class="mb-0">Liste des factures</h5>
                <div class="d-flex align-items-center gap-2">
                    <label for="periodeFilter" class="form-label mb-0 small fw-semibold">Filtrer par période:</label>
                    <select id="periodeFilter" class="form-select form-select-sm" style="width: auto; min-width: 180px;">
                        <option value="recent" {% if periodeFilter == 'recent' %}selected{% endif %}>30 derniers jours</option>
                        <option value="month" {% if periodeFilter == 'month' %}selected{% endif %}>Ce mois</option>
                        <option value="quarter" {% if periodeFilter == 'quarter' %}selected{% endif %}>90 derniers jours</option>
                        <option value="year" {% if periodeFilter == 'year' %}selected{% endif %}>Cette année</option>
                        <option value="all" {% if periodeFilter == 'all' %}selected{% endif %}>Toutes les factures</option>
                    </select>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Consultation</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Payé</th>
                            <th>Reste</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for facture in factures %}
                        {% set consultation = facture.consultation|default(null) %}
                        {% set patient = null %}
                        {% if consultation %}
                            {% if consultation.rendezVous and consultation.rendezVous.patient %}
                                {% set patient = consultation.rendezVous.patient %}
                            {% elseif consultation.dossierMedical and consultation.dossierMedical.patient %}
                                {% set patient = consultation.dossierMedical.patient %}
                            {% endif %}
                        {% endif %}
                        {% set statut = facture.statut.value %}
                        <tr>
                            <td>{{ facture.id }}</td>
                            <td>
                                {% if patient %}
                                    {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>
                                {% if consultation %}
                                    #{{ consultation.id }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>{{ facture.dateEmission ? facture.dateEmission|date('Y-m-d H:i') : '-' }}</td>
                            <td>{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ facture.montantPaye|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ facture.resteAPayer|number_format(0, ',', ' ') }} FCFA</td>
                            <td>
                                {% if statut == 'brouillon' %}
                                    <span class="badge bg-secondary">Brouillon</span>
                                {% elseif statut == 'non_paye' %}
                                    <span class="badge bg-warning text-dark">Non payé</span>
                                {% elseif statut == 'partiellement_paye' %}
                                    <span class="badge bg-info text-dark">Partiellement payé</span>
                                {% elseif statut == 'paye' %}
                                    <span class="badge bg-success">Payé</span>
                                {% elseif statut == 'annule' %}
                                    <span class="badge bg-danger">Annulé</span>
                                {% else %}
                                    <span class="badge bg-dark">{{ statut }}</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('app_perception_facture_show', {id: facture.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Voir
                                </a>

                            {% if facture.resteAPayer > 0 and statut != 'annule' %}
                                <button type="button"
                                        class="btn btn-sm btn-success js-open-encaissement"
                                        data-bs-toggle="modal"
                                        data-bs-target="#encaissementModal"
                                        data-url="{{ path('app_perception_facture_encaisser', {id: facture.id}) }}">
                                    Encaisser
                                </button>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center text-muted">Aucune facture trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    </div>
</div>

<div class="modal fade" id="encaissementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" id="encaissementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
(function () {
    // Gestionnaire pour le filtre de période
    document.getElementById('periodeFilter').addEventListener('change', function() {
        const selectedValue = this.value;
        const url = new URL(window.location);
        if (selectedValue && selectedValue !== 'all') {
            url.searchParams.set('periode', selectedValue);
        } else {
            url.searchParams.set('periode', 'all');
        }
        window.location.href = url.toString();
    });
})();
</script>
{% endblock %}
