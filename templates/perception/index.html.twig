{% extends 'base.html.twig' %}

{% block title %}Perception{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">Perception / Encaissement</h3>
            <p class="text-muted mb-0">Gestion des factures et des paiements patients</p>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures non payées</div>
                    <div class="fs-3 fw-bold">{{ nbNonPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Paiements partiels</div>
                    <div class="fs-3 fw-bold">{{ nbPartielles }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Factures payées</div>
                    <div class="fs-3 fw-bold">{{ nbPayees }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body">
                    <div class="text-muted small">Encaissement du jour</div>
                    <div class="fs-4 fw-bold">{{ totalEncaisseJour|number_format(0, ',', ' ') }} FCFA</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white">
            <h5 class="mb-0">Liste des factures</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Patient</th>
                            <th>Consultation</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Payé</th>
                            <th>Reste</th>
                            <th>Statut</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for facture in factures %}
                        {% set patient = facture.consultation and facture.consultation.rendezVous ? facture.consultation.rendezVous.patient|default(null) : null %}
                        {% set statut = facture.statut.value %}
                        <tr>
                            <td>{{ facture.id }}</td>
                            <td>
                                {% if patient %}
                                    {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                                {% else %}
                                    -
                                {% endif %}
                            </td>
                            <td>#{{ facture.consultation.id }}</td>
                            <td>{{ facture.dateEmission ? facture.dateEmission|date('Y-m-d H:i') : '-' }}</td>
                            <td>{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ facture.montantPaye|number_format(0, ',', ' ') }} FCFA</td>
                            <td>{{ facture.resteAPayer|number_format(0, ',', ' ') }} FCFA</td>
                            <td>
                                {% if statut == 'brouillon' %}
                                    <span class="badge bg-secondary">Brouillon</span>
                                {% elseif statut == 'non_paye' %}
                                    <span class="badge bg-warning text-dark">Non payé</span>
                                {% elseif statut == 'partiellement_paye' %}
                                    <span class="badge bg-info text-dark">Partiellement payé</span>
                                {% elseif statut == 'paye' %}
                                    <span class="badge bg-success">Payé</span>
                                {% elseif statut == 'annule' %}
                                    <span class="badge bg-danger">Annulé</span>
                                {% else %}
                                    <span class="badge bg-dark">{{ statut }}</span>
                                {% endif %}
                            </td>
                            <td class="text-end">
                                <a href="{{ path('app_perception_facture_show', {id: facture.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Voir
                                </a>

                    {% if consultation %}
                        {% if consultation.rendezVous and consultation.rendezVous.patient %}
                            {% set patient = consultation.rendezVous.patient %}
                        {% elseif consultation.dossierMedical and consultation.dossierMedical.patient %}
                            {% set patient = consultation.dossierMedical.patient %}
                        {% endif %}
                    {% endif %}

                    {% set statut = facture.statut.value %}

                    <tr>
                        <td>{{ facture.id }}</td>
                        <td>
                            {% if patient %}
                                {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>
                            {% if consultation %}
                                #{{ consultation.id }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td>{{ facture.dateEmission ? facture.dateEmission|date('Y-m-d H:i') : '-' }}</td>
                        <td>{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</td>
                        <td>{{ (facture.montantPaye ?? 0)|number_format(0, ',', ' ') }} FCFA</td>
                        <td>{{ (facture.resteAPayer ?? 0)|number_format(0, ',', ' ') }} FCFA</td>
                        <td>
                            {% if statut == 'brouillon' %}
                                <span class="badge bg-secondary">Brouillon</span>
                            {% elseif statut == 'non_paye' %}
                                <span class="badge bg-warning text-dark">Non payé</span>
                            {% elseif statut == 'partiellement_paye' %}
                                <span class="badge bg-info text-dark">Partiellement payé</span>
                            {% elseif statut == 'paye' %}
                                <span class="badge bg-success">Payé</span>
                            {% elseif statut == 'annule' %}
                                <span class="badge bg-danger">Annulé</span>
                            {% else %}
                                <span class="badge bg-dark">{{ statut }}</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('app_perception_facture_show', {id: facture.id}) }}"
                               class="btn btn-sm btn-outline-primary">
                                Voir
                            </a>

                            {% if facture.resteAPayer > 0 and statut != 'annule' %}
                                <button type="button"
                                        class="btn btn-sm btn-success js-open-encaissement"
                                        data-bs-toggle="modal"
                                        data-bs-target="#encaissementModal"
                                        data-url="{{ path('app_perception_facture_encaisser', {id: facture.id}) }}">
                                    Encaisser
                                </button>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center text-muted">Aucune facture trouvée.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    </div>
</div>

<div class="modal fade" id="encaissementModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" id="encaissementModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('encaissementModal');
            const modalContent = document.getElementById('encaissementModalContent');

            function openEncaissementModal(url) {
                modalContent.innerHTML = `
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 mb-0">Chargement...</p>
                    </div>
                `;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    modalContent.innerHTML = html;
                    bindEncaissementForm();
                })
                .catch(() => {
                    modalContent.innerHTML = `
                        <div class="modal-body">
                            <div class="alert alert-danger mb-0">
                                Impossible de charger le formulaire d'encaissement.
                            </div>
                        </div>
                    `;
                });
            }

            function bindEncaissementForm() {
                const form = modalContent.querySelector('form');
                if (!form) return;

                const montantInput = form.querySelector('#encaissement_montant');
                const alertBox = form.querySelector('.js-encaissement-alert');
                const maxAmount = Number.parseInt(form.dataset.resteAPayer || montantInput?.dataset.maxAmount || '0', 10);

                function showAlert(message) {
                    if (!alertBox) {
                        return;
                    }

                    if (!message) {
                        alertBox.textContent = '';
                        alertBox.classList.add('d-none');
                        return;
                    }

                    alertBox.textContent = message;
                    alertBox.classList.remove('d-none');
                }

                function validateMontant() {
                    if (!montantInput || Number.isNaN(maxAmount) || maxAmount <= 0) {
                        showAlert('');
                        return true;
                    }

                    const value = Number.parseInt(montantInput.value || '0', 10);

                    if (!Number.isNaN(value) && value > maxAmount) {
                        showAlert(`Le montant saisi ne doit pas depasser le total a payer de ${maxAmount} FCFA.`);
                        return false;
                    }

                    showAlert('');

                    return true;
                }

                montantInput?.addEventListener('input', validateMontant);

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    if (!validateMontant()) {
                        return;
                    }

                    const submitBtn = form.querySelector('.js-submit-encaissement');
                    if (submitBtn) submitBtn.disabled = true;

                    fetch(form.action, {
                        method: form.method || 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(async response => {
                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.includes('application/json')) {
                            const data = await response.json();

                            if (data.success) {
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                modal?.hide();
                                window.location.reload();
                                return;
                            }
                        }

                        const html = await response.text();
                        modalContent.innerHTML = html;
                        bindEncaissementForm();
                    })
                    .catch(() => {
                        modalContent.innerHTML = `
                            <div class="modal-body">
                                <div class="alert alert-danger mb-0">
                                    Une erreur est survenue pendant l'encaissement.
                                </div>
                            </div>
                        `;
                    })
                    .finally(() => {
                        if (submitBtn) submitBtn.disabled = false;
                    });
                });
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.js-open-encaissement');
                if (!btn) return;

                const url = btn.dataset.url;
                if (!url) return;

                openEncaissementModal(url);
            });
        });
    </script>
{% endblock %}