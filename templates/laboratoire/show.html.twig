{% extends 'base.html.twig' %}

{% block title %}Examen laboratoire #{{ prestation.id }}{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set consultation = prestation.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}
    {% set statut = prestation.statut.value %}

    <div class="d-flex justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h3 class="mb-1">Examen laboratoire #{{ prestation.id }}</h3>
            <div class="text-muted small">
                {{ prestation.tarifPrestation.libelle }}
            </div>
        </div>

        <div class="d-flex gap-2">
            <a href="{{ path('app_laboratoire_index') }}" class="btn btn-outline-secondary">
                Retour
            </a>

            {% if statut == 'paye' %}
                <form method="post" action="{{ path('app_laboratoire_prendre_en_charge', {id: prestation.id}) }}">
                    <button type="submit" class="btn btn-primary">
                        Prendre en charge
                    </button>
                </form>
            {% endif %}

           {% if prestation.resultatLaboratoire %}
                <button type="button"
                        class="btn btn-outline-dark js-open-resultat"
                        data-bs-toggle="modal"
                        data-bs-target="#resultatLaboratoireModal"
                        data-url="{{ path('app_laboratoire_resultat_edit', {id: prestation.id}) }}">
                    Modifier le résultat
                </button>
            {% else %}
                {% if statut == 'en_cours' %}
                    <button type="button"
                            class="btn btn-outline-dark js-open-resultat"
                            data-bs-toggle="modal"
                            data-bs-target="#resultatLaboratoireModal"
                            data-url="{{ path('app_laboratoire_resultat_edit', {id: prestation.id}) }}">
                        {{ prestation.resultatLaboratoire ? 'Modifier le résultat' : 'Saisir le résultat' }}
                    </button>
                {% else %}
                    <button class="btn btn-outline-dark" disabled>
                        Saisir le résultat
                    </button>
                {% endif %}
            {% endif %}
            {% if prestation.resultatLaboratoire %}
                <a href="{{ path('app_laboratoire_resultat_print', {id: prestation.id}) }}"
                target="_blank"
                class="btn btn-outline-primary">
                    <i class="ri-printer-line me-1"></i> Imprimer le résultat
                </a>
            {% endif %}
            {% if statut in ['paye', 'en_cours'] %}
               {% if prestation.resultatLaboratoire %}
                    <form method="post" action="{{ path('app_laboratoire_realiser', {id: prestation.id}) }}">
                        <button type="submit" class="btn btn-success">
                            Marquer réalisé
                        </button>
                    </form>
                {% else %}
                    <button class="btn btn-success" disabled
                     title="Veuillez d'abord saisir le résultat" >
                        Marquer réalisé
                    </button>
                {% endif %}
            {% endif %}
        </div>
    </div>

    {% if not canEditResult %}
        <div class="alert alert-warning">
            Vous devez d'abord prendre en charge cet examen avant de saisir le resultat.
        </div>
    {% elseif statut == 'en_cours' and not hasResultatSaisi %}
        <div class="alert alert-info">
            Saisissez le resultat avant de marquer cet examen comme realise.
        </div>
    {% endif %}

    <div class="row g-3">
        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Patient</div>
                <div class="card-body">
                    <div><strong>Nom :</strong>
                        {% if patient %}
                            {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                    <div><strong>Consultation :</strong> #{{ consultation.id }}</div>
                    <div><strong>Rendez-vous :</strong> {{ rdv ? ('#' ~ rdv.id) : '-' }}</div>
                    <div><strong>Sexe :</strong> {{ patient and patient.sexe ? patient.sexe : '-' }}</div>
                    <div><strong>Âge :</strong> {{ patient and patient.dateNaissance ? patient.dateNaissance.diff(date()).y ~ ' ans' : '-' }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Examen</div>
                <div class="card-body">
                    <div><strong>Libellé :</strong> {{ prestation.tarifPrestation.libelle }}</div>
                    <div><strong>Catégorie :</strong> {{ prestation.tarifPrestation.categorie.value|replace({'_':' '})|title }}</div>
                    <div><strong>Quantité :</strong> {{ prestation.quantite }}</div>
                    <div><strong>Service :</strong> {{ prestation.tarifPrestation.serviceExecution ?: '-' }}</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white fw-semibold">Suivi</div>
                <div class="card-body">
                    <div><strong>Statut :</strong>
                        {% if statut == 'paye' %}
                            <span class="badge bg-success">Payé</span>
                        {% elseif statut == 'en_cours' %}
                            <span class="badge bg-primary">En cours</span>
                        {% elseif statut == 'realise' %}
                            <span class="badge bg-secondary">Réalisé</span>
                        {% else %}
                            <span class="badge bg-dark">{{ statut }}</span>
                        {% endif %}
                    </div>
                    <div class="mt-2"><strong>Date création :</strong> {{ prestation.createdAt ? prestation.createdAt|date('Y-m-d H:i') : '-' }}</div>
                    <div><strong>Dernière mise à jour :</strong> {{ prestation.modifiedAt ? prestation.modifiedAt|date('Y-m-d H:i') : '-' }}</div>
                    <div><strong>Résultat saisi :</strong> {{ hasResultatSaisi ? 'Oui' : 'Non' }}</div>
                    <div><strong>Validé par :</strong> {{ prestation.resultatLaboratoire and prestation.resultatLaboratoire.validePar ? prestation.resultatLaboratoire.validePar : '-' }}</div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white fw-semibold">Instructions médicales</div>
                <div class="card-body">
                    {{ prestation.instructions ?: 'Aucune instruction particulière.' }}
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="resultatLaboratoireModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content rounded-4 border-0 shadow" id="resultatLaboratoireModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-3 mb-0">Chargement...</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('resultatLaboratoireModal');
            const modalContent = document.getElementById('resultatLaboratoireModalContent');

            function openResultatModal(url) {
                modalContent.innerHTML = `
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 mb-0">Chargement...</p>
                    </div>
                `;

                fetch(url, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => response.text())
                .then(html => {
                    modalContent.innerHTML = html;
                    bindResultatForm();
                    bindDynamicResultLines();
                })
                .catch(() => {
                    modalContent.innerHTML = `
                        <div class="modal-body">
                            <div class="alert alert-danger mb-0">
                                Impossible de charger le formulaire de résultat.
                            </div>
                        </div>
                    `;
                });
            }

            function bindDynamicResultLines() {
                const container = modalContent.querySelector('#resultat-lignes');
                const addBtn = modalContent.querySelector('.js-add-result-line');

                if (!container || !addBtn) return;

                addBtn.addEventListener('click', function () {
                    const index = parseInt(container.dataset.index, 10);
                    const prototype = container.dataset.prototype;
                    const newForm = prototype.replace(/__name__/g, index);

                    const wrapper = document.createElement('div');
                    wrapper.className = 'card border mb-3 js-result-line-item';
                    wrapper.innerHTML = `
                        <div class="card-body">
                            <div class="d-flex justify-content-end mb-2">
                                <button type="button" class="btn btn-sm btn-outline-danger js-remove-result-line">
                                    <i class="ri-delete-bin-line"></i>
                                </button>
                            </div>
                            <div class="row g-3">
                                ${newForm}
                            </div>
                        </div>
                    `;

                    container.appendChild(wrapper);
                    container.dataset.index = index + 1;

                    bindRemoveButtons();
                });

                bindRemoveButtons();
            }

            function bindRemoveButtons() {
                modalContent.querySelectorAll('.js-remove-result-line').forEach(btn => {
                    btn.onclick = function () {
                        const item = this.closest('.js-result-line-item');
                        if (item) item.remove();
                    };
                });
            }

            function bindResultatForm() {
                const form = modalContent.querySelector('form');
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();

                    const submitBtn = form.querySelector('.js-submit-resultat');
                    if (submitBtn) submitBtn.disabled = true;

                    fetch(form.action, {
                        method: form.method || 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(async response => {
                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.includes('application/json')) {
                            const data = await response.json();

                            if (data.success) {
                                const modal = bootstrap.Modal.getInstance(modalEl);
                                modal?.hide();
                                window.location.reload();
                                return;
                            }
                        }

                        const html = await response.text();
                        modalContent.innerHTML = html;
                        bindResultatForm();
                        bindDynamicResultLines();
                    })
                    .catch(() => {
                        modalContent.innerHTML = `
                            <div class="modal-body">
                                <div class="alert alert-danger mb-0">
                                    Une erreur est survenue pendant l'enregistrement du résultat.
                                </div>
                            </div>
                        `;
                    })
                    .finally(() => {
                        if (submitBtn) submitBtn.disabled = false;
                    });
                });
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('.js-open-resultat');
                if (!btn) return;

                const url = btn.dataset.url;
                if (!url) return;

                openResultatModal(url);
            });
        });
    </script>
{% endblock %}