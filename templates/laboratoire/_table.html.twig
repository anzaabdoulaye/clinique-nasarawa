<div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr class="text-nowrap">
                <th class="text-uppercase small text-muted">#</th>
                <th class="text-uppercase small text-muted">Dossier / Patient</th>
                <th class="text-uppercase small text-muted">Examen</th>
                <th class="text-uppercase small text-muted">Consultation</th>
                <th class="text-uppercase small text-muted">Médecin</th>
                <th class="text-uppercase small text-muted">Date prescription</th>
                <th class="text-uppercase small text-muted">Statut</th>
                <th class="text-uppercase small text-muted text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for prestation in prestations %}
            {% set consultation = prestation.consultation %}
            {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
            {% set patient = rdv ? rdv.patient|default(null) : null %}
            {% set dossier = patient and patient.dossierMedical ? patient.dossierMedical : null %}
            {% set statut = prestation.statut.value %}

            <tr>
                <td class="text-nowrap">{{ prestation.id }}</td>

                <td style="min-width: 260px;">
                    {% if patient %}
                        <div class="fw-semibold">
                            <i class="fa fa-folder-open me-1 text-muted"></i>
                            {{ dossier ? dossier.numeroDossier : '—' }}
                        </div>

                        <div class="small text-muted">
                            {{ patient.nom|default('') }} {{ patient.prenom|default('') }}
                        </div>

                        <div class="small text-muted">
                            {{ patient.telephone|default('—') }}
                        </div>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>

                <td class="text-start" style="min-width: 220px;">
                    {{ prestation.tarifPrestation.libelle }}
                </td>

                <td class="text-nowrap">
                    {% if consultation %}
                        <span class="badge bg-light text-dark border">
                            #{{ consultation.id }}
                        </span>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>

                <td class="text-nowrap">
                    {% if consultation and consultation.medecin %}
                        <span class="badge bg-primary-subtle text-primary border">
                            <i class="fa fa-user-md me-1"></i>
                            {{ consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim) }}
                        </span>
                    {% else %}
                        <span class="badge bg-light text-muted border">Non renseigné</span>
                    {% endif %}
                </td>

                <td class="text-nowrap">
                    {% if prestation.createdAt %}
                        <div class="fw-semibold">{{ prestation.createdAt|date('d/m/Y') }}</div>
                        <div class="small text-muted">{{ prestation.createdAt|date('H:i') }}</div>
                    {% else %}
                        <span class="text-muted">—</span>
                    {% endif %}
                </td>

                <td class="text-nowrap">
                    {% if statut == 'paye' %}
                        <span class="badge bg-success">Payé</span>
                    {% elseif statut == 'en_cours' %}
                        <span class="badge bg-primary">En cours</span>
                    {% elseif statut == 'realise' %}
                        <span class="badge bg-secondary">Réalisé</span>
                    {% else %}
                        <span class="badge bg-dark">{{ statut }}</span>
                    {% endif %}
                </td>

                <td class="text-end">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Actions laboratoire">
                        <a href="{{ path('app_laboratoire_show', {id: prestation.id}) }}"
                           class="btn btn-outline-primary">
                            <i class="fa fa-eye me-1"></i> Voir
                        </a>

                        {% if consultation %}
                            <a href="{{ path('app_laboratoire_bon_show', {id: consultation.id}) }}"
                               class="btn btn-outline-dark">
                                <i class="fa fa-file-alt me-1"></i> Bon d'examen
                            </a>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">
                    <div class="py-5 text-center">
                        <div class="mb-2">
                            <i class="fa fa-info-circle text-muted" style="font-size: 28px;"></i>
                        </div>
                        <div class="fw-semibold">{{ emptyMessage }}</div>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>