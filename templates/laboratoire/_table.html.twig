<div class="table-responsive">
    <table class="table table-borderless align-middle table-hover mb-0 datatable labo-table">
        <thead>
            <tr>
                <th class="text-muted small fw-semibold">#</th>
                <th class="text-muted small fw-semibold">Patient</th>
                <th class="text-muted small fw-semibold">Examen</th>
                <th class="text-muted small fw-semibold">Consultation</th>
                <th class="text-muted small fw-semibold">Médecin</th>
                <th class="text-muted small fw-semibold">Date prescription</th>
                <th class="text-muted small fw-semibold">Statut</th>
                <th class="text-end text-muted small fw-semibold">Actions</th>
            </tr>
        </thead>

        <tbody>
        {% for prestation in prestations %}
            {% set consultation = prestation.consultation %}
            {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
            {% set patient = rdv ? rdv.patient|default(null) : null %}
            {% set statut = prestation.statut.value %}

            {% set patientNom = patient
                ? patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim)
                : 'Patient non renseigné'
            %}

            {% set medecinNom = consultation and consultation.medecin
                ? consultation.medecin.nomComplet|default((consultation.medecin.nom|default('') ~ ' ' ~ consultation.medecin.prenom|default(''))|trim)
                : 'Non assigné'
            %}

            <tr>
                <td>
                    <span class="fw-semibold text-dark">#{{ prestation.id }}</span>
                </td>

                <td>
                    <div class="d-flex align-items-center gap-3">
                        <div class="patient-avatar">
                            <i class="ri-user-3-line"></i>
                        </div>
                        <div>
                            <div class="fw-semibold text-dark">
                                {{ patientNom ?: '-' }}
                            </div>
                            <div class="text-muted small">
                                {% if rdv %}
                                    Rendez-vous #{{ rdv.id }}
                                {% else %}
                                    Aucun rendez-vous
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </td>

                <td>
                    <div class="fw-semibold text-dark">
                        {{ prestation.tarifPrestation.libelle }}
                    </div>
                    <div class="text-muted small">
                        {{ prestation.tarifPrestation.categorie.value|replace({'_':' '})|title }}
                    </div>
                </td>

                <td>
                    <div class="fw-semibold text-dark">
                        {% if consultation %}
                            #{{ consultation.id }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                </td>

                <td>
                    <div class="fw-semibold text-dark">{{ medecinNom }}</div>
                </td>

                <td>
                    <div class="fw-semibold text-dark">
                        {{ prestation.createdAt ? prestation.createdAt|date('d/m/Y') : '-' }}
                    </div>
                    <div class="text-muted small">
                        {{ prestation.createdAt ? prestation.createdAt|date('H:i') : '' }}
                    </div>
                </td>

                <td>
                    {% if statut == 'paye' %}
                        <span class="badge rounded-pill text-bg-warning px-3 py-2">
                            <i class="ri-time-line me-1"></i> À traiter
                        </span>
                    {% elseif statut == 'en_cours' %}
                        <span class="badge rounded-pill text-bg-primary px-3 py-2">
                            <i class="ri-loader-4-line me-1"></i> En cours
                        </span>
                    {% elseif statut == 'realise' %}
                        <span class="badge rounded-pill text-bg-success px-3 py-2">
                            <i class="ri-checkbox-circle-line me-1"></i> Réalisé
                        </span>
                    {% else %}
                        <span class="badge rounded-pill text-bg-dark px-3 py-2">
                            {{ statut|replace({'_':' '})|title }}
                        </span>
                    {% endif %}
                </td>

                <td class="text-end">
                    <div class="d-flex justify-content-end flex-wrap gap-2">
                        <a href="{{ path('app_laboratoire_show', {id: prestation.id}) }}"
                           class="btn btn-sm btn-primary rounded-pill px-3">
                            <i class="ri-eye-line me-1"></i> Voir
                        </a>

                        {% if consultation %}
                            <a href="{{ path('app_laboratoire_bon_show', {id: consultation.id}) }}"
                               class="btn btn-sm btn-outline-dark rounded-pill px-3">
                                <i class="ri-file-text-line me-1"></i> Bon d'examen
                            </a>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

<style>
    .labo-table {
        --bs-table-bg: transparent;
    }

    .labo-table thead th {
        background: #f8fafc;
        border-bottom: 1px solid #e9ecef;
        padding-top: 1rem;
        padding-bottom: 1rem;
        white-space: nowrap;
    }

    .labo-table tbody tr {
        background: #fff;
        transition: all .2s ease;
        border-bottom: 1px solid #f1f5f9;
    }

    .labo-table tbody tr:hover {
        background: #f8fbff;
    }

    .labo-table tbody td {
        padding-top: 1rem;
        padding-bottom: 1rem;
        vertical-align: middle;
    }

    .patient-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: #eaf2ff;
        color: #0d6efd;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .empty-state {
        padding: 1rem;
    }

    .empty-state-icon {
        width: 68px;
        height: 68px;
        margin: 0 auto;
        border-radius: 50%;
        background: #f1f5f9;
        color: #64748b;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
    }

    .badge.text-bg-warning {
        color: #664d03 !important;
        background-color: #fff3cd !important;
    }

    .badge.text-bg-primary {
        background-color: #0d6efd !important;
    }

    .badge.text-bg-success {
        background-color: #198754 !important;
    }
</style>