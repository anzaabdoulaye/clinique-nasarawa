<div class="modal-header bg-light">
  <div>
    <h5 class="modal-title mb-0">Résultat — {{ ligne.libelle }}</h5>
    <small class="text-muted">Bon #{{ bon.id }} — Patient : {{ bon.patient.nom }} {{ bon.patient.prenom }}</small>
  </div>
  <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
  <form id="ligneResultForm" action="{{ path('app_labo_ligne_save', {id: ligne.id}) }}" method="post">
    <div class="row g-2">
      <div class="col-md-4">
        <label class="form-label">Valeur</label>
        <input class="form-control" name="resultatValeur" value="{{ ligne.resultatValeur ?? '' }}">
      </div>
      <div class="col-md-3">
        <label class="form-label">Unité</label>
        <input class="form-control" name="unite" value="{{ ligne.unite ?? '' }}">
      </div>
      <div class="col-md-5">
        <label class="form-label">Valeurs normales</label>
        <input class="form-control" name="valeursNormales" value="{{ ligne.valeursNormales ?? '' }}">
      </div>
    </div>

    <div class="mt-2">
      <label class="form-label">Résultat (texte libre)</label>
      <textarea class="form-control" name="resultatTexte" rows="6">{{ ligne.resultatTexte ?? '' }}</textarea>
    </div>

    <div class="row g-2 mt-2">
      <div class="col-md-4">
        <label class="form-label">Prix (FCFA)</label>
        <input class="form-control" name="prixUnitaire" value="{{ ligne.prixUnitaire ?? '' }}" placeholder="ex: 7000">
        <div class="form-text">Pour la facturation quand résultats disponibles.</div>
      </div>
      <div class="col-md-8 d-flex align-items-end justify-content-end gap-2">
        <button class="btn btn-primary" type="submit">
          <i class="ri-save-line me-1"></i> Enregistrer
        </button>
      </div>
    </div>
  </form>
</div>
