<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Résultat laboratoire</title>

    <style>
        @page {
            size: A4 portrait;
            margin: 8mm;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 10px;
            color: #1f2937;
        }

        .document {
            width: 100%;
        }

        .top-bar {
            height: 4px;
            background: #0f4c81;
            margin-bottom: 8px;
        }

        .header-table,
        .meta-table,
        .result-table,
        .footer-table,
        .signature-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .meta-table td,
        .footer-table td,
        .signature-table td {
            vertical-align: top;
        }

        .clinic-logo {
            width: 26mm;
            height: 26mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #ffffff;
            border-radius: 50%;
        }

        .clinic h1 {
            margin: 0 0 3px 0;
            font-size: 14px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
        }

        .clinic .sub {
            font-size: 8px;
            line-height: 1.35;
            color: #6b7280;
        }

        .qr-box {
            width: 30mm;
            text-align: center;
            border: 1px solid #d1d5db;
            padding: 4px;
            background: #f8fafc;
        }

        .qr-box img {
            width: 22mm;
            height: 22mm;
            border: 1px solid #e5e7eb;
            background: #fff;
            padding: 2px;
        }

        .qr-label {
            margin-top: 2px;
            font-size: 7px;
            line-height: 1.2;
            color: #6b7280;
        }

        .separator {
            border-bottom: 1px solid #d1d5db;
            margin: 8px 0;
        }

        .title-box {
            text-align: center;
            margin-bottom: 8px;
        }

        .title-box .title {
            font-size: 13px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
        }

        .title-box .subtitle {
            margin-top: 2px;
            font-size: 8px;
            color: #6b7280;
        }

        .meta-box,
        .box,
        .table-wrap {
            border: 1px solid #d1d5db;
        }

        .meta-box {
            padding: 6px;
            margin-bottom: 8px;
        }

        .meta-table td {
            width: 50%;
            padding: 3px 4px;
            line-height: 1.35;
        }

        .section {
            margin-top: 6px;
        }

        .section-title {
            padding: 4px 6px;
            font-size: 9px;
            font-weight: bold;
            color: #0f4c81;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-bottom: none;
            text-transform: uppercase;
        }

        .box {
            padding: 6px;
            line-height: 1.35;
        }

        .table-wrap {
            border-top: none;
        }

        .result-table th,
        .result-table td {
            border: 1px solid #e5e7eb;
            padding: 6px 5px;
            font-size: 9px;
            text-align: left;
            vertical-align: top;
        }

        .result-table th {
            color: #ffffff;
            background: #0f4c81;
            font-weight: bold;
        }

        .footer-block {
            border-top: 1px dashed #d1d5db;
            margin-top: 8px;
            padding-top: 6px;
        }

        .footer-left {
            font-size: 8px;
            color: #6b7280;
            line-height: 1.35;
            padding-right: 6px;
        }

        .signature-table {
            margin-top: 10px;
        }

        .signature-block {
            text-align: center;
            vertical-align: bottom;
            height: 70px;
            padding: 0 12px;
        }

        .line {
            border-top: 1px solid #000;
            padding-top: 4px;
            font-size: 8px;
            color: #6b7280;
        }

        .footer-note {
            margin-top: 8px;
            padding-top: 4px;
            text-align: center;
            font-size: 9px;
            font-weight: bold;
            color: #0f4c81;
            border-top: 1px dashed #d1d5db;
        }

        .no-print {
            display: none;
        }

        @media print {
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    {% set consultation = prestation.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = rdv ? rdv.patient|default(null) : null %}
    {% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}

    <div class="document">
        <div class="top-bar"></div>

        <table class="header-table">
            <tr>
                <td style="width:16%;">
                    {% if logo_path is defined and logo_path %}
                        <img src="{{ logo_path }}" alt="Logo Clinique Médicale Nassarawa" class="clinic-logo">
                    {% endif %}
                </td>

                <td style="width:60%;">
                    <div class="clinic">
                        <h1>Clinique Médicale Nassarawa</h1>
                        <div class="sub">
                            NIF : 120402/R<br>
                            RCCM : NE-NIM-01-2024-B12-00145<br>
                            Yantala Haut Avenue du Daoura YN 187<br>
                            Tél : 20 75 51 02 / 88 05 22 20<br>
                            BP : 2120 Niamey<br>
                            Email : nassrawaclinique@gmail.com
                        </div>
                    </div>
                </td>

                <td style="width:24%; text-align:right;">
                    <div class="qr-box">
                        {% if _qr %}
                            <img src="{{ _qr }}" alt="QR Code">
                        {% endif %}

                        {% if code_qr is defined and code_qr %}
                            <div class="qr-label">Code : {{ code_qr }}</div>
                        {% endif %}

                        <div class="qr-label">Scanner pour vérification</div>
                    </div>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <div class="title-box">
            <div class="title">Résultat laboratoire</div>
            <div class="subtitle">
                {% if prestation.tarifPrestation is defined and prestation.tarifPrestation %}
                    {{ prestation.tarifPrestation.libelle }}
                {% endif %}
            </div>
        </div>

        <div class="meta-box">
            <table class="meta-table">
                <tr>
                    <td>
                        <strong>Nom Prénom :</strong>
                        {% if patient %}
                            {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                        {% else %}
                            -
                        {% endif %}
                    </td>
                    <td>
                        <strong>Consultation :</strong>
                        {{ consultation ? ('#' ~ consultation.id) : '-' }}
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Âge :</strong>
                        {{ patient and attribute(patient, 'age') is defined ? patient.age ~ ' ans' : '-' }}
                    </td>
                    <td>
                        <strong>Sexe :</strong>
                        {{ patient and attribute(patient, 'sexe') is defined ? patient.sexe : '-' }}
                    </td>
                </tr>
                <tr>
                    <td>
                        <strong>Date de validation :</strong>
                        {{ resultat.dateValidation ? resultat.dateValidation|date('d/m/Y') : "now"|date('d/m/Y') }}
                    </td>
                    <td>
                        <strong>Référence :</strong>
                        LAB-{{ resultat.id ?? prestation.id }}
                    </td>
                </tr>
            </table>
        </div>

        <div class="section">
            <div class="section-title">Résultats</div>
            <div class="table-wrap">
                <table class="result-table">
                    <thead>
                        <tr>
                            <th style="width:34%;">Demandes</th>
                            <th style="width:33%;">Résultats</th>
                            <th style="width:33%;">Valeurs normales</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% if resultat.lignes|length > 0 %}
                        {% for ligne in resultat.lignes|sort((a, b) => a.ordre <=> b.ordre) %}
                            <tr>
                                <td>{{ ligne.demande|nl2br }}</td>
                                <td>{{ ligne.resultat ? ligne.resultat|nl2br : '-' }}</td>
                                <td>{{ ligne.valeurNormale ? ligne.valeurNormale|nl2br : '-' }}</td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td>{{ prestation.tarifPrestation.libelle }}</td>
                            <td>{{ resultat.resultat ? resultat.resultat|nl2br : '-' }}</td>
                            <td>-</td>
                        </tr>
                    {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if resultat.conclusion %}
            <div class="section">
                <div class="section-title">Conclusion</div>
                <div class="box">
                    {{ resultat.conclusion|nl2br }}
                </div>
            </div>
        {% endif %}

        <div class="footer-block">
            <table class="footer-table">
                <tr>
                    <td class="footer-left">
                        <div>
                            <strong>Document :</strong>
                            Résultat laboratoire généré par le système de gestion de la clinique.
                        </div>
                        <div>
                            <strong>Examen :</strong>
                            {{ prestation.tarifPrestation.libelle }}
                        </div>
                    </td>
                </tr>
            </table>
        </div>

        <table class="signature-table">
            <tr>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Signature du biologiste / technicien</div>
                </td>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Cachet du laboratoire</div>
                </td>
            </tr>
        </table>

        <div class="footer-note">
            Document à conserver par le patient
        </div>

        <div class="no-print" style="margin-top:12px; text-align:right;">
            <button onclick="window.print()">Imprimer</button>
        </div>
    </div>
</body>
</html>