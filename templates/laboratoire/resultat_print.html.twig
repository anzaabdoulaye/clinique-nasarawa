<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Résultat laboratoire</title>

    <style>
        @page {
            size: A5 portrait;
            margin: 6mm;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 9px;
            color: #1f2937;
            background: #ffffff;
        }

        .document {
            width: 100%;
            margin: 0 auto;
            border: 1px solid #dbe3ea;
            border-radius: 10px;
            padding: 6px;
        }

        .top-bar {
            height: 3px;
            background: #0f4c81;
            margin-bottom: 6px;
            border-radius: 4px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .info-table td,
        .trace-table td,
        .signature-table td {
            vertical-align: top;
        }

        .clinic-logo {
            width: 20mm;
            height: 20mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #ffffff;
            border-radius: 50%;
            object-fit: cover;
        }

        .clinic h1 {
            margin: 0 0 2px 0;
            font-size: 11px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
            line-height: 1.2;
        }

        .clinic .sub {
            font-size: 7px;
            line-height: 1.3;
            color: #6b7280;
        }

        .qr-box {
            width: 100%;
            text-align: center;
            border: 1px solid #d1d5db;
            padding: 3px;
            background: #f8fafc;
            border-radius: 6px;
        }

        .qr-box img {
            width: 17mm;
            height: 17mm;
            border: 1px solid #e5e7eb;
            background: #fff;
            padding: 2px;
        }

        .qr-label {
            margin-top: 2px;
            font-size: 6.5px;
            line-height: 1.2;
            color: #6b7280;
        }

        .separator {
            border-bottom: 1px solid #d1d5db;
            margin: 5px 0 6px 0;
        }

        .title-box {
            text-align: center;
            margin-bottom: 6px;
            padding: 4px 6px;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-radius: 8px;
        }

        .title-box .title {
            font-size: 11px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
            line-height: 1.2;
        }

        .title-box .subtitle {
            margin-top: 2px;
            font-size: 7px;
            color: #6b7280;
            line-height: 1.2;
        }

        .section {
            margin-top: 6px;
        }

        .section-title {
            padding: 4px 5px;
            font-size: 8px;
            font-weight: bold;
            color: #0f4c81;
            background: #f8fafc;
            border: 1px solid #d1d5db;
            border-bottom: none;
            border-radius: 6px 6px 0 0;
            text-transform: uppercase;
            line-height: 1.2;
        }

        .section-body {
            border: 1px solid #d1d5db;
            border-top: none;
            border-radius: 0 0 6px 6px;
            overflow: hidden;
            background: #fff;
        }

        .info-table td,
        .trace-table td {
            padding: 4px 5px;
            font-size: 8px;
            line-height: 1.35;
            border: 1px solid #eef2f7;
        }

        .label {
            font-weight: bold;
            color: #374151;
        }

        .result-table th,
        .result-table td {
            border: 1px solid #e5e7eb;
            padding: 4px;
            font-size: 8px;
            text-align: left;
            vertical-align: top;
            line-height: 1.3;
        }

        .result-table th {
            color: #ffffff;
            background: #0f4c81;
            font-weight: bold;
        }

        .result-table tbody tr:nth-child(even) {
            background: #fafcff;
        }

        .box {
            padding: 6px;
            line-height: 1.4;
            font-size: 8px;
            min-height: 28px;
        }

        .footer-note {
            margin-top: 6px;
            padding-top: 4px;
            text-align: center;
            font-size: 8px;
            font-weight: bold;
            color: #0f4c81;
            border-top: 1px dashed #d1d5db;
        }

        .signature-table {
            margin-top: 80px;
        }

        .signature-block {
            text-align: center;
            vertical-align: bottom;
            height: 10px;
            padding: 0 8px;
        }

        .line {
            border-top: 1px solid #000;
            padding-top: 3px;
            font-size: 7px;
            color: #6b7280;
            line-height: 1.2;
        }

        .no-print {
            margin-top: 10px;
            text-align: right;
        }

        .no-print button {
            padding: 6px 10px;
            border: none;
            border-radius: 6px;
            background: #0f4c81;
            color: #fff;
            cursor: pointer;
            font-size: 8px;
        }

        @media print {
            body {
                background: #fff !important;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .document {
                border: none;
                border-radius: 0;
                padding: 0;
            }

            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    {% set consultation = prestation.consultation %}
    {% set rdv = consultation ? consultation.rendezVous|default(null) : null %}
    {% set patient = patient|default(consultation and consultation.dossierMedical ? consultation.dossierMedical.patient|default(null) : null) %}
    {% set patient = patient ?: (rdv ? rdv.patient|default(null) : null) %}
    {% set _qr = qr_data is defined ? qr_data : (qrCodeDataUri is defined ? qrCodeDataUri : null) %}

    <div class="document">
        <div class="top-bar"></div>

        <table class="header-table">
            <tr>
                <td style="width:18%;">
                    {% if logo_path is defined and logo_path %}
                        <img src="{{ logo_path }}" alt="Logo Clinique Médicale Nassarawa" class="clinic-logo">
                    {% endif %}
                </td>

                <td style="width:56%;">
                    <div class="clinic">
                        <h1>Clinique Médicale Nassarawa</h1>
                        <div class="sub">
                            NIF : 120402/R<br>
                            RCCM : NE-NIM-01-2024-B12-00145<br>
                            Yantala Haut Avenue du Daoura YN 187<br>
                            Tél : 20 75 51 02 / 88 05 22 20<br>
                            BP : 2120 Niamey<br>
                            Email : nassrawaclinique@gmail.com
                        </div>
                    </div>
                </td>

                <td style="width:26%; text-align:right;">
                    <div class="qr-box">
                        {% if _qr %}
                            <img src="{{ _qr }}" alt="QR Code">
                        {% endif %}

                        {% if code_qr is defined and code_qr %}
                            <div class="qr-label">Code : {{ code_qr }}</div>
                        {% endif %}

                        <div class="qr-label">Scanner pour vérification</div>
                    </div>
                </td>
            </tr>
        </table>

        <div class="separator"></div>

        <div class="title-box">
            <div class="title">Résultat laboratoire</div>
            <div class="subtitle">
                {{ prestation.tarifPrestation is defined and prestation.tarifPrestation ? prestation.tarifPrestation.libelle : 'Examen de laboratoire' }}
            </div>
        </div>

        <div class="section">
            <div class="section-title">Informations du patient et de l'examen</div>
            <div class="section-body">
                <table class="info-table">
                    <tr>
                        <td style="width:50%;">
                            <span class="label">Nom et prénom :</span>
                            {% if patient %}
                                {{ patient.nomComplet|default((patient.nom|default('') ~ ' ' ~ patient.prenom|default(''))|trim) }}
                            {% else %}
                                -
                            {% endif %}
                        </td>
                        <td style="width:50%;">
                            <span class="label">Référence :</span>
                            LAB-{{ resultat.id ?? prestation.id }}
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <span class="label">Âge :</span>
                            {{ patient and patient.dateNaissance ? patient.dateNaissance.diff(date()).y ~ ' ans' : '-' }}
                        </td>
                        <td>
                            <span class="label">Sexe :</span>
                            {{ patient and patient.sexe ? patient.sexe : '-' }}
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <span class="label">Consultation :</span>
                            {{ consultation ? ('#' ~ consultation.id) : '-' }}
                        </td>
                        <td>
                            <span class="label">Date de validation :</span>
                            {{ resultat.dateValidation ? resultat.dateValidation|date('d/m/Y') : "now"|date('d/m/Y') }}
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            <span class="label">Examen demandé :</span>
                            {{ prestation.tarifPrestation is defined and prestation.tarifPrestation ? prestation.tarifPrestation.libelle : '-' }}
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="section">
            <div class="section-title">Résultats du laboratoire</div>
            <div class="section-body">
                <table class="result-table">
                    <thead>
                        <tr>
                            <th style="width:34%;">Paramètre / Demande</th>
                            <th style="width:33%;">Résultat</th>
                            <th style="width:33%;">Valeurs normales</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if resultat.lignes|length > 0 %}
                            {% for ligne in resultat.lignes|sort((a, b) => a.ordre <=> b.ordre) %}
                                <tr>
                                    <td>{{ ligne.demande|nl2br }}</td>
                                    <td>{{ ligne.resultat ? ligne.resultat|nl2br : '-' }}</td>
                                    <td>{{ ligne.valeurNormale ? ligne.valeurNormale|nl2br : '-' }}</td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td>{{ prestation.tarifPrestation.libelle }}</td>
                                <td>{{ resultat.resultat ? resultat.resultat|nl2br : '-' }}</td>
                                <td>-</td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

        {% if resultat.conclusion %}
            <div class="section">
                <div class="section-title">Conclusion / Observation</div>
                <div class="section-body">
                    <div class="box">
                        {{ resultat.conclusion|nl2br }}
                    </div>
                </div>
            </div>
        {% endif %}

        <div class="section">
            <div class="section-title">Traçabilité et validation</div>
            <div class="section-body">
                <table class="trace-table">
                    <tr>
                        <td style="width:50%;">
                            <span class="label">Laborantin :</span>
                            {{ resultat.validePar ?: '-' }}
                        </td>
                        <td style="width:50%;">
                            <span class="label">Document :</span>
                            Résultat laboratoire généré par le système
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2">
                            <span class="label">Mention :</span>
                            Document à conserver par le patient
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <table class="signature-table">
            <tr>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Signature du biologiste / technicien</div>
                </td>
                <td class="signature-block" style="width:50%;">
                    <div class="line">Cachet du laboratoire</div>
                </td>
            </tr>
        </table>

        <div class="footer-note">
            Clinique Médicale Nassarawa — Résultat de laboratoire
        </div>

        
    </div>
</body>
</html>