{% extends 'base.html.twig' %}

{% block title %}Facture #{{ facture.id }}{% endblock %}

{% block body %}
<style>
  .fx-wrap{ max-width: 1100px; margin: 0 auto; }
  .fx-card{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 16px;
  }
  .fx-card .card-header{
    background:#fff;
    border-bottom:1px solid rgba(0,0,0,.06);
    border-top-left-radius:16px;
    border-top-right-radius:16px;
  }
  .fx-kv{
    display:grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 16px;
  }
  @media (max-width: 768px){ .fx-kv{ grid-template-columns: 1fr; } }

  .fx-field{
    border: 1px solid rgba(0,0,0,.06);
    border-radius: 14px;
    padding: 12px;
    background:#fff;
  }
  .fx-label{
    font-size: 12px;
    color:#6b7280;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: .04em;
    margin-bottom: 6px;
  }
  .fx-value{
    font-size: 14px;
    font-weight: 650;
    color:#111827;
    line-height: 1.35;
    word-break: break-word;
  }

  .badge-soft{
    border: 1px solid rgba(0,0,0,.10);
    padding: .45rem .65rem;
    border-radius: 999px;
    font-weight: 900;
    display:inline-flex;
    align-items:center;
    gap:8px;
  }
  .dot{ width: 8px; height: 8px; border-radius: 999px; background:#9ca3af; }
  .is-ok{ background:#ecfdf5; color:#065f46; border-color:#a7f3d0; }
  .is-ok .dot{ background:#10b981; }
  .is-warn{ background:#fffbeb; color:#92400e; border-color:#fde68a; }
  .is-warn .dot{ background:#f59e0b; }
  .is-bad{ background:#fef2f2; color:#991b1b; border-color:#fecaca; }
  .is-bad .dot{ background:#ef4444; }

  @media print{
    .no-print{ display:none !important; }
    body{-webkit-print-color-adjust:exact; print-color-adjust:exact;}
    .fx-card{ box-shadow:none !important; }
  }
</style>

{# ===== Helpers enum/string ===== #}
{% set statut = facture.statut.value ?? '' %}
{% set dernierPaiement = facture.paiements|last %}
{% set mode = dernierPaiement and dernierPaiement.mode ? dernierPaiement.mode.value : '' %}
{% set consultation = facture.consultation ?? null %}
{% set rendezVous = consultation and consultation.rendezVous ? consultation.rendezVous : null %}
{% set patient = rendezVous and rendezVous.patient ? rendezVous.patient : null %}

{% set statutClass =
  statut in ['PAYE','PAYEE','PAID'] ? 'badge-soft is-ok' :
  (statut in ['EN_ATTENTE','EN_ATTENTE_PAIEMENT','PENDING'] ? 'badge-soft is-warn' :
  (statut in ['ANNULE','ANNULEE','CANCELED'] ? 'badge-soft is-bad' :
  'badge-soft bg-light text-muted'))
%}

<div class="fx-wrap">
  <div class="card fx-card shadow-sm border-0">
    <div class="card-header py-3">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
        <div>
          <h5 class="mb-0 fw-semibold">
            <i class="fa fa-file-invoice-dollar me-2 text-primary"></i>
            Facture #{{ facture.id }}
          </h5>
          <div class="text-muted small">Détails de la facture et suivi du paiement</div>
        </div>

        <div class="d-flex gap-2 align-items-center no-print">
          <span class="{{ statutClass }}">
            <span class="dot"></span> {{ statut }}
          </span>

          <a href="{{ path('app_facture_index') }}" class="btn btn-light border">
            <i class="fa fa-arrow-left me-1"></i> Retour
          </a>

          {# <a href="{{ path('app_facture_edit', {'id': facture.id}) }}" class="btn btn-outline-primary">
            <i class="fa fa-pen me-1"></i> Modifier
          </a> #}

          <a href="{{ path('app_facture_print', {id: facture.id}) }}"
           
            class="btn btn-outline-primary border">
              <i class="ri-eye-line"></i> Voir
          </a>

          <a href="{{ path('app_facture_pdf', {id: facture.id}) }}"
            
            class="btn btn-success border">
              <i class="ri-file-pdf-line"></i> Imprimer
          </a>

         <div class="d-flex gap-2">

    
          

          
          {# <a href="{{ path('app_facture_print', {id: facture.id}) }}"
            target="_blank"
            class="btn btn-primary btn-sm"
            onclick="setTimeout(() => window.print(), 500)">
              <i class="ri-printer-line"></i> Imprimer
          </a> #}

          
          

      </div>
        </div>
      </div>
    </div>

    <div class="card-body">
      <div class="fx-kv">
        <div class="fx-field">
          <div class="fx-label">Patient</div>
          <div class="fx-value">
            {% set patient = facture.consultation and facture.consultation.dossierMedical ? facture.consultation.dossierMedical.patient : null %}
                  {{ patient ? patient.nom ~ ' ' ~ patient.prenom : '—' }}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Code patient</div>
          <div class="fx-value">{{ patient and patient.code ? patient.code : '—' }}</div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Téléphone patient</div>
          <div class="fx-value">{{ patient and patient.telephone ? patient.telephone : '—' }}</div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Sexe</div>
          <div class="fx-value">{{ patient and patient.sexe ? patient.sexe : '—' }}</div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Montant</div>
          <div class="fx-value">{{ facture.montantTotal|number_format(0, ',', ' ') }} FCFA</div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Statut de paiement</div>
          <div class="fx-value">
            <span class="{{ statutClass }}"><span class="dot"></span> {{ statut }}</span>
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Date d’émission</div>
          <div class="fx-value">
            {{ facture.dateEmission ? facture.dateEmission|date('d/m/Y H:i') : '—' }}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Date de paiement</div>
          <div class="fx-value">
            {{ facture.datePaiement ? facture.datePaiement|date('d/m/Y H:i') : 'Non payé' }}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Mode de paiement</div>
          <div class="fx-value">
            {% if mode != '—' %}
              <span class="badge bg-primary-subtle text-primary border">
                <i class="fa fa-credit-card me-1"></i> {{ mode }}
              </span>
            {% else %}
              <span class="text-muted">—</span>
            {% endif %}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Consultation</div>
          <div class="fx-value">
            {% if facture.consultation is defined and facture.consultation %}
              #{{ facture.consultation.id }}
            {% else %}
              —
            {% endif %}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Créé le</div>
          <div class="fx-value">
            {{ facture.createdAt ? facture.createdAt|date('d/m/Y H:i') : '—' }}
          </div>
        </div>

        <div class="fx-field">
          <div class="fx-label">Modifié le</div>
          <div class="fx-value">
            {{ facture.modifiedAt ? facture.modifiedAt|date('d/m/Y H:i') : '—' }}
          </div>
        </div>
      </div>
    </div>

    <div class="card-footer bg-white border-0 pt-0">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div class="text-muted small">
          Référence : <span class="badge bg-light text-dark border">#{{ facture.id }}</span>
        </div>

        <div class="no-print">
          {{ include('facture/_delete_form.html.twig') }}
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}