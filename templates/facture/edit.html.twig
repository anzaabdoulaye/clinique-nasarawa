{% extends 'base.html.twig' %}

{% block title %}Modifier la facture{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">Modifier la facture #{{ facture.id }}</h1>
            <p class="text-muted mb-0">Le statut et les paiements sont calculés automatiquement.</p>
        </div>
        <a href="{{ path('app_facture_index') }}" class="btn btn-light border">Retour</a>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            {{ include('facture/_form.html.twig', {'button_label': 'Mettre à jour'}) }}
        </div>
    </div>

    <div>
        {{ include('facture/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}
