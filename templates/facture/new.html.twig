{% extends 'base.html.twig' %}

{% block title %}Nouvelle facture{% endblock %}

{% block body %}
<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Nouvelle facture</h1>
      <p class="text-muted mb-0">Créez une facture en l'associant à une consultation existante.</p>
    </div>
    <a href="{{ path('app_facture_index') }}" class="btn btn-light border">Retour</a>
  </div>

  <div class="card shadow-sm border-0">
    <div class="card-body">
      {{ include('facture/_form.html.twig', {'button_label': 'Enregistrer'}) }}
    </div>
  </div>
</div>
{% endblock %}