{% extends 'base.html.twig' %}

{% block title %}Utilisateurs{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# ===== En-tête de page ===== #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="ri-team-line me-2 text-primary"></i>
                Gestion des utilisateurs
            </h2>
            <p class="text-muted mb-0">
                Gérez les comptes utilisateurs, leurs rôles et leurs rattachements aux services.
            </p>
        </div>

        <div>
            <button class="btn btn-primary shadow-sm rounded-pill px-4"
                    data-bs-toggle="modal"
                    data-bs-target="#addUtilisateurModal">
                <i class="ri-user-add-line me-1"></i>
                Nouvel utilisateur
            </button>
        </div>
    </div>

    {# ===== Carte principale ===== #}
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
                <div>
                    <h5 class="mb-1 fw-semibold text-dark">Liste des utilisateurs</h5>
                    <small class="text-muted">
                        Total : <span class="fw-semibold">{{ utilisateurs|length }}</span> utilisateur(s)
                    </small>
                </div>
            </div>
        </div>

        <div class="card-body px-4 pb-4">

            {% if utilisateurs|length > 0 %}
                <div class="table-responsive">
                    <table class="table align-middle table-hover mb-0 datatable">
                        <thead class="table-light">
                            <tr>
                                <th class="fw-semibold text-dark">Utilisateur</th>
                                <th class="fw-semibold text-dark">Statut</th>
                                <th class="fw-semibold text-dark">Rôles</th>
                                <th class="fw-semibold text-dark">Service</th>
                                <th class="fw-semibold text-dark">Créé le</th>
                                <th class="fw-semibold text-dark text-center no-sort no-export">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for u in utilisateurs %}
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="rounded-circle bg-primary-subtle text-primary d-flex justify-content-center align-items-center"
                                                 style="width: 42px; height: 42px; font-weight: 700; font-size: 14px;">
                                                {{ (u.nom|default('U')|slice(0,1) ~ u.prenom|default('')|slice(0,1))|upper }}
                                            </div>
                                            <div>
                                                <div class="fw-semibold text-dark">
                                                    {{ u.nom }} {{ u.prenom }}
                                                </div>
                                                <small class="text-muted">
                                                    @{{ u.username }}
                                                </small>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        {% if u.statut is defined and u.statut %}
                                            {% set statutValue = u.statut.value is defined ? u.statut.value : u.statut %}
                                            {% if statutValue in ['ACTIF', 'Actif', 'actif'] %}
                                                <span class="badge rounded-pill bg-success-subtle text-success px-3 py-2">
                                                    <i class="ri-checkbox-circle-line me-1"></i> Actif
                                                </span>
                                            {% else %}
                                                <span class="badge rounded-pill bg-danger-subtle text-danger px-3 py-2">
                                                    <i class="ri-close-circle-line me-1"></i> Inactif
                                                </span>
                                            {% endif %}
                                        {% else %}
                                            <span class="badge rounded-pill bg-light text-muted border px-3 py-2">
                                                Non défini
                                            </span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if u.roles is defined and u.roles|length > 0 %}
                                            <div class="d-flex flex-wrap gap-1">
                                                {% for role in u.roles %}
                                                    <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                                        {{ role }}
                                                    </span>
                                                {% endfor %}
                                            </div>
                                        {% else %}
                                            <span class="text-muted">Aucun rôle</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if u.serviceMedical %}
                                            <span class="badge rounded-pill bg-info-subtle text-info px-3 py-2">
                                                <i class="ri-hospital-line me-1"></i>
                                                {{ u.serviceMedical.libelle ?? u.serviceMedical.nom ?? 'Service' }}
                                            </span>
                                        {% else %}
                                            <span class="text-muted">Non rattaché</span>
                                        {% endif %}
                                    </td>

                                    <td>
                                        {% if u.createdAt %}
                                            <div class="fw-semibold text-dark">{{ u.createdAt|date('d/m/Y') }}</div>
                                            <small class="text-muted">{{ u.createdAt|date('H:i') }}</small>
                                        {% else %}
                                            <span class="text-muted">Non définie</span>
                                        {% endif %}
                                    </td>

                                    <td class="text-center">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-1 js-edit-utilisateur"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editUtilisateurModal"
                                                data-url="{{ path('app_utilisateur_edit', {'id': u.id}) }}">
                                            <i class="ri-edit-line me-1"></i>
                                            Modifier
                                        </button>

                                        <a class="btn btn-sm btn-primary rounded-pill px-3"
                                           href="{{ path('app_utilisateur_show', {'id': u.id}) }}">
                                            <i class="ri-eye-line me-1"></i>
                                            Voir
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-5">
                    <div class="mb-3">
                        <div class="rounded-circle bg-light d-inline-flex justify-content-center align-items-center"
                             style="width: 70px; height: 70px;">
                            <i class="ri-team-line fs-2 text-muted"></i>
                        </div>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Aucun utilisateur enregistré</h5>
                    <p class="text-muted mb-4">
                        Commencez par créer un nouvel utilisateur pour alimenter la plateforme.
                    </p>
                    <button class="btn btn-primary rounded-pill px-4"
                            data-bs-toggle="modal"
                            data-bs-target="#addUtilisateurModal">
                        <i class="ri-user-add-line me-1"></i>
                        Nouvel utilisateur
                    </button>
                </div>
            {% endif %}

        </div>
    </div>
</div>

{# =========================
   MODAL AJOUT UTILISATEUR
========================= #}
<div class="modal fade" id="addUtilisateurModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 px-4 pt-4 pb-2">
                <div>
                    <h5 class="modal-title fw-bold text-dark mb-1">
                        <i class="ri-user-add-line me-1 text-primary"></i>
                        Nouvel utilisateur
                    </h5>
                    <small class="text-muted">Création d’un nouveau compte utilisateur</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4 pb-4">
                {{ form_start(form, {'attr': {'id': 'UtilisateurForm'}}) }}

                <div class="row g-3">
                    <div class="col-md-6">
                        {{ form_row(form.nom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.prenom) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.username) }}
                    </div>
                    <div class="col-md-6">
                        {% if form.plainPassword is defined %}
                            {{ form_row(form.plainPassword) }}
                        {% else %}
                            {{ form_row(form.hashPassword) }}
                        {% endif %}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.statut) }}
                    </div>
                    <div class="col-md-6">
                        {{ form_row(form.roles) }}
                    </div>
                    <div class="col-md-12">
                        {{ form_row(form.serviceMedical) }}
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="button" class="btn btn-light rounded-pill px-4 border" data-bs-dismiss="modal">
                        Annuler
                    </button>
                    <button type="submit" class="btn btn-success rounded-pill px-4">
                        <i class="ri-save-line me-1"></i>
                        Enregistrer
                    </button>
                </div>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{# =========================
   MODAL EDIT UTILISATEUR
========================= #}
<div class="modal fade" id="editUtilisateurModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 px-4 pt-4 pb-2">
                <div>
                    <h5 class="modal-title fw-bold text-dark mb-1">
                        <i class="ri-edit-line me-1 text-primary"></i>
                        Modifier utilisateur
                    </h5>
                    <small class="text-muted">Mise à jour des informations utilisateur</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body px-4 pb-4">
                <div class="text-center py-5" id="editUtilisateurLoader">
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="mt-3 text-muted">Chargement du formulaire...</div>
                </div>

                <div id="editUtilisateurModalBody" class="d-none"></div>
            </div>
        </div>
    </div>
</div>
{% endblock %}