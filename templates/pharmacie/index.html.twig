{% extends 'base.html.twig' %}

{% block title %}Pharmacie{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h3 class="mb-1 fw-bold">
                <i class="ri-capsule-line me-2 text-primary"></i> Tableau de bord - Pharmacie
            </h3>
            <p class="text-muted mb-0">
                Vue d’ensemble des médicaments, stocks, lots, ventes et alertes.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_medicament_index') }}" class="btn btn-primary">
                <i class="ri-medicine-bottle-line me-1"></i> Médicaments
            </a>
            <a href="{{ path('app_lot_index') }}" class="btn btn-outline-primary">
                <i class="ri-archive-line me-1"></i> Lots
            </a>
            <a href="{{ path('app_caisse_index') }}" class="btn btn-success">
                <i class="ri-money-dollar-circle-line me-1"></i> Caisse
            </a>
        </div>
    </div>

    {# ======================= KPIs ======================= #}
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center me-3"
                         style="width:56px;height:56px;">
                        <i class="ri-capsule-line fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Médicaments</div>
                        <h4 class="mb-0 fw-bold">{{ totalMedicaments|default(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-info-subtle text-info d-flex align-items-center justify-content-center me-3"
                         style="width:56px;height:56px;">
                        <i class="ri-stack-line fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Lots actifs</div>
                        <h4 class="mb-0 fw-bold">{{ totalLots|default(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center me-3"
                         style="width:56px;height:56px;">
                        <i class="ri-error-warning-line fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Stocks faibles</div>
                        <h4 class="mb-0 fw-bold">{{ lowStockCount|default(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center me-3"
                         style="width:56px;height:56px;">
                        <i class="ri-alarm-warning-line fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Lots proches péremption</div>
                        <h4 class="mb-0 fw-bold">{{ nearExpirationCount|default(0) }}</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ======================= CA / VENTES ======================= #}
    <div class="row g-3 mb-4">
        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h5 class="mb-0 fw-semibold">
                        <i class="ri-shopping-cart-2-line me-2 text-success"></i> Activité du jour
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="border rounded-3 p-3 bg-light h-100">
                                <div class="text-muted small">Ventes du jour</div>
                                <div class="fs-4 fw-bold text-success">{{ ventesToday|default(0) }}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded-3 p-3 bg-light h-100">
                                <div class="text-muted small">Chiffre d’affaires</div>
                                <div class="fs-4 fw-bold text-primary">
                                    {{ chiffreAffairesToday|default(0)|number_format(0, ',', ' ') }} FCFA
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <div class="d-flex flex-wrap gap-2">
                        <a href="{{ path('app_caisse_index') }}" class="btn btn-success btn-sm">
                            <i class="ri-money-dollar-circle-line me-1"></i> Ouvrir la caisse
                        </a>
                        <a href="{{ path('app_lot_index') }}" class="btn btn-outline-secondary btn-sm">
                            <i class="ri-archive-2-line me-1"></i> Gérer les lots
                        </a>
                        <a href="{{ path('app_medicament_index') }}" class="btn btn-outline-primary btn-sm">
                            <i class="ri-capsule-line me-1"></i> Voir le stock
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pb-0">
                    <h5 class="mb-0 fw-semibold">
                        <i class="ri-notification-3-line me-2 text-danger"></i> Alertes
                    </h5>
                </div>
                <div class="card-body">
                    {% set totalAlertes = (lowStockCount|default(0)) + (nearExpirationCount|default(0)) %}
                    {% if totalAlertes > 0 %}
                        <div class="alert alert-warning border-0">
                            <i class="ri-alert-line me-1"></i>
                            <strong>{{ totalAlertes }}</strong> alerte(s) nécessitent une attention.
                        </div>
                    {% else %}
                        <div class="alert alert-success border-0">
                            <i class="ri-checkbox-circle-line me-1"></i>
                            Aucune alerte critique pour le moment.
                        </div>
                    {% endif %}

                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center border rounded-3 p-3">
                            <span>
                                <i class="ri-error-warning-line text-warning me-2"></i>
                                Produits en stock faible
                            </span>
                            <span class="badge bg-warning text-dark">{{ lowStockCount|default(0) }}</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center border rounded-3 p-3">
                            <span>
                                <i class="ri-alarm-warning-line text-danger me-2"></i>
                                Lots proches de péremption
                            </span>
                            <span class="badge bg-danger">{{ nearExpirationCount|default(0) }}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ======================= DETAILS ======================= #}
    <div class="row g-3">
        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0 fw-semibold">
                        <i class="ri-error-warning-line me-2 text-warning"></i> Médicaments à stock faible
                    </h5>
                </div>
                <div class="card-body">
                    {% if lowStockMedicaments is defined and lowStockMedicaments|length > 0 %}
                        <div class="table-responsive">
                            <table class="table align-middle table-hover mb-0 datatable-mi">
                                <thead class="table-light">
                                    <tr>
                                        <th>Médicament</th>
                                        <th>Stock disponible</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for item in lowStockMedicaments %}
                                        <tr>
                                            <td>{{ item.nom }}</td>
                                            <td>{{ item.quantite }}</td>
                                            <td>
                                                <span class="badge bg-warning text-dark">Faible</span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-4">
                            <i class="ri-inbox-line fs-2 d-block mb-2"></i>
                            Aucun médicament en stock faible.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0 fw-semibold">
                        <i class="ri-calendar-close-line me-2 text-danger"></i> Lots proches de péremption
                    </h5>
                </div>
                <div class="card-body">
                    {% if nearExpirationLots is defined and nearExpirationLots|length > 0 %}
                        <div class="table-responsive">
                            <table class="table align-middle table-hover mb-0 datatable-mi">
                                <thead class="table-light">
                                    <tr>
                                        <th>Médicament</th>
                                        <th>Lot</th>
                                        <th>Péremption</th>
                                        <th>Qté</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for lot in nearExpirationLots %}
                                        <tr>
                                            <td>{{ lot.medicament.nom ?? '—' }}</td>
                                            <td>{{ lot.numeroLot ?? lot.id }}</td>
                                            <td>
                                                {{ lot.datePeremption ? lot.datePeremption|date('d/m/Y') : '—' }}
                                            </td>
                                            <td>{{ lot.quantite }}</td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="text-center text-muted py-4">
                            <i class="ri-shield-check-line fs-2 d-block mb-2"></i>
                            Aucun lot proche de péremption.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ======================= RACCOURCIS ======================= #}
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0">
                    <h5 class="mb-0 fw-semibold">
                        <i class="ri-flashlight-line me-2 text-primary"></i> Accès rapides
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <a href="{{ path('app_medicament_index') }}" class="text-decoration-none">
                                <div class="border rounded-3 p-3 h-100 hover-shadow">
                                    <h6 class="fw-bold mb-1 text-dark">Médicaments</h6>
                                    <p class="text-muted mb-0">Créer, modifier et consulter la liste des médicaments.</p>
                                </div>
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="{{ path('app_lot_index') }}" class="text-decoration-none">
                                <div class="border rounded-3 p-3 h-100 hover-shadow">
                                    <h6 class="fw-bold mb-1 text-dark">Lots</h6>
                                    <p class="text-muted mb-0">Suivre les quantités, numéros de lots et dates de péremption.</p>
                                </div>
                            </a>
                        </div>
                        <div class="col-12 col-md-4">
                            <a href="{{ path('app_caisse_index') }}" class="text-decoration-none">
                                <div class="border rounded-3 p-3 h-100 hover-shadow">
                                    <h6 class="fw-bold mb-1 text-dark">Caisse</h6>
                                    <p class="text-muted mb-0">Enregistrer les ventes et consulter l’historique des encaissements.</p>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow {
        transition: all .2s ease-in-out;
    }
    .hover-shadow:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.08);
    }
</style>
{% endblock %}