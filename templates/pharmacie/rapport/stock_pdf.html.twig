<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport de Stock</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: sans-serif; font-size: 11px; color: #333; padding: 20px; }
        .header { text-align: center; margin-bottom: 20px; border-bottom: 2px solid #0d6efd; padding-bottom: 15px; }
        .header h1 { font-size: 18px; color: #0d6efd; margin-bottom: 4px; }
        .header p { font-size: 11px; color: #666; }
        .kpi-row { display: table; width: 100%; margin-bottom: 15px; }
        .kpi { display: table-cell; text-align: center; padding: 8px; border: 1px solid #dee2e6; }
        .kpi .label { font-size: 9px; color: #888; text-transform: uppercase; }
        .kpi .value { font-size: 16px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background: #f8f9fa; font-size: 9px; text-transform: uppercase; color: #555; padding: 6px 4px; border: 1px solid #dee2e6; text-align: left; }
        td { padding: 5px 4px; border: 1px solid #dee2e6; font-size: 10px; }
        .text-center { text-align: center; }
        .text-end { text-align: right; }
        .text-success { color: #198754; }
        .text-danger { color: #dc3545; }
        .text-primary { color: #0d6efd; }
        .fw-bold { font-weight: bold; }
        tfoot td { background: #f8f9fa; font-weight: bold; }
        .footer { margin-top: 20px; text-align: center; font-size: 9px; color: #999; border-top: 1px solid #dee2e6; padding-top: 10px; }
        .badge-danger { background: #dc3545; color: white; padding: 1px 5px; border-radius: 3px; font-size: 9px; }
        .badge-warning { background: #ffc107; color: #333; padding: 1px 5px; border-radius: 3px; font-size: 9px; }
    </style>
</head>
<body>

<div class="header">
    <h1>RAPPORT DE STOCK</h1>
    <p>Période : {{ date_debut|date('d/m/Y') }} — {{ date_fin|date('d/m/Y') }}</p>
    <p>Généré le {{ 'now'|date('d/m/Y à H:i') }}</p>
</div>

{% set totalStock = 0 %}
{% set totalEntrees = 0 %}
{% set totalSorties = 0 %}
{% set totalValeur = 0 %}
{% for r in resultats %}
    {% set totalStock = totalStock + r.stock_actuel %}
    {% set totalEntrees = totalEntrees + r.entrees_periode %}
    {% set totalSorties = totalSorties + r.sorties_periode %}
    {% set totalValeur = totalValeur + (r.stock_actuel * r.prix_unitaire) %}
{% endfor %}

<div class="kpi-row">
    <div class="kpi">
        <div class="label">Médicaments</div>
        <div class="value">{{ resultats|length }}</div>
    </div>
    <div class="kpi">
        <div class="label">Entrées</div>
        <div class="value text-success">{{ totalEntrees }}</div>
    </div>
    <div class="kpi">
        <div class="label">Sorties</div>
        <div class="value text-danger">{{ totalSorties }}</div>
    </div>
    <div class="kpi">
        <div class="label">Valeur stock</div>
        <div class="value text-primary">{{ totalValeur|number_format(0, ',', ' ') }} F</div>
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>Médicament</th>
            <th>SKU</th>
            <th class="text-center">Lots</th>
            <th class="text-center">Stock</th>
            <th class="text-center">Entrées</th>
            <th class="text-center">Sorties</th>
            <th class="text-end">Prix unit.</th>
            <th class="text-end">Valeur</th>
            <th>Péremption</th>
        </tr>
    </thead>
    <tbody>
        {% for r in resultats %}
            <tr>
                <td class="fw-bold">{{ r.medicament_nom }}</td>
                <td>{{ r.sku ?? '—' }}</td>
                <td class="text-center">{{ r.nb_lots }}</td>
                <td class="text-center fw-bold">{{ r.stock_actuel }}</td>
                <td class="text-center text-success">{% if r.entrees_periode > 0 %}+{{ r.entrees_periode }}{% else %}—{% endif %}</td>
                <td class="text-center text-danger">{% if r.sorties_periode > 0 %}-{{ r.sorties_periode }}{% else %}—{% endif %}</td>
                <td class="text-end">{{ r.prix_unitaire|number_format(0, ',', ' ') }} F</td>
                <td class="text-end fw-bold">{{ (r.stock_actuel * r.prix_unitaire)|number_format(0, ',', ' ') }} F</td>
                <td>
                    {% if r.prochaine_peremption %}
                        {% set peremption = r.prochaine_peremption|date('U') %}
                        {% set now = 'now'|date('U') %}
                        {% if peremption < now %}
                            <span class="badge-danger">{{ r.prochaine_peremption|date('d/m/Y') }}</span>
                        {% elseif (peremption - now) < 7776000 %}
                            <span class="badge-warning">{{ r.prochaine_peremption|date('d/m/Y') }}</span>
                        {% else %}
                            {{ r.prochaine_peremption|date('d/m/Y') }}
                        {% endif %}
                    {% else %}
                        —
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="fw-bold">TOTAL</td>
            <td class="text-center">{{ totalStock }}</td>
            <td class="text-center text-success">{{ totalEntrees }}</td>
            <td class="text-center text-danger">{{ totalSorties }}</td>
            <td></td>
            <td class="text-end text-primary">{{ totalValeur|number_format(0, ',', ' ') }} F</td>
            <td></td>
        </tr>
    </tfoot>
</table>

<div class="footer">
    Clinique Nassarawa — Rapport de stock généré automatiquement
</div>

</body>
</html>
