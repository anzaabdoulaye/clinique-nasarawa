{% extends 'base.html.twig' %}

{% block title %}Rapports Pharmacie{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="ri-file-chart-line me-2 text-primary"></i>
                Rapports Pharmacie
            </h2>
            <p class="text-muted mb-0">Générez des rapports de stock et de ventes sur une période choisie.</p>
        </div>
        <a href="{{ path('app_pharmacie_index') }}" class="btn btn-outline-secondary">
            <i class="ri-arrow-left-line me-1"></i> Retour pharmacie
        </a>
    </div>

    <div class="row g-4">

        {# Rapport Stock #}
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-success-subtle text-success d-flex justify-content-center align-items-center"
                             style="width: 56px; height: 56px;">
                            <i class="ri-archive-drawer-line fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Rapport de Stock</h5>
                            <p class="text-muted small mb-0">
                                État du stock actuel avec les mouvements (entrées/sorties) sur la période sélectionnée.
                            </p>
                        </div>
                    </div>
                    <ul class="list-unstyled text-muted small mb-4">
                        <li><i class="ri-check-line text-success me-1"></i> Stock actuel par médicament</li>
                        <li><i class="ri-check-line text-success me-1"></i> Entrées et sorties sur la période</li>
                        <li><i class="ri-check-line text-success me-1"></i> Dates de péremption</li>
                        <li><i class="ri-check-line text-success me-1"></i> Export PDF</li>
                    </ul>
                    <a href="{{ path('app_rapport_pharmacie_stock') }}" class="btn btn-success w-100">
                        <i class="ri-bar-chart-box-line me-1"></i> Générer le rapport
                    </a>
                </div>
            </div>
        </div>

        {# Rapport Ventes #}
        <div class="col-12 col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="rounded-circle bg-primary-subtle text-primary d-flex justify-content-center align-items-center"
                             style="width: 56px; height: 56px;">
                            <i class="ri-shopping-cart-2-line fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-1">Rapport de Ventes</h5>
                            <p class="text-muted small mb-0">
                                Détail des ventes par médicament avec chiffre d'affaires sur la période.
                            </p>
                        </div>
                    </div>
                    <ul class="list-unstyled text-muted small mb-4">
                        <li><i class="ri-check-line text-primary me-1"></i> Ventes par médicament</li>
                        <li><i class="ri-check-line text-primary me-1"></i> Quantités vendues</li>
                        <li><i class="ri-check-line text-primary me-1"></i> Chiffre d'affaires</li>
                        <li><i class="ri-check-line text-primary me-1"></i> Export PDF</li>
                    </ul>
                    <a href="{{ path('app_rapport_pharmacie_ventes') }}" class="btn btn-primary w-100">
                        <i class="ri-line-chart-line me-1"></i> Générer le rapport
                    </a>
                </div>
            </div>
        </div>

    </div>

    {# ======================= RAPPORTS MENSUELS PDF ======================= #}
    {% set moisNoms = ['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'] %}
    {% set anneeCourante = "now"|date("Y")|number_format(0,'','') %}
    {% set anneeChoisie = app.request.query.get('annee', anneeCourante)|number_format(0,'','') %}
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h5 class="mb-0 fw-bold">
                        <i class="ri-calendar-2-line me-2 text-warning"></i> Rapports mensuels PDF — {{ anneeChoisie }}
                    </h5>
                    <div class="d-flex align-items-center gap-2">
                        <a href="{{ path('app_rapport_pharmacie_index', {annee: anneeChoisie - 1}) }}"
                           class="btn btn-sm btn-outline-secondary" title="Année précédente">
                            <i class="ri-arrow-left-s-line"></i> {{ anneeChoisie - 1 }}
                        </a>
                        {% if anneeChoisie < anneeCourante %}
                            <a href="{{ path('app_rapport_pharmacie_index', {annee: anneeChoisie + 1}) }}"
                               class="btn btn-sm btn-outline-secondary" title="Année suivante">
                                {{ anneeChoisie + 1 }} <i class="ri-arrow-right-s-line"></i>
                            </a>
                        {% endif %}
                        {% if anneeChoisie != anneeCourante %}
                            <a href="{{ path('app_rapport_pharmacie_index') }}"
                               class="btn btn-sm btn-outline-primary" title="Revenir à l'année en cours">
                                <i class="ri-refresh-line me-1"></i> {{ anneeCourante }}
                            </a>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table align-middle table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:5%;">#</th>
                                    <th>Mois</th>
                                    <th>Période</th>
                                    <th class="text-end">Rapports PDF</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for m in 1..12 %}
                                    {% set moisNum = m < 10 ? '0' ~ m : m %}
                                    {% set debut = anneeChoisie ~ '-' ~ moisNum ~ '-01' %}
                                    {% set dernierJour = debut|date_modify('last day of this month')|date('Y-m-d') %}
                                    {% set isFutur = debut|date('Y-m') > "now"|date('Y-m') %}
                                    <tr{% if debut|date('Y-m') == "now"|date('Y-m') %} class="table-warning"{% endif %}>
                                        <td class="fw-bold text-muted">{{ moisNum }}</td>
                                        <td class="fw-semibold">{{ moisNoms[m - 1] }} {{ anneeChoisie }}</td>
                                        <td class="text-muted small">{{ debut|date('d/m/Y') }} — {{ dernierJour|date('d/m/Y') }}</td>
                                        <td class="text-end">
                                            {% if not isFutur %}
                                                <a href="{{ path('app_rapport_pharmacie_stock_pdf', {date_debut: debut, date_fin: dernierJour}) }}"
                                                   class="btn btn-sm btn-outline-success me-1" target="_blank"
                                                   title="Rapport stock — {{ moisNoms[m - 1] }}">
                                                    <i class="ri-archive-drawer-line me-1"></i> Stock
                                                </a>
                                                <a href="{{ path('app_rapport_pharmacie_ventes_pdf', {date_debut: debut, date_fin: dernierJour}) }}"
                                                   class="btn btn-sm btn-outline-primary" target="_blank"
                                                   title="Rapport ventes — {{ moisNoms[m - 1] }}">
                                                    <i class="ri-shopping-cart-2-line me-1"></i> Ventes
                                                </a>
                                            {% else %}
                                                <span class="text-muted small fst-italic">À venir</span>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
