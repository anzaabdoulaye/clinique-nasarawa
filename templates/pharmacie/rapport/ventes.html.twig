{% extends 'base.html.twig' %}

{% block title %}Rapport de Ventes{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {# Header #}
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1 text-dark">
                <i class="ri-shopping-cart-2-line me-2 text-primary"></i>
                Rapport de Ventes
            </h2>
            <p class="text-muted mb-0">Détail des ventes pharmacie sur la période sélectionnée.</p>
        </div>
        <a href="{{ path('app_rapport_pharmacie_index') }}" class="btn btn-outline-secondary">
            <i class="ri-arrow-left-line me-1"></i> Retour aux rapports
        </a>
    </div>

    {# Formulaire de sélection de période #}
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <form method="GET" action="{{ path('app_rapport_pharmacie_ventes') }}" class="row g-3 align-items-end">
                <div class="col-12 col-md-4">
                    <label for="date_debut" class="form-label fw-semibold">Date début</label>
                    <input type="date" class="form-control" id="date_debut" name="date_debut"
                           value="{{ date_debut ? date_debut|date('Y-m-d') : '' }}" required>
                </div>
                <div class="col-12 col-md-4">
                    <label for="date_fin" class="form-label fw-semibold">Date fin</label>
                    <input type="date" class="form-control" id="date_fin" name="date_fin"
                           value="{{ date_fin ? date_fin|date('Y-m-d') : '' }}" required>
                </div>
                <div class="col-12 col-md-4">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="ri-search-line me-1"></i> Générer
                        </button>
                        {% if resultats is not null %}
                            <a href="{{ path('app_rapport_pharmacie_ventes_pdf', {
                                date_debut: date_debut|date('Y-m-d'),
                                date_fin: date_fin|date('Y-m-d')
                            }) }}" class="btn btn-outline-danger" target="_blank">
                                <i class="ri-file-pdf-2-line me-1"></i> PDF
                            </a>
                        {% endif %}
                    </div>
                </div>
            </form>
        </div>
    </div>

    {# Résultats #}
    {% if resultats is not null %}

        {# KPI cards #}
        <div class="row g-3 mb-4">
            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body text-center py-3">
                        <small class="text-muted d-block mb-1">Nombre de ventes</small>
                        <h3 class="fw-bold text-dark mb-0">{{ totaux.nb_ventes }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body text-center py-3">
                        <small class="text-muted d-block mb-1">Médicaments vendus</small>
                        <h3 class="fw-bold text-primary mb-0">{{ resultats|length }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body text-center py-3">
                        <small class="text-muted d-block mb-1">Quantité totale</small>
                        <h3 class="fw-bold text-success mb-0">{{ totaux.total_quantite }}</h3>
                    </div>
                </div>
            </div>
            <div class="col-6 col-xl-3">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body text-center py-3">
                        <small class="text-muted d-block mb-1">Chiffre d'affaires</small>
                        <h3 class="fw-bold text-primary mb-0">{{ totaux.total_montant|number_format(0, ',', ' ') }}</h3>
                        <small class="text-muted">FCFA</small>
                    </div>
                </div>
            </div>
        </div>

        {# Tableau #}
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-0 pt-4 pb-3 px-4">
                <h5 class="fw-semibold mb-0">
                    Ventes par médicament — {{ date_debut|date('d/m/Y') }} au {{ date_fin|date('d/m/Y') }}
                </h5>
            </div>
            <div class="card-body px-4 pb-4">
                {% if resultats|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0 datatable">
                            <thead class="table-light">
                                <tr>
                                    <th class="fw-semibold">#</th>
                                    <th class="fw-semibold">Médicament</th>
                                    <th class="fw-semibold">SKU</th>
                                    <th class="fw-semibold text-center">Nb ventes</th>
                                    <th class="fw-semibold text-center">Quantité vendue</th>
                                    <th class="fw-semibold text-end">Montant total</th>
                                    <th class="fw-semibold text-end">% du CA</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for r in resultats %}
                                    <tr>
                                        <td>{{ loop.index }}</td>
                                        <td class="fw-semibold">{{ r.medicament_nom }}</td>
                                        <td><span class="text-muted">{{ r.sku ?? '—' }}</span></td>
                                        <td class="text-center">{{ r.nb_ventes }}</td>
                                        <td class="text-center">
                                            <span class="badge bg-primary-subtle text-primary border px-3 py-2">{{ r.quantite_vendue }}</span>
                                        </td>
                                        <td class="text-end fw-bold">{{ r.montant_total|number_format(0, ',', ' ') }} F</td>
                                        <td class="text-end">
                                            {% if totaux.total_montant > 0 %}
                                                {{ ((r.montant_total / totaux.total_montant) * 100)|number_format(1) }}%
                                            {% else %}
                                                —
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                            <tfoot class="table-light">
                                <tr class="fw-bold">
                                    <td colspan="3">TOTAL</td>
                                    <td class="text-center">{{ totaux.nb_ventes }}</td>
                                    <td class="text-center">{{ totaux.total_quantite }}</td>
                                    <td class="text-end text-primary">{{ totaux.total_montant|number_format(0, ',', ' ') }} F</td>
                                    <td class="text-end">100%</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                {% else %}
                    <div class="text-center py-5">
                        <i class="ri-shopping-cart-line fs-1 text-muted"></i>
                        <h5 class="fw-bold text-dark mt-3 mb-2">Aucune vente sur cette période</h5>
                        <p class="text-muted">Aucune vente n'a été enregistrée entre ces deux dates.</p>
                    </div>
                {% endif %}
            </div>
        </div>

    {% elseif resultats is null %}
        <div class="text-center py-5">
            <div class="rounded-circle bg-light d-inline-flex justify-content-center align-items-center mb-3"
                 style="width: 70px; height: 70px;">
                <i class="ri-calendar-line fs-2 text-muted"></i>
            </div>
            <h5 class="fw-bold text-dark mb-2">Sélectionnez une période</h5>
            <p class="text-muted">Choisissez les dates de début et fin pour générer le rapport de ventes.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
