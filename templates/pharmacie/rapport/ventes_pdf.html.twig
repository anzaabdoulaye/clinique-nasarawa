<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Rapport de Ventes</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: sans-serif; font-size: 11px; color: #333; padding: 20px; }
        .header { text-align: center; margin-bottom: 20px; border-bottom: 2px solid #0d6efd; padding-bottom: 15px; }
        .header h1 { font-size: 18px; color: #0d6efd; margin-bottom: 4px; }
        .header p { font-size: 11px; color: #666; }
        .kpi-row { display: table; width: 100%; margin-bottom: 15px; }
        .kpi { display: table-cell; text-align: center; padding: 8px; border: 1px solid #dee2e6; }
        .kpi .label { font-size: 9px; color: #888; text-transform: uppercase; }
        .kpi .value { font-size: 16px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th { background: #f8f9fa; font-size: 9px; text-transform: uppercase; color: #555; padding: 6px 4px; border: 1px solid #dee2e6; text-align: left; }
        td { padding: 5px 4px; border: 1px solid #dee2e6; font-size: 10px; }
        .text-center { text-align: center; }
        .text-end { text-align: right; }
        .text-primary { color: #0d6efd; }
        .fw-bold { font-weight: bold; }
        tfoot td { background: #f8f9fa; font-weight: bold; }
        .footer { margin-top: 20px; text-align: center; font-size: 9px; color: #999; border-top: 1px solid #dee2e6; padding-top: 10px; }
    </style>
</head>
<body>

<div class="header">
    <h1>RAPPORT DE VENTES — PHARMACIE</h1>
    <p>Période : {{ date_debut|date('d/m/Y') }} — {{ date_fin|date('d/m/Y') }}</p>
    <p>Généré le {{ 'now'|date('d/m/Y à H:i') }}</p>
</div>

<div class="kpi-row">
    <div class="kpi">
        <div class="label">Nombre de ventes</div>
        <div class="value">{{ totaux.nb_ventes }}</div>
    </div>
    <div class="kpi">
        <div class="label">Médicaments vendus</div>
        <div class="value">{{ resultats|length }}</div>
    </div>
    <div class="kpi">
        <div class="label">Quantité totale</div>
        <div class="value">{{ totaux.total_quantite }}</div>
    </div>
    <div class="kpi">
        <div class="label">Chiffre d'affaires</div>
        <div class="value text-primary">{{ totaux.total_montant|number_format(0, ',', ' ') }} F</div>
    </div>
</div>

<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Médicament</th>
            <th>SKU</th>
            <th class="text-center">Nb ventes</th>
            <th class="text-center">Quantité</th>
            <th class="text-end">Montant</th>
            <th class="text-end">% CA</th>
        </tr>
    </thead>
    <tbody>
        {% for r in resultats %}
            <tr>
                <td>{{ loop.index }}</td>
                <td class="fw-bold">{{ r.medicament_nom }}</td>
                <td>{{ r.sku ?? '—' }}</td>
                <td class="text-center">{{ r.nb_ventes }}</td>
                <td class="text-center">{{ r.quantite_vendue }}</td>
                <td class="text-end fw-bold">{{ r.montant_total|number_format(0, ',', ' ') }} F</td>
                <td class="text-end">
                    {% if totaux.total_montant > 0 %}
                        {{ ((r.montant_total / totaux.total_montant) * 100)|number_format(1) }}%
                    {% else %}
                        —
                    {% endif %}
                </td>
            </tr>
        {% endfor %}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="3" class="fw-bold">TOTAL</td>
            <td class="text-center">{{ totaux.nb_ventes }}</td>
            <td class="text-center">{{ totaux.total_quantite }}</td>
            <td class="text-end text-primary">{{ totaux.total_montant|number_format(0, ',', ' ') }} F</td>
            <td class="text-end">100%</td>
        </tr>
    </tfoot>
</table>

<div class="footer">
    Clinique Nassarawa — Rapport de ventes pharmacie généré automatiquement
</div>

</body>
</html>
