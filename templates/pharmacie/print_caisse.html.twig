<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Facture #{{ vente.id }}</title>
    <style>
        @page {
            size: A5 portrait;
            margin: 5mm;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: DejaVu Sans, Arial, sans-serif;
            font-size: 9.5px;
            color: #1f2937;
        }

        .document {
            width: 100%;
        }

        .top-bar {
            height: 4px;
            background: #0f4c81;
            margin-bottom: 6px;
        }

        .header-table,
        .meta-table,
        .bottom-table,
        .footer-table,
        .items-table,
        .totals-table {
            width: 100%;
            border-collapse: collapse;
        }

        .header-table td,
        .meta-table td,
        .bottom-table td,
        .footer-table td {
            vertical-align: top;
        }

        .clinic-logo {
            width: 24mm;
            height: 24mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #ffffff;
            border-radius: 50%;
        }

        .clinic h1 {
            margin: 0 0 3px 0;
            font-size: 13px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
        }

        .clinic .sub {
            color: #6b7280;
            font-size: 8px;
            line-height: 1.3;
            margin-bottom: 3px;
        }

        .clinic div {
            margin: 1px 0;
            line-height: 1.3;
            font-size: 8px;
        }

        .invoice-box {
            width: 32mm;
            border: 1px solid #d1d5db;
            padding: 5px;
            text-align: center;
            background: #f8fafc;
        }

        .invoice-box .title {
            font-size: 12px;
            font-weight: bold;
            color: #0f4c81;
            text-transform: uppercase;
            margin-bottom: 3px;
        }

        .invoice-box .ref {
            font-size: 10px;
            font-weight: bold;
        }

        .separator {
            border-bottom: 1px solid #d1d5db;
            margin: 6px 0;
        }

        .meta-table td {
            width: 50%;
            padding-right: 4px;
        }

        .box {
            border: 1px solid #d1d5db;
            padding: 5px 6px;
            min-height: 66px;
        }

        .box h3,
        .notes h3 {
            margin: 0 0 4px 0;
            font-size: 9px;
            color: #0f4c81;
            text-transform: uppercase;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 2px;
        }

        .box p,
        .notes p {
            margin: 2px 0;
            line-height: 1.3;
            font-size: 8.5px;
        }

        .label {
            color: #6b7280;
            font-weight: bold;
        }

        .table-wrap {
            margin-top: 6px;
            margin-bottom: 6px;
            border: 1px solid #d1d5db;
        }

        .items-table th {
            background: #0f4c81;
            color: #ffffff;
            padding: 4px;
            font-size: 8.5px;
            text-align: left;
        }

        .items-table td {
            padding: 4px;
            border-top: 1px solid #e5e7eb;
            vertical-align: top;
            font-size: 8.5px;
        }

        .center {
            text-align: center;
        }

        .right {
            text-align: right;
        }

        .notes {
            border: 1px solid #d1d5db;
            padding: 5px 6px;
            min-height: 68px;
            margin-right: 6px;
        }

        .totals-box {
            width: 100%;
            border: 1px solid #d1d5db;
        }

        .totals-table th,
        .totals-table td {
            padding: 5px 6px;
            border-top: 1px solid #e5e7eb;
            font-size: 8.5px;
        }

        .totals-table tr:first-child th,
        .totals-table tr:first-child td {
            border-top: none;
        }

        .grand-total th,
        .grand-total td {
            background: #0f4c81;
            color: #ffffff;
            font-weight: bold;
            font-size: 9.5px;
        }

        .footer-block {
            border-top: 1px dashed #d1d5db;
            margin-top: 6px;
            padding-top: 6px;
        }

        .footer-left {
            font-size: 8px;
            color: #6b7280;
            line-height: 1.3;
            padding-right: 6px;
        }

        .qr {
            text-align: center;
            width: 28mm;
        }

        .qr img {
            width: 20mm;
            height: 20mm;
            border: 1px solid #d1d5db;
            padding: 2px;
            background: #fff;
        }

        .qr small {
            display: block;
            margin-top: 2px;
            font-size: 7px;
            color: #6b7280;
            line-height: 1.2;
        }

        .sign {
            width: 30mm;
            text-align: center;
            font-size: 8px;
            color: #6b7280;
        }

        .sign-line {
            margin-top: 18px;
            border-top: 1px solid #000;
            padding-top: 3px;
        }
    </style>
</head>
<body>
<div class="document">
    <div class="top-bar"></div>

    <table class="header-table">
        <tr>
            <td style="width:18%;">
                {% if logo_path is defined and logo_path %}
                        <img src="{{ absolute_url(asset('logo.jpeg')) }}" alt="Logo Clinique Nassarawa" class="clinic-logo">
                    {% endif %}
            </td>

            <td style="width:52%;">
                <div class="clinic">
                    <h1>Clinique Médicale Nassarawa</h1>
                    <div class="sub">Facturation / Caisse</div>
                    <div><strong>NIF :</strong> 120402/R</div>
                    <div><strong>RCCM :</strong> NE-NIM-01-2024-B12-00145</div>
                    <div><strong>Adresse :</strong> Yantala Haut, Avenue du Daoura YN 187, Niamey</div>
                    <div><strong>Tél :</strong> 20 75 51 02 / 88 05 22 20</div>
                    <div><strong>BP :</strong> 2120 Niamey</div>
                    <div><strong>Email :</strong> nassrawaclinique@gmail.com</div>
                </div>
            </td>

            <td style="width:30%; text-align:right;">
                <div class="invoice-box">
                    <div class="title">Facture</div>
                    <div class="ref">N° {{ vente.id }}</div>
                </div>
            </td>
        </tr>
    </table>

    <div class="separator"></div>

    <table class="meta-table">
        <tr>
            <td>
                <div class="box">
                    <h3>Informations</h3>
                    <p><span class="label">Référence :</span> FACT-{{ vente.id }}</p>
                    <p><span class="label">Date :</span> {{ vente.date ? vente.date|date('d/m/Y H:i') : '–' }}</p>
                    <p>
                        <span class="label">Vendeur :</span>
                        {% if vente.vendeur %}
                            {{ vente.vendeur.nomComplet ?? vente.vendeur.userIdentifier ?? '-' }}
                        {% else %}
                            -
                        {% endif %}
                    </p>
                    <p><span class="label">Nature :</span> Vente pharmacie</p>
                </div>
            </td>
            <td>
                <div class="box">
                    <h3>Client / Patient</h3>
                    <p>
                        <span class="label">Nom :</span>
                        {{ vente.patient.nomComplet ?? vente.patient.nom ?? 'Patient non renseigné' }}
                    </p>
                    <p><span class="label">Téléphone :</span> {{ vente.patient.telephone ?? '–' }}</p>
                    <p><span class="label">Adresse :</span> {{ vente.patient.adresse ?? '–' }}</p>
                    <p><span class="label">Observation :</span> Achat de médicaments</p>
                </div>
            </td>
        </tr>
    </table>

    <div class="table-wrap">
        <table class="items-table">
            <thead>
                <tr>
                    <th style="width:8%;" class="center">#</th>
                    <th style="width:42%;">Produit</th>
                    <th style="width:12%;" class="center">Qté</th>
                    <th style="width:18%;" class="right">PU</th>
                    <th style="width:20%;" class="right">Total</th>
                </tr>
            </thead>
            <tbody>
            {% for ligne in vente.lignes %}
                <tr>
                    <td class="center">{{ loop.index }}</td>
                    <td>
                        {{ ligne.medicament.nom }}
                        {% if ligne.medicament.codeBarre %}
                            <br><span style="color:#6b7280; font-size:7px;">CB : {{ ligne.medicament.codeBarre }}</span>
                        {% endif %}
                    </td>
                    <td class="center">{{ ligne.quantite }}</td>
                    <td class="right">{{ ligne.prixUnitaire|number_format(0, ',', ' ') }}</td>
                    <td class="right"><strong>{{ ligne.sousTotal|number_format(0, ',', ' ') }}</strong></td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="center">Aucune ligne enregistrée</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <table class="bottom-table">
        <tr>
            <td style="width:66%;">
                <div class="notes">
                    <h3>Notes</h3>
                    <p>Merci pour votre confiance.</p>
                    <p>Cette facture constitue une pièce justificative de vente.</p>
                    <p>Médicaments ni repris ni échangés après livraison, sauf disposition particulière.</p>
                </div>
            </td>
            <td style="width:34%;">
                <div class="totals-box">
                    <table class="totals-table">
                        <tr>
                            <th>Sous-total</th>
                            <td class="right">{{ vente.getBaseTotal()|number_format(0, ',', ' ') }} FCFA</td>
                        </tr>
                        <tr>
                            <th>Timbre</th>
                            <td class="right">{{ vente.getTimbreAmount()|number_format(0, ',', ' ') }} FCFA</td>
                        </tr>
                        <tr class="grand-total">
                            <th>Total</th>
                            <td class="right">{{ vente.total|number_format(0, ',', ' ') }} FCFA</td>
                        </tr>
                    </table>
                </div>
            </td>
        </tr>
    </table>

    <div class="footer-block">
        <table class="footer-table">
            <tr>
                <td style="width:58%;" class="footer-left">
                    <div><strong>Montant arrêté à :</strong> {{ vente.total|number_format(0, ',', ' ') }} FCFA</div>
                    <div>Document généré automatiquement par le système de gestion de la Clinique Médicale Nassarawa.</div>
                </td>
                <td style="width:18%;" class="qr">
                    {% if qr_data is defined and qr_data %}
                        <img src="{{ qr_data }}" alt="QR Code">
                    {% endif %}
                    {% if code_qr is defined and code_qr %}
                        <small>Code : {{ code_qr }}</small>
                    {% endif %}
                    <small>Scanner pour vérification</small>
                </td>
                <td style="width:24%;" class="sign">
                    <div class="sign-line">Signature / Cachet</div>
                </td>
            </tr>
        </table>
    </div>
</div>
</body>
</html>