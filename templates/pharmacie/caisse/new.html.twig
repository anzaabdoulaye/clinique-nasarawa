{% extends 'base.html.twig' %}

{% block title %}Nouvelle vente{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h3 class="mb-1 fw-bold">
                <i class="ri-shopping-cart-2-line text-success me-2"></i>
                Nouvelle vente
            </h3>
            <p class="text-muted mb-0">
                Enregistrez une vente de médicaments et ajoutez plusieurs lignes si nécessaire.
            </p>
        </div>

        <div>
            <a href="{{ path('app_caisse_index') }}" class="btn btn-outline-secondary">
                <i class="ri-arrow-left-line me-1"></i> Retour à la caisse
            </a>
        </div>
    </div>

    <div class="row g-4">
        {# Formulaire principal #}
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h5 class="mb-1 fw-semibold">
                        <i class="ri-file-list-3-line text-primary me-2"></i>
                        Saisie de la vente
                    </h5>
                    <p class="text-muted mb-0 small">
                        Ajoutez les produits vendus, quantités et prix unitaires.
                    </p>
                </div>

                <div class="card-body p-4">
                    {{ form_start(form) }}

                    {% if form.vars.errors|length > 0 %}
                        <div class="alert alert-danger border-0 rounded-3">
                            {{ form_errors(form) }}
                        </div>
                    {% endif %}

                    <div id="ventes-lignes" class="vente-lignes-wrapper">
                        {{ form_widget(form.lignes) }}
                    </div>

                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-stretch align-items-sm-center gap-2 mt-4 pt-3 border-top">
                        <a href="{{ path('app_caisse_index') }}" class="btn btn-light border">
                            <i class="ri-close-line me-1"></i> Annuler
                        </a>

                        <button type="submit" class="btn btn-success px-4">
                            <i class="ri-save-3-line me-1"></i> Enregistrer la vente
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        {# Panneau latéral d'aide #}
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="ri-information-line text-info me-2"></i>
                        Informations utiles
                    </h5>

                    <div class="d-flex flex-column gap-3">
                        <div class="info-box">
                            <div class="info-icon bg-primary-subtle text-primary">
                                <i class="ri-capsule-line"></i>
                            </div>
                            <div>
                                <h6 class="mb-1">Sélection des médicaments</h6>
                                <p class="text-muted mb-0 small">
                                    Choisissez les produits vendus pour générer les lignes de vente.
                                </p>
                            </div>
                        </div>

                        <div class="info-box">
                            <div class="info-icon bg-warning-subtle text-warning">
                                <i class="ri-stack-line"></i>
                            </div>
                            <div>
                                <h6 class="mb-1">Gestion des quantités</h6>
                                <p class="text-muted mb-0 small">
                                    Vérifiez les quantités saisies pour éviter un dépassement du stock disponible.
                                </p>
                            </div>
                        </div>

                        <div class="info-box">
                            <div class="info-icon bg-success-subtle text-success">
                                <i class="ri-money-dollar-circle-line"></i>
                            </div>
                            <div>
                                <h6 class="mb-1">Validation</h6>
                                <p class="text-muted mb-0 small">
                                    Une fois la vente enregistrée, le stock sera décrémenté selon les règles prévues.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="ri-lightbulb-flash-line text-warning me-2"></i>
                        Conseils
                    </h5>

                    <ul class="text-muted small ps-3 mb-0">
                        <li class="mb-2">Ajoutez une ligne par médicament vendu.</li>
                        <li class="mb-2">Contrôlez le prix unitaire avant validation.</li>
                        <li class="mb-2">Supprimez les lignes inutiles avant l’enregistrement.</li>
                        <li>Utilisez le bouton d’ajout dynamique pour les ventes multiples.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .vente-lignes-wrapper > div {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .vente-lignes-wrapper .form-group,
    .vente-lignes-wrapper .row,
    .vente-lignes-wrapper .sf-fieldset,
    .vente-lignes-wrapper .ligne-vente-item {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 1rem;
        padding: 1rem;
        box-shadow: 0 0.125rem 0.5rem rgba(0,0,0,.03);
    }

    .info-box {
        display: flex;
        gap: 0.875rem;
        align-items: flex-start;
    }

    .info-icon {
        width: 42px;
        height: 42px;
        min-width: 42px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
    }

    .card {
        overflow: hidden;
    }

    .medicament-search-host {
        position: relative;
    }

    .medicament-search-dropdown {
        position: absolute;
        top: calc(100% + 0.35rem);
        left: 0;
        right: 0;
        z-index: 30;
        background: #fff;
        border: 1px solid #dbe3ea;
        border-radius: 0.9rem;
        box-shadow: 0 1rem 2rem rgba(15, 23, 42, 0.10);
        max-height: 280px;
        overflow-y: auto;
        padding: 0.35rem;
    }

    .medicament-search-result {
        width: 100%;
        border: 0;
        background: transparent;
        text-align: left;
        padding: 0.75rem 0.85rem;
        border-radius: 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
    }

    .medicament-search-result:hover,
    .medicament-search-result.is-active {
        background: #f1f5f9;
    }

    .medicament-search-result__title {
        font-weight: 600;
        color: #0f172a;
    }

    .medicament-search-result__meta,
    .medicament-search-empty {
        font-size: 0.82rem;
        color: #64748b;
    }

    .medicament-search-empty {
        padding: 0.8rem 0.9rem;
    }

    .medicament-search-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
        margin-top: 0.5rem;
    }

    .lot-selector-wrapper {
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: 0.65rem 0.85rem;
        background: #f8fafc;
    }

    .lot-selector-wrapper.d-none {
        display: none !important;
    }

    .lot-pick-btn {
        font-size: 0.82rem;
        border-radius: 0.5rem;
    }

    .lot-pick-btn.btn-primary {
        pointer-events: none;
    }

    @media (max-width: 768px) {
        .vente-lignes-wrapper .form-group,
        .vente-lignes-wrapper .row,
        .vente-lignes-wrapper .sf-fieldset,
        .vente-lignes-wrapper .ligne-vente-item {
            padding: 0.85rem;
        }
    }
</style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/pharmacie-caisse.js') }}?v=20260401-lot-selection"></script>
{% endblock %}