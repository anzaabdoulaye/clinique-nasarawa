{% extends 'base.html.twig' %}

{% block title %}Détails lot{% endblock %}

{% block body %}
<div class="container-fluid">
    {% set expireSoon = lot.datePeremption and lot.datePeremption <= date('+30 days') %}
    {% set expired = lot.datePeremption and lot.datePeremption < date() %}
    {% set stockEmpty = lot.quantite <= 0 %}
    {% set stockLow = lot.quantite > 0 and lot.quantite <= 10 %}

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h3 class="mb-1 fw-bold">
                <i class="ri-archive-line text-primary me-2"></i>
                Détails du lot
            </h3>
            <p class="text-muted mb-0">
                Consultation complète des informations du lot
                <strong>{{ lot.numeroLot ?: ('#' ~ lot.id) }}</strong>.
            </p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a href="{{ path('app_lot_edit', {id: lot.id}) }}" class="btn btn-primary">
                <i class="ri-pencil-line me-1"></i> Modifier
            </a>
            <a href="{{ path('app_lot_index') }}" class="btn btn-outline-secondary">
                <i class="ri-arrow-left-line me-1"></i> Retour à la liste
            </a>
        </div>
    </div>

    <div class="row g-4">
        {# Bloc principal #}
        <div class="col-12 col-xl-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 p-4 pb-0">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
                        <div>
                            <h4 class="mb-1 fw-semibold">
                                Lot {{ lot.numeroLot ?: lot.id }}
                            </h4>
                            <div class="text-muted">
                                Médicament :
                                <strong>{{ lot.medicament ? lot.medicament.nom : 'Non renseigné' }}</strong>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            {% if expired %}
                                <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                    Expiré
                                </span>
                            {% elseif expireSoon %}
                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                    Péremption proche
                                </span>
                            {% else %}
                                <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                    Valide
                                </span>
                            {% endif %}

                            {% if stockEmpty %}
                                <span class="badge bg-danger px-3 py-2">Stock épuisé</span>
                            {% elseif stockLow %}
                                <span class="badge bg-warning text-dark px-3 py-2">Stock faible</span>
                            {% else %}
                                <span class="badge bg-primary px-3 py-2">Stock disponible</span>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Médicament</div>
                                <div class="info-value">
                                    {{ lot.medicament ? lot.medicament.nom : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Numéro de lot</div>
                                <div class="info-value">
                                    {{ lot.numeroLot ?: '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Date de péremption</div>
                                <div class="info-value">
                                    {{ lot.datePeremption ? lot.datePeremption|date('d/m/Y') : '—' }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Quantité disponible</div>
                                <div class="info-value">
                                    {{ lot.quantite }}
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Prix d’achat</div>
                                <div class="info-value">
                                    {{ lot.prixAchat|number_format(0, ',', ' ') }} FCFA
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="info-card">
                                <div class="info-label">Identifiant</div>
                                <div class="info-value">
                                    #{{ lot.id }}
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="border-top pt-4 mt-4 d-flex flex-wrap gap-2">
                        <a href="{{ path('app_lot_edit', {id: lot.id}) }}" class="btn btn-primary">
                            <i class="ri-edit-line me-1"></i> Modifier ce lot
                        </a>
                        <a href="{{ path('app_lot_index') }}" class="btn btn-light border">
                            <i class="ri-list-check-2 me-1"></i> Voir tous les lots
                        </a>
                    </div>
                </div>
            </div>
        </div>

        {# Colonne latérale #}
        <div class="col-12 col-xl-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="ri-bar-chart-box-line text-info me-2"></i>
                        État du lot
                    </h5>

                    <div class="d-flex flex-column gap-3">
                        <div class="state-box">
                            <span class="state-label">Disponibilité</span>
                            <span class="state-value">
                                {% if stockEmpty %}
                                    <span class="text-danger fw-semibold">Épuisé</span>
                                {% elseif stockLow %}
                                    <span class="text-warning fw-semibold">Faible</span>
                                {% else %}
                                    <span class="text-success fw-semibold">Disponible</span>
                                {% endif %}
                            </span>
                        </div>

                        <div class="state-box">
                            <span class="state-label">Péremption</span>
                            <span class="state-value">
                                {% if expired %}
                                    <span class="text-danger fw-semibold">Expiré</span>
                                {% elseif expireSoon %}
                                    <span class="text-warning fw-semibold">Proche</span>
                                {% else %}
                                    <span class="text-success fw-semibold">Correcte</span>
                                {% endif %}
                            </span>
                        </div>

                        <div class="state-box">
                            <span class="state-label">Quantité</span>
                            <span class="state-value fw-semibold">{{ lot.quantite }}</span>
                        </div>

                        <div class="state-box">
                            <span class="state-label">Valeur estimée</span>
                            <span class="state-value fw-semibold">
                                {{ (lot.quantite * lot.prixAchat)|number_format(0, ',', ' ') }} FCFA
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h5 class="fw-semibold mb-3">
                        <i class="ri-lightbulb-flash-line text-warning me-2"></i>
                        Recommandations
                    </h5>

                    <ul class="small text-muted ps-3 mb-0">
                        {% if expired %}
                            <li class="mb-2">Ce lot est expiré et ne devrait plus être utilisé pour la vente.</li>
                        {% elseif expireSoon %}
                            <li class="mb-2">Ce lot arrive bientôt à péremption, privilégiez son écoulement.</li>
                        {% else %}
                            <li class="mb-2">Le lot est encore exploitable selon la date de péremption enregistrée.</li>
                        {% endif %}

                        {% if stockEmpty %}
                            <li class="mb-2">Le stock est nul, un réapprovisionnement peut être nécessaire.</li>
                        {% elseif stockLow %}
                            <li class="mb-2">Le niveau de stock est faible, surveillez les prochaines ventes.</li>
                        {% else %}
                            <li class="mb-2">Le niveau de stock reste exploitable pour les opérations courantes.</li>
                        {% endif %}

                        <li>Vérifiez régulièrement la cohérence entre stock physique et stock système.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .info-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 1rem;
        padding: 1rem 1.1rem;
        height: 100%;
    }

    .info-label {
        font-size: .82rem;
        color: #6c757d;
        margin-bottom: .35rem;
    }

    .info-value {
        font-size: 1rem;
        font-weight: 600;
        color: #212529;
        word-break: break-word;
    }

    .state-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .9rem 1rem;
        border: 1px solid #e9ecef;
        border-radius: .9rem;
        background: #fff;
    }

    .state-label {
        color: #6c757d;
        font-size: .92rem;
    }

    .state-value {
        color: #212529;
        text-align: right;
    }

    .card {
        overflow: hidden;
    }
</style>
{% endblock %}