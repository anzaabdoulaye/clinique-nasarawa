{% extends 'base.html.twig' %}

{% block title %}Hospitalisation #{{ hospitalisation.id }}{% endblock %}

{% block body %}
<style>
    .hs-wrap { max-width: 1100px; margin: 0 auto; }
    .hs-card { border: 1px solid rgba(0,0,0,.06); border-radius: 16px; background: #fff; }
    .hs-card .card-header { background: #fff; border-bottom: 1px solid rgba(0,0,0,.06); border-top-left-radius: 16px; border-top-right-radius: 16px; }
    .hs-kv { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 16px; }
    @media (max-width: 768px) { .hs-kv { grid-template-columns: 1fr; } }
    .hs-field { border: 1px solid rgba(0,0,0,.06); border-radius: 14px; padding: 12px; background: #fff; }
    .hs-label { font-size: 11px; color: #6b7280; font-weight: 800; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 4px; }
    .hs-value { font-size: 14px; font-weight: 650; color: #111827; }
    .hs-section { border: 1px solid rgba(0,0,0,.06); border-radius: 16px; background: #fff; padding: 16px; margin-bottom: 20px; }
    .hs-section-title { font-weight: 800; font-size: 14px; color: #111827; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .hs-text { white-space: pre-line; color: #374151; font-size: 14px; line-height: 1.5; }
    .badge-soft { border: 1px solid rgba(0,0,0,.08); padding: .4rem .7rem; border-radius: 999px; font-weight: 700; font-size: 12px; }

    .table-soins th {
        font-size: 10px;
        background: #f9fafb;
        text-align: center;
        padding: 8px 4px;
    }

    .hour-cell {
        width: 40px;
        height: 40px;
        padding: 0 !important;
        vertical-align: middle;
        text-align: center;
        border: 1px solid #edf2f7;
    }

    .medic-col {
        width: 160px;
    }

    .medic-text {
        max-width: 160px;
        white-space: normal;
        word-break: break-word;
    }

    .scheduled-cell {
        background: #f3f4f6;
    }

    .hour-active {
        background-color: #0d6efd !important;
        color: #fff !important;
    }

    .hour-missed {
        background: #f8d7da !important;
    }

    .hour-upcoming {
        background: #fff3cd !important;
    }

    .admin-cell-btn {
        width: 100%;
        height: 100%;
        min-height: 40px;
        border: none;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        padding: 0;
    }

    .admin-cell-btn:hover {
        background: rgba(13, 110, 253, 0.08);
    }

    .hour-active .admin-cell-btn:hover {
        background: transparent;
    }

    .admin-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: #6c757d;
        display: inline-block;
    }

    .alert-strip {
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 13px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .alert-strip-danger {
        background: #f8d7da;
        color: #842029;
        border: 1px solid #f1aeb5;
    }

    .alert-strip-warning {
        background: #fff3cd;
        color: #664d03;
        border: 1px solid #ffecb5;
    }

    .badge-alert {
        display: inline-block;
        padding: 4px 8px;
        border-radius: 999px;
        font-size: 11px;
        font-weight: 700;
        margin-top: 6px;
        margin-right: 4px;
    }

    .badge-alert-info {
        background: #e7f1ff;
        color: #0a58ca;
    }

    .badge-alert-warning {
        background: #fff3cd;
        color: #997404;
    }

    .badge-alert-danger {
        background: #f8d7da;
        color: #842029;
    }
</style>

{# Initialisation des variables #}
{% set statut = hospitalisation.statut.value ?? hospitalisation.statut %}
{% set patient = hospitalisation.dossierMedical.patient ?? null %}
{% set today = "now"|date("Y-m-d") %}
{% set currentHour = "now"|date("G") %}
{% set missedCount = 0 %}
{% set endingTodayCount = 0 %}

{% for t in hospitalisation.traitements %}
    {% if t.dateFin and t.dateFin|date("Y-m-d") == today %}
        {% set endingTodayCount = endingTodayCount + 1 %}
    {% endif %}

    {% if t.dateDebut and t.dateFin and t.dateDebut|date("Y-m-d") <= today and t.dateFin|date("Y-m-d") >= today %}
        {% for h in t.heuresAdministration %}
            {% if h < currentHour and not t.isAdministeredAt("now"|date_modify("midnight"), h) %}
                {% set missedCount = missedCount + 1 %}
            {% endif %}
        {% endfor %}
    {% endif %}
{% endfor %}

<div class="hs-wrap mt-4">
    {# ====== ENTÊTE ====== #}
    <div class="card hs-card shadow-sm border-0 mb-4">
        <div class="card-header py-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <h5 class="mb-0 fw-bold">
                        <i class="fa fa-procedures me-2 text-primary"></i>
                        Hospitalisation #{{ hospitalisation.id }}
                    </h5>
                    <small class="text-muted">
                        Patient : <strong>{{ patient ? patient.nom|upper ~ ' ' ~ patient.prenom : 'Non défini' }}</strong>
                    </small>
                </div>

                <div class="d-flex gap-2">
                    <span class="badge-soft {{ statut in ['TERMINE','SORTIE'] ? 'bg-success-subtle text-success' : 'bg-warning-subtle text-warning' }}">
                        {{ statut|upper }}
                    </span>
                    <a href="{{ path('app_hospitalisation_index') }}" class="btn btn-light border btn-sm">
                        <i class="fa fa-arrow-left me-1"></i> Retour
                    </a>
                    <button type="button" class="btn btn-outline-primary btn-sm js-ajax-modal" 
                            data-url="{{ path('app_hospitalisation_edit', {'id': hospitalisation.id}) }}"
                            data-title="Modifier l'hospitalisation">
                        <i class="fa fa-pen me-1"></i> Modifier
                    </button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="window.print()">
                        <i class="fa fa-print me-1"></i> Imprimer
                    </button>
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="hs-kv mb-4">
                <div class="hs-field">
                    <div class="hs-label">Dossier Médical</div>
                    <div class="hs-value">{{ hospitalisation.dossierMedical.numeroDossier ?? 'N/A' }}</div>
                </div>
                <div class="hs-field">
                    <div class="hs-label">Médecin Référent</div>
                    <div class="hs-value">{{ hospitalisation.medecinReferent ? hospitalisation.medecinReferent.nom ~ '  ' ~ hospitalisation.medecinReferent.prenom : 'Non assigné' }}</div>
                </div>
                <div class="hs-field">
                    <div class="hs-label">Date Admission</div>
                    <div class="hs-value text-primary">{{ hospitalisation.dateAdmission ? hospitalisation.dateAdmission|date('d/m/Y H:i') : '—' }}</div>
                </div>
                <div class="hs-field">
                    <div class="hs-label">Date Sortie Prévue / Effective</div>
                    <div class="hs-value">{{ hospitalisation.dateSortie ? hospitalisation.dateSortie|date('d/m/Y H:i') : 'En cours' }}</div>
                </div>
            </div>

            <div class="row g-3">
                <div class="col-12">
                    <div class="hs-section">
                        <div class="hs-section-title"><i class="fa fa-clipboard-list text-primary"></i> Motif d'admission</div>
                        <div class="hs-text">{{ hospitalisation.motifAdmission ?: 'Aucun motif renseigné.' }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="hs-section h-100">
                        <div class="hs-section-title"><i class="fa fa-notes-medical text-primary"></i> Histoire de la maladie</div>
                        <div class="hs-text">{{ hospitalisation.histoireMaladie ?: '—' }}</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="hs-section h-100">
                        <div class="hs-section-title"><i class="fa fa-chart-line text-primary"></i> Évolution</div>
                        <div class="hs-text">{{ hospitalisation.evolution ?: '—' }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ====== PLAN DE TRAITEMENT (FEUILLE DE SOINS) ====== #}
    <div class="hs-section shadow-sm">
        <div class="hs-section-title d-flex justify-content-between align-items-center">
            <span><i class="fa fa-pills text-primary"></i> Plan de Traitement / Feuille de Soins</span>
            <button type="button" class="btn btn-sm btn-primary js-ajax-modal"
                    data-url="{{ path('app_traitement_hospitalisation_new', {'hospitalisation': hospitalisation.id}) }}"
                    data-title="Ajouter un nouveau traitement">
                <i class="fa fa-plus me-1"></i> Ajouter un traitement
            </button>
        </div>

        {% if missedCount > 0 %}
            <div class="alert-strip alert-strip-danger">
                ⚠ {{ missedCount }} administration(s) manquée(s) aujourd’hui.
            </div>
        {% endif %}

        {% if endingTodayCount > 0 %}
            <div class="alert-strip alert-strip-warning">
                ⏳ {{ endingTodayCount }} traitement(s) se termine(nt) aujourd’hui.
            </div>
        {% endif %}

        <div class="table-responsive">
            <table class="table table-bordered align-middle table-soins">
                <thead>
                    <tr>
                        <th class="text-start medic-col">Médicament / Soin</th>
                        <th style="min-width: 100px;">Période</th>
                        {% for h in 0..23 %}
                            <th class="hour-cell">{{ h }}h</th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody>
                    {% for t in hospitalisation.traitements %}
                        {% set startTs = t.dateDebut ? t.dateDebut|date('U') : null %}
                        {% set endTs = t.dateFin ? t.dateFin|date('U') : null %}
                        {% set dayCount = (startTs and endTs and endTs >= startTs)
                            ? ((endTs - startTs) / 86400)|round(0, 'floor')
                            : 0
                        %}

                        {% for i in 0..dayCount %}
                            {% set currentDate = t.dateDebut|date_modify('+' ~ i ~ ' day') %}

                            <tr>
                                {% if i == 0 %}
                                    <td class="text-start fw-bold small medic-text" rowspan="{{ dayCount + 1 }}">
                                        <div>{{ t.description }}</div>

                                        {% if t.dateDebut and t.dateFin and t.dateDebut|date("Y-m-d") <= today and t.dateFin|date("Y-m-d") >= today %}
                                            <span class="badge-alert badge-alert-info">Actif aujourd’hui</span>
                                        {% endif %}

                                        {% if t.dateFin and t.dateFin|date("Y-m-d") == today %}
                                            <span class="badge-alert badge-alert-warning">Fin aujourd’hui</span>
                                        {% endif %}

                                        {% if t.heuresAdministration is empty %}
                                            <span class="badge-alert badge-alert-danger">Aucune heure</span>
                                        {% endif %}
                                    </td>
                                {% endif %}

                                <td class="text-muted small">
                                    {{ currentDate|date('d/m/Y') }}
                                </td>

                                {% for h in 0..23 %}
                                    {% set scheduled = h in t.heuresAdministration %}
                                    {% set administered = t.isAdministeredAt(currentDate, h) %}
                                    {% set isToday = currentDate|date('Y-m-d') == today %}
                                    {% set missed = scheduled and isToday and h < currentHour and not administered %}
                                    {% set upcoming = scheduled and isToday and h == currentHour and not administered %}

                                    <td class="hour-cell {{ scheduled ? 'scheduled-cell' : '' }} {{ administered ? 'hour-active' : '' }} {{ missed ? 'hour-missed' : '' }} {{ upcoming ? 'hour-upcoming' : '' }}">
                                        {% if scheduled %}
                                            <button
                                                type="button"
                                                class="admin-cell-btn js-admin-toggle"
                                                data-url="{{ path('app_administration_traitement_toggle', {'id': t.id}) }}"
                                                data-date="{{ currentDate|date('Y-m-d') }}"
                                                data-heure="{{ h }}"
                                                title="{% if administered %}Administré{% elseif missed %}Administration manquée{% elseif upcoming %}À administrer maintenant{% else %}Prévu{% endif %}"
                                            >
                                                {% if administered %}
                                                    <i class="fa fa-check text-white"></i>
                                                {% elseif missed %}
                                                    <i class="fa fa-exclamation text-danger"></i>
                                                {% else %}
                                                    <span class="admin-dot"></span>
                                                {% endif %}
                                            </button>
                                        {% endif %}
                                    </td>
                                {% endfor %}
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="26" class="text-center py-4 text-muted small">
                                Aucun traitement enregistré.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="ajaxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title fw-bold" id="ajaxModalTitle">Chargement...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="ajaxModalBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalElement = document.getElementById('ajaxModal');
            const modalBody = document.getElementById('ajaxModalBody');
            const modalTitle = document.getElementById('ajaxModalTitle');

            if (!modalElement || !modalBody || !modalTitle) {
                return;
            }

            const ajaxModal = new bootstrap.Modal(modalElement);

            const xhrHeaders = {
                'X-Requested-With': 'XMLHttpRequest'
            };

            document.addEventListener('click', async function (e) {
                const btn = e.target.closest('.js-ajax-modal');
                if (!btn) return;

                e.preventDefault();

                const url = btn.dataset.url;
                const title = btn.dataset.title || 'Formulaire';

                modalTitle.textContent = title;
                modalBody.innerHTML = `
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                    </div>
                `;
                ajaxModal.show();

                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        headers: xhrHeaders
                    });

                    const contentType = response.headers.get('content-type') || '';

                    if (contentType.includes('application/json')) {
                        const data = await response.json();
                        if (data.form) {
                            modalBody.innerHTML = data.form;
                            bindAjaxForm(modalBody.querySelector('form'));
                        } else {
                            modalBody.innerHTML = `
                                <div class="alert alert-danger mb-0">
                                    Impossible de charger le formulaire.
                                </div>
                            `;
                        }
                    } else {
                        modalBody.innerHTML = await response.text();
                        bindAjaxForm(modalBody.querySelector('form'));
                    }
                } catch (error) {
                    console.error('Erreur chargement modal :', error);
                    modalBody.innerHTML = `
                        <div class="alert alert-danger mb-0">
                            Une erreur est survenue lors du chargement.
                        </div>
                    `;
                }
            });

            function bindAjaxForm(form) {
                if (!form) return;

                form.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const submitBtn = form.querySelector('button[type="submit"]');
                    if (submitBtn) {
                        submitBtn.disabled = true;
                    }

                    const action = form.getAttribute('action') || window.location.href;
                    const formData = new FormData(form);

                    try {
                        const response = await fetch(action, {
                            method: 'POST',
                            body: formData,
                            headers: xhrHeaders
                        });

                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.includes('application/json')) {
                            const data = await response.json();

                            if (data.success) {
                                ajaxModal.hide();
                                window.location.reload();
                                return;
                            }

                            if (data.form) {
                                modalBody.innerHTML = data.form;
                                bindAjaxForm(modalBody.querySelector('form'));
                                return;
                            }

                            let errorsHtml = '';
                            if (Array.isArray(data.errors) && data.errors.length > 0) {
                                errorsHtml = `
                                    <div class="alert alert-danger">
                                        <ul class="mb-0">
                                            ${data.errors.map(error => `<li>${error}</li>`).join('')}
                                        </ul>
                                    </div>
                                `;
                            } else {
                                errorsHtml = `
                                    <div class="alert alert-danger">
                                        Le formulaire contient des erreurs.
                                    </div>
                                `;
                            }

                            modalBody.innerHTML = errorsHtml + modalBody.innerHTML;
                        } else {
                            // HTML response (form re-rendered with errors)
                            modalBody.innerHTML = await response.text();
                            bindAjaxForm(modalBody.querySelector('form'));
                        }

                    } catch (error) {
                        console.error('Erreur soumission formulaire :', error);
                        modalBody.innerHTML = `
                            <div class="alert alert-danger mb-0">
                                Une erreur est survenue lors de l'enregistrement.
                            </div>
                        `;
                    } finally {
                        if (submitBtn) {
                            submitBtn.disabled = false;
                        }
                    }
                });
            }
        });
    </script>

    <script>
        document.addEventListener('click', async function (e) {
            const btn = e.target.closest('.js-admin-toggle');
            if (!btn) return;

            e.preventDefault();

            const url = btn.dataset.url;
            const date = btn.dataset.date;
            const heure = btn.dataset.heure;

            const formData = new FormData();
            formData.append('date', date);
            formData.append('heure', heure);

            try {
                const response = await fetch(url, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                const data = await response.json();

                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.message || 'Erreur lors de la mise à jour.');
                }
            } catch (error) {
                console.error(error);
                alert('Erreur serveur.');
            }
        });
    </script>
{% endblock %}