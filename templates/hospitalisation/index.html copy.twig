{% extends 'base.html.twig' %}

{% block title %}Hospitalisation{% endblock %}

{% block body %}
<div class="row">
  <div class="col-12">

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-0 py-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <h5 class="mb-0 fw-semibold">
              <i class="fa fa-bed me-2 text-primary"></i> Hospitalisations
            </h5>
            <div class="text-muted small">Suivi des hospitalisations</div>
          </div>

          <div class="d-flex flex-wrap align-items-center gap-2">
            <form method="get" action="{{ path('app_hospitalisation_index') }}" class="d-flex align-items-center gap-2">
              <div class="position-relative">
                <input
                  type="text"
                  id="hospitalisationSearchInput"
                  name="search"
                  class="form-control ps-4"
                  placeholder="Code patient, N° dossier ou téléphone"
                  value="{{ search|default('') }}"
                  style="min-width: 320px;"
                >
                <span class="position-absolute top-50 start-0 translate-middle-y ms-2 text-muted">
                  <i class="fa fa-search"></i>
                </span>
              </div>

              <button class="btn btn-primary">
                <i class="fa fa-search me-1"></i> Rechercher
              </button>

              {% if search %}
                <a href="{{ path('app_hospitalisation_index') }}" class="btn btn-light border">
                  Réinitialiser
                </a>
              {% endif %}
            </form>

            <button type="button"
                    class="btn btn-primary"
                    data-bs-toggle="modal"
                    data-bs-target="#addHospitalisationModal">
              <i class="fa fa-plus me-1"></i> Nouvelle hospitalisation
            </button>
          </div>
        </div>
      </div>

      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Date admission</th>
                <th>Date sortie</th>
                <th>Motif</th>
                <th>Dossier / Patient</th>
                <th>Statut</th>
                <th>Créé le</th>
                <th>Actions</th>
              </tr>
            </thead>

            <tbody>
            {% for h in hospitalisations %}
              {% set dossier = h.dossierMedical ?? null %}
              {% set patient = dossier ? dossier.patient : null %}

              <tr>
                <td>
                  {{ h.dateAdmission ? h.dateAdmission|date('d/m/Y H:i') : '-' }}
                </td>

                <td>
                  {{ h.dateSortie ? h.dateSortie|date('d/m/Y H:i') : '-' }}
                </td>

                <td class="text-start">
                  {{ h.motifAdmission ? h.motifAdmission|u.truncate(80, '…', false) : '-' }}
                </td>

                <td style="min-width: 260px;">
                  {% if patient %}
                    <div class="fw-semibold">
                      <i class="fa fa-folder-open me-1 text-muted"></i>
                      {{ dossier.numeroDossier ?? '—' }}
                    </div>

                    <div class="small text-muted">
                      {{ patient.nom }} {{ patient.prenom ?? '' }}
                    </div>

                    <div class="small text-muted">
                      {{ patient.telephone ?? '—' }}
                    </div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td>
                  <span class="badge bg-light text-dark border">
                    {{ h.statut.value ?? '—' }}
                  </span>
                </td>

                <td>
                  {{ h.createdAt ? h.createdAt|date('d/m/Y H:i') : '-' }}
                </td>

                <td>
                  <div class="btn-group btn-group-sm">

                    <a class="btn btn-outline-secondary"
                       href="{{ path('app_hospitalisation_show', {'id': h.id}) }}">
                      <i class="fa fa-eye"></i>
                    </a>

                    <a class="btn btn-outline-secondary"
                       href="{{ path('app_hospitalisation_print', {'id': h.id}) }}"
                       target="_blank">
                      <i class="fa fa-print"></i>
                    </a>

                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_RH') %}
                      <button type="button"
                              class="btn btn-outline-primary js-edit-hospitalisation"
                              data-url="{{ path('app_hospitalisation_edit', {'id': h.id}) }}"
                              data-bs-toggle="modal"
                              data-bs-target="#editHospitalisationModal">
                        <i class="ri-pencil-fill"></i>
                      </button>
                    {% endif %}
                  </div>
                </td>
              </tr>

            {% else %}
              <tr>
                <td colspan="7" class="text-center text-muted py-4">
                  Aucun enregistrement
                </td>
              </tr>
            {% endfor %}
            </tbody>

          </table>
        </div>
      </div>
    </div>

  </div>
</div>
{% endblock %}