{% extends 'base.html.twig' %}

{% block title %}Hospitalisations{% endblock %}

{% block body %}
<div class="row">
  <div class="col-12">

    <div class="card shadow-sm border-0">
      <div class="card-header bg-white border-0 py-3">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <h5 class="mb-0 fw-semibold">
              <i class="fa fa-procedures me-2 text-primary"></i> Hospitalisations
            </h5>
            <div class="text-muted small">Suivi des admissions, évolutions et sorties</div>
          </div>

          <button type="button"
                  class="btn btn-primary"
                  data-bs-toggle="modal"
                  data-bs-target="#addHospitalisationModal">
            <i class="fa fa-plus me-1"></i> Nouvelle hospitalisation
          </button>
        </div>
      </div>

      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 datatable">
            <thead class="table-light">
              <tr class="text-nowrap">
                <th class="text-uppercase small text-muted">Patient</th>
                <th class="text-uppercase small text-muted">N° Dossier</th>
                <th class="text-uppercase small text-muted">Admission</th>
                <th class="text-uppercase small text-muted">Sortie</th>
                <th class="text-uppercase small text-muted">Motif</th>
                <th class="text-uppercase small text-muted">Statut</th>
                <th class="text-uppercase small text-muted">Médecin</th>
                <th class="text-uppercase small text-muted">Créé</th>
                <th class="text-uppercase small text-muted">Modifié</th>
                <th class="text-uppercase small text-muted text-end" style="width: 210px;">Actions</th>
              </tr>
            </thead>

            <tbody>
            {% for hospitalisation in hospitalisations %}
              {% set statut = hospitalisation.statut.value ?? hospitalisation.statut.name ?? hospitalisation.statut ?? '' %}
              {% set patient = hospitalisation.dossierMedical ? hospitalisation.dossierMedical.patient : null %}
              <tr>
                <td class="text-nowrap">
                  {% if patient %}
                    <div class="fw-semibold">{{ patient.nom }} {{ patient.prenom }}</div>
                    <div class="small text-muted">{{ patient.telephone ?? '' }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.dossierMedical %}
                    <span class="badge bg-primary-subtle text-primary border">{{ hospitalisation.dossierMedical.numeroDossier }}</span>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.dateAdmission %}
                    <div class="fw-semibold">{{ hospitalisation.dateAdmission|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ hospitalisation.dateAdmission|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.dateSortie %}
                    <div class="fw-semibold">{{ hospitalisation.dateSortie|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ hospitalisation.dateSortie|date('H:i') }}</div>
                  {% else %}
                    <span class="badge bg-light text-muted border">Non sortie</span>
                  {% endif %}
                </td>

                <td class="text-start" style="min-width: 180px;">
                  {{ hospitalisation.motifAdmission ?: '—' }}
                </td>

                <td class="text-nowrap">
                  {% if statut %}
                    {% set badgeStatut =
                      statut in ['EN_COURS','ENCOURS','ACTIVE'] ? 'bg-warning-subtle text-warning border' :
                      (statut in ['TERMINE','TERMINEE','CLOTURE','CLOSED'] ? 'bg-success-subtle text-success border' :
                      (statut in ['ANNULE','ANNULEE','CANCELED'] ? 'bg-danger-subtle text-danger border' :
                      'bg-light text-muted border'))
                    %}
                    <span class="badge {{ badgeStatut }}">{{ statut }}</span>
                  {% else %}
                    <span class="badge bg-light text-muted border">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.medecinReferent %}
                    <div class="fw-semibold">{{ hospitalisation.medecinReferent.nom ?? '' }} {{ hospitalisation.medecinReferent.prenom ?? '' }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.createdAt %}
                    <div class="fw-semibold">{{ hospitalisation.createdAt|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ hospitalisation.createdAt|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-nowrap">
                  {% if hospitalisation.modifiedAt %}
                    <div class="fw-semibold">{{ hospitalisation.modifiedAt|date('d/m/Y') }}</div>
                    <div class="small text-muted">{{ hospitalisation.modifiedAt|date('H:i') }}</div>
                  {% else %}
                    <span class="text-muted">—</span>
                  {% endif %}
                </td>

                <td class="text-end">
                  <div class="btn-group btn-group-sm" role="group" aria-label="Actions hospitalisation">
                    <a class="btn btn-outline-secondary"
                       href="{{ path('app_hospitalisation_show', {'id': hospitalisation.id}) }}"
                       title="Voir">
                      <i class="fa fa-eye me-1"></i> Voir
                    </a>

                    <a class="btn btn-outline-info"
                       href="{{ path('app_hospitalisation_print', {'id': hospitalisation.id}) }}"
                       target="_blank"
                       title="Imprimer PDF">
                      <i class="fa fa-file-pdf me-1"></i> PDF
                    </a>

                    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_RH') %}
                      <button type="button"
                              class="btn btn-outline-primary js-edit-hospitalisation"
                              title="Modifier"
                              data-bs-toggle="modal"
                              data-bs-target="#editHospitalisationModal"
                              data-url="{{ path('app_hospitalisation_edit', {'id': hospitalisation.id}) }}">
                        <i class="ri-pencil-fill"></i>
                      </button>
                    {% endif %}
                  </div>
                </td>
              </tr>

            {% endfor %}
            </tbody>

          </table>
        </div>
      </div>
    </div>

  </div>
</div>

{# =========================
   MODAL AJOUT
========================= #}
<div class="modal fade" id="addHospitalisationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-plus me-2 text-primary"></i> Nouvelle hospitalisation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
  <style>
    .h-form .form-label{ font-weight:700; }
    .h-form .required:after{ content:" *"; color:#dc3545; font-weight:900; }
    .h-form .form-control, .h-form .form-select{ border-radius:12px; }
    .h-form .section{
      border:1px solid rgba(0,0,0,.06);
      border-radius:14px;
      padding:14px;
      background:#fff;
      margin-bottom:12px;
    }
    .h-form .section-title{
      font-weight:800;
      font-size:.95rem;
      margin-bottom:10px;
      color:#111827;
      display:flex;
      align-items:center;
      gap:8px;
    }
  </style>

  {{ form_start(form, {'attr': {'id': 'HospitalisationForm', 'class': 'h-form', 'novalidate': 'novalidate'}}) }}

  {% if form_errors(form) %}
    <div class="alert alert-danger d-flex gap-2 align-items-start">
      <i class="fa fa-triangle-exclamation mt-1"></i>
      <div>
        <div class="fw-semibold">Veuillez corriger les erreurs du formulaire.</div>
        <div class="small">{{ form_errors(form) }}</div>
      </div>
    </div>
  {% endif %}

  <div class="section">
    <div class="section-title"><i class="fa fa-folder-open text-primary"></i> Informations principales</div>
    <div class="row g-3">
      <div class="col-12 col-md-6">
        {{ form_label(form.dossierMedical, null, {'label_attr': {'class': 'form-label required'}}) }}
        {{ form_widget(form.dossierMedical) }}
        {{ form_errors(form.dossierMedical) }}
      </div>

      <div class="col-12 col-md-6">
        {{ form_label(form.medecinReferent, null, {'label_attr': {'class': 'form-label required'}}) }}
        {{ form_widget(form.medecinReferent) }}
        {{ form_errors(form.medecinReferent) }}
      </div>

      <div class="col-12 col-md-6">
        {{ form_label(form.dateAdmission, null, {'label_attr': {'class': 'form-label required'}}) }}
        {{ form_widget(form.dateAdmission) }}
        {{ form_errors(form.dateAdmission) }}
      </div>

      <div class="col-12 col-md-6">
        {{ form_label(form.statut, null, {'label_attr': {'class': 'form-label required'}}) }}
        {{ form_widget(form.statut) }}
        {{ form_errors(form.statut) }}
      </div>

      <div class="col-12 col-md-6">
        {{ form_label(form.dateSortie, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.dateSortie) }}
        <div class="form-text">{{ form_help(form.dateSortie) }}</div>
        {{ form_errors(form.dateSortie) }}
      </div>

      <div class="col-12">
        {{ form_label(form.motifAdmission, null, {'label_attr': {'class': 'form-label required'}}) }}
        {{ form_widget(form.motifAdmission) }}
        {{ form_errors(form.motifAdmission) }}
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title"><i class="fa fa-notes-medical text-primary"></i> Détails médicaux</div>
    <div class="row g-3">
      <div class="col-12">
        {{ form_label(form.histoireMaladie, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.histoireMaladie) }}
        {{ form_errors(form.histoireMaladie) }}
      </div>

      <div class="col-12">
        {{ form_label(form.evolution, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.evolution) }}
        {{ form_errors(form.evolution) }}
      </div>

      <div class="col-12">
        {{ form_label(form.conclusion, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.conclusion) }}
        {{ form_errors(form.conclusion) }}
      </div>
    </div>
  </div>

  <div class="section">
    <div class="section-title"><i class="fa fa-stethoscope text-primary"></i> Examens</div>
    <div class="row g-3">
      <div class="col-12 col-md-6">
        {{ form_label(form.examenClinique, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.examenClinique) }}
        {{ form_errors(form.examenClinique) }}
      </div>

      <div class="col-12 col-md-6">
        {{ form_label(form.examenNeurologique, null, {'label_attr': {'class': 'form-label'}}) }}
        {{ form_widget(form.examenNeurologique) }}
        {{ form_errors(form.examenNeurologique) }}
      </div>
    </div>
  </div>

  {{ form_rest(form) }}

  <div class="d-flex justify-content-end mt-3 gap-2">
    <button type="reset" class="btn btn-light border">Vider</button>
    <button type="submit" class="btn btn-primary">
      <i class="fa fa-save me-1"></i> Enregistrer
    </button>
  </div>

  {{ form_end(form, {'render_rest': false}) }}
</div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fermer</button>
      </div>

    </div>
  </div>
</div>

{# =========================
   MODAL EDIT (AJAX)
========================= #}
<div class="modal fade" id="editHospitalisationModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
    <div class="modal-content border-0 shadow">

      <div class="modal-header bg-white">
        <h5 class="modal-title fw-semibold">
          <i class="fa fa-pen me-2 text-primary"></i> Modifier hospitalisation
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <div class="py-5 text-center" id="editHospitalisationLoader">
          <div class="spinner-border" role="status" aria-hidden="true"></div>
          <div class="mt-2 text-muted small">Chargement du formulaire…</div>
        </div>
        <div id="editHospitalisationModalBody" class="d-none"></div>
      </div>

      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Fermer</button>
      </div>

    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    (function () {
      const editModalEl = document.getElementById('editHospitalisationModal');
      const loader = document.getElementById('editHospitalisationLoader');
      const body = document.getElementById('editHospitalisationModalBody');

      let currentUrl = null;

      function setLoading() {
        loader.classList.remove('d-none');
        body.classList.add('d-none');
        body.innerHTML = '';
      }

      function showError(message) {
        loader.classList.add('d-none');
        body.classList.remove('d-none');
        body.innerHTML = `
          <div class="alert alert-danger d-flex align-items-start gap-2 mb-0" role="alert">
            <i class="fa fa-exclamation-triangle mt-1"></i>
            <div>
              <div class="fw-semibold">Erreur</div>
              <div class="small">${message || 'Impossible de charger le formulaire.'}</div>
            </div>
          </div>
        `;
      }

      function focusFirstField() {
        const first = body.querySelector('input, select, textarea');
        if (first) first.focus();
      }

      async function loadEditForm(url) {
        currentUrl = url;
        setLoading();

        const res = await fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
        if (!res.ok) throw new Error('HTTP ' + res.status);

        body.innerHTML = await res.text();
        loader.classList.add('d-none');
        body.classList.remove('d-none');

        focusFirstField();
        bindSubmit();
      }

      function bindSubmit() {
        const form = body.querySelector('form');
        if (!form) return;

        if (form.dataset.bound === '1') return;
        form.dataset.bound = '1';

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const submitBtn = form.querySelector('[type="submit"]');
          const oldHtml = submitBtn ? submitBtn.innerHTML : null;

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span> Enregistrement...`;
          }

          try {
            const formData = new FormData(form);
            const submitUrl = form.getAttribute('action') || currentUrl;
            const method = (form.getAttribute('method') || 'POST').toUpperCase();

            const res = await fetch(submitUrl, {
              method,
              body: formData,
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });

            const contentType = res.headers.get('content-type') || '';

            if (contentType.includes('application/json')) {
              const json = await res.json();
              if (json.success) {
                bootstrap.Modal.getInstance(editModalEl)?.hide();
                window.location.reload();
                return;
              }
              // JSON sans success → recharger le formulaire
              await loadEditForm(currentUrl);
              return;
            }

            // HTML → formulaire re-rendu avec erreurs
            body.innerHTML = await res.text();
            focusFirstField();
            bindSubmit();
          } catch (err) {
            showError("Une erreur est survenue lors de l'enregistrement.");
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = oldHtml;
            }
          }
        });
      }

      // Délégation click
      document.addEventListener('click', (e) => {
        const btn = e.target.closest('.js-edit-hospitalisation');
        if (!btn) return;

        const url = btn.getAttribute('data-url');
        if (!url) return;

        loadEditForm(url).catch(() => {
          showError("Impossible de charger le formulaire. Vérifie la route et la réponse AJAX.");
        });
      });

      editModalEl?.addEventListener('hidden.bs.modal', () => {
        currentUrl = null;
        setLoading();
      });
    })();
  </script>
{% endblock %}